{% import "rz_merged.j2" as game_merged %}
{% import "snippets.j2" as snippets %}
{% import "snippets/gi.j2" as snippet_gi %}
{% import "snippets/zzz.j2" as snippet_zzz %}
{% import "snippets/hsr.j2" as snippet_hsr %}
{% import "snippets/face_module.j2" as snippet_face %}
{% import "modules/core.j2" as core %}
{% import "modules/data.j2" as data %}
{% import "modules/functions.j2" as fn %}
{% import "modules/keymap.j2" as keymap %}
{% import "modules/elements.j2" as elements %}
{% import "modules/elements_helpers.j2" as elements_helpers %}
{% import "modules/modules.j2" as modules %}
;RZMenu2.9.5
{% if mod_file.game.name %}
;{{mod_file.game.name}}
{% endif %}

{% block overridesbuffers %}
    {{snippets.overridesbuffers_pre(mod_file,scene)}}
	{{  game_merged.overridesbuffers(mod_file,scene) }}
    {{snippets.overridesbuffers_post(mod_file,scene)}}
{% endblock %}

{% block overridesibs %}
    {{snippets.overridesibs_pre(mod_file,scene)}}
	{{  game_merged.overridesibs(mod_file,scene) }}
    {{snippets.overridesibs_post(mod_file,scene)}}
{% endblock %}

{% block resourcebuffers %}
    {{snippets.resourcebuffers_pre(mod_file,scene)}}
	{{  game_merged.resourcebuffers(mod_file,scene) }}
    {{snippets.resourcebuffers_post(mod_file,scene)}}
{% endblock %}

{% block resourcetextures %}
    {{snippets.resourcetextures_pre(mod_file,scene)}}
    {{game_merged.resourcetextures(mod_file,scene)}}
    {{core.menu_resource_ui(mod_file,scene)}}
    {{snippets.resourcetextures_post(mod_file,scene)}}
	{% if mod_file.game.name == "GenshinImpact"%}
	{% elif mod_file.game.name == "ZenlessZoneZero"%}
	{% elif mod_file.game.name == "HonkaiStarRail"%}
	{% endif %}
{% endblock %}

{% block rz_menu_core %}
{{core.entryPoint(mod_file,scene)}}
{{core.baseCompute(mod_file,scene)}}
{{core.menuDrawUi(mod_file,scene)}}
{{core.shape_generate(mod_file,scene)}}
{% endblock %}

{{fn.Base()}}

[CommandListClickedSlot]

{% if scene.rzm %}
	{{ elements_helpers.popup_helpers_generate(mod_file,scene)}}
	{{ elements_helpers.resources_generate(mod_file,scene)}}
	{{ elements_helpers.grid_helpers_generate(mod_file,scene)}}

	{{modules.generate_addons(mod_file,scene)}}
	{{elements.elements_generate(mod_file,scene)}}

	{% if mod_file.game.name == "GenshinImpact"%}
	{{snippet_gi.snippet()}}
	{% elif mod_file.game.name == "ZenlessZoneZero"%}
	{{snippet_zzz.snippet()}}
	{% elif mod_file.game.name == "HonkaiStarRail"%}
	{{snippet_hsr.snippet()}}
	{% endif %}
{% endif %}

{% if scene.rzm %}
{% if scene.rzm.conditions %}
	{% for condition in scene.rzm.conditions %}
		{% if condition %}
			[TextureOverride{{condition.condition_name}}]
			hash = {{condition.condition_hash}}
			match_priority = 24
			${{condition.condition_name}} = 1
		{% endif %}
	{%endfor%}
{% endif %}
{% endif %}

{% block rz_menu_data %}
{{keymap.main_button(mod_file,scene)}}
{{data.config(mod_file,scene)}}
{% endblock %}

{{snippet_face.snippet()}}
{# Experimental RZM segmented transform export.
   This file intentionally depends on rzm_export_cache instead of mod_file.
   It is a test target for splitting shape/VFX-transform runtime away from
   the main game exporter INI. #}
{% import "modules/utils.j2" as utils with context %}
{% import "modules/shapes_native.j2" as shapes_native with context %}
{% import "modules/weights_native.j2" as weights_native with context %}

; RZM EXPERIMENTAL TRANSFORM SEGMENT
; Generated by rzm.export_transform_segment
; Source cache exists: {{ rzm_export_cache is not none }}
{% if rzm_export_cache %}
; Cache source: {{ rzm_export_cache.source }}
; Cache mod: {{ rzm_export_cache.mod_name }}
; Cache components: {{ rzm_export_cache.components | length if rzm_export_cache.components is defined else 0 }}
{% endif %}

;[META-INFO] [START] [MOD-BLOCK]

{% if not rzm_export_cache or rzm_export_cache.components is not defined or not rzm_export_cache.components %}
; ERROR: RZM export cache is missing. Run Full Export or Game Buffers first.
{% else %}

; --- RZM TRANSFORM BASE INIT ---
; Copies exported base buffers into the resources mutated by shape/weight/VFX
; compute passes. The component list comes from rzm_export_cache.
[CommandListRZMTransformObjectDataInit]
{% for base_name, comp_data in rzm_export_cache.components.items() %}
    {% set raw_comp_name = rzm_export_cache.mod_name ~ base_name if rzm_export_cache.source == 'xxmi' else base_name %}
    {% set comp_name = utils.format_from_idiot(raw_comp_name) %}
    {% if scene.rzm.game.selection in ["ArknightsEndfield", "WutheringWaves"] %}
Resource_{{ comp_name }}_VB0 = copy Resource{{ comp_name }}_Base
    {% else %}
Resource{{ comp_name }}Position = copy Resource{{ comp_name }}_Base
    {% endif %}
{% endfor %}

; --- RZM SHAPE / WEIGHT RUNTIME ---
{{ shapes_native.shape_generate(scene=scene, game_name=scene.rzm.game.name) }}
{{ weights_native.weight_generate(scene=scene, game_name=scene.rzm.game.name) }}

; --- RZM VFX RUNTIME NOTE ---
; VFX buffer patching already uses the same export cache, but the full VFX INI
; shader blocks still live in rz_MERGED_HOYO.j2 and are tied to mod_file.parts.
; This placeholder keeps the shape Present hook resolvable while the VFX section
; is migrated to a cache-driven module.
{% set has_vfx_curves = [false] %}
{% if scene and scene.objects %}
    {% for obj in scene.objects if obj.type == 'CURVE' and (obj.get('RZM.CURVE_VFX') or obj.rzm_curve_vfx_enabled) %}
        {% if has_vfx_curves.append(true) %}{% endif %}
    {% endfor %}
{% endif %}
{% if has_vfx_curves[-1] %}
[CommandListRZM_VFX_Present]
; TODO: cache-driven VFX shader blocks will move here.
{% endif %}

{% endif %}

;[META-INFO] [END] [MOD-BLOCK]

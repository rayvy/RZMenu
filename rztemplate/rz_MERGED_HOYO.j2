    {#--- ОБРАБОТКА КОМПОНЕНТОВ ТОЛЬКО С POSITION БУФЕРОМ (без blend) ---#}
    {% for component in mod_file.components if component.draw_vb != "" and component.blend_vb == "" %}
        [TextureOverride{{ component.fullname }}]

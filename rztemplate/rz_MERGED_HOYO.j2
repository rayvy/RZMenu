{% import "rz_helper.j2" as helper with context %}
{% import "modules/utils.j2" as utils with context %}

{% macro get_vfx_vertex_count(scene, component) %}
    {%- set assoc_curves = [] -%}
    {%- if scene and scene.objects -%}
        {%- for obj in scene.objects if obj.type == 'CURVE' and obj.get('RZM.CURVE_VFX') -%}
            {%- for col in obj.users_collection -%}
                {%- for part in component.parts -%}
                    {%- for entry in part.objects if entry.vertex_count > 0 -%}
                        {%- for col_obj in col.objects if col_obj.name == entry.name -%}
                            {%- if obj not in assoc_curves -%}
                                {%- if assoc_curves.append(obj) %}{% endif -%}
                            {%- endif -%}
                        {%- endfor -%}
                    {%- endfor -%}
                {%- endfor -%}
            {%- endfor -%}
        {%- endfor -%}
    {%- endif -%}
    {%- set result = [0] -%}
    {%- for curve in assoc_curves -%}
        {%- set p_count = curve.get("RZM.CURVE_VFX.PARTICLE_COUNT") | default(1) | int -%}
        {%- set fx_type = curve.get("RZM.CURVE_VFX.MESH_FX_TYPE") | default(0) | int -%}
        {%- set vpp = 3 -%}
        {%- if fx_type == 1 -%}{%- set vpp = 4 -%}{%- endif -%}
        {%- if fx_type == 2 -%}{%- set vpp = 7 -%}{%- endif -%}
        {# fx_type 3 = Custom Mesh stub → fallback triangle (vpp stays 3) #}
        {%- if result.append(result.pop() + p_count * vpp) %}{% endif -%}
    {%- endfor -%}
    {{- result[-1] -}}
{%- endmacro %}


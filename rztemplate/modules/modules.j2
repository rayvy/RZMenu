{% import "modules/elements.j2" as elements with context %}
{% import "modules/utils.j2" as utils with context %}

{% import "modules/debug_snippet.j2" as debug_snippet with context %}


{%macro generate_addons(mod_file,scene)%}
{% if scene.rzm.addons %}
;Addons Activity

{% if scene.rzm.addons.debugger_info == 1 %}
[Constants]
global persist $RZM_DEBUG_VALUE_0 = {{ scene.rzm.addons.debug_var_0 if scene.rzm.addons.debug_var_0 else "0" }}
global persist $RZM_DEBUG_VALUE_1 = {{ scene.rzm.addons.debug_var_1 if scene.rzm.addons.debug_var_1 else "0" }}
global persist $RZM_DEBUG_VALUE_2 = {{ scene.rzm.addons.debug_var_2 if scene.rzm.addons.debug_var_2 else "0" }}
global persist $RZM_DEBUG_VALUE_3 = {{ scene.rzm.addons.debug_var_3 if scene.rzm.addons.debug_var_3 else "0" }}
global persist $RZM_DEBUG_VALUE_4 = {{ scene.rzm.addons.debug_var_4 if scene.rzm.addons.debug_var_4 else "0" }}
global persist $RZM_DEBUG_VALUE_5 = {{ scene.rzm.addons.debug_var_5 if scene.rzm.addons.debug_var_5 else "0" }}
global persist $RZM_DEBUG_VALUE_6 = {{ scene.rzm.addons.debug_var_6 if scene.rzm.addons.debug_var_6 else "0" }}
global persist $RZM_DEBUG_VALUE_7 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_8 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_9 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_10 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_11 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_12 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_13 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_14 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_15 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_16 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}
global persist $RZM_DEBUG_VALUE_17 = {{ scene.rzm.addons.debug_var_7 if scene.rzm.addons.debug_var_7 else "0" }}

[CommandListElementDebug]
; Hover ID Debug
$drawType = 4
$PositionX = 200
$PositionY = -64
$sizeX = (1000) * $sizeMultiplier
$sizeY = (100) * $sizeMultiplier
$colorR = 1
$colorG = 0
$colorB = 1
$colorA = 1
$TexPosX = $hoveredID
run = CustomShaderRCI2D

{% for i in range(17) %}
$PositionY = $PositionY + 100
$TexPosX = $RZM_DEBUG_VALUE_{{ i }}
run = CustomShaderRCI2D
{% endfor %}
{% endif %}

{% if scene.rzm.addons.frame_trace == 1 %}
{% set ft_objects = [] %}
{% if scene and scene.objects %}
    {% for obj in scene.objects %}
        {% if obj.get('CustomDraw.FRAMETRACE') is not none %}
            {% if ft_objects.append(obj) %}{% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{% for obj in ft_objects %}
    {% set safe_name = utils.format_from_idiot(obj.name) %}
    {% set speed = scene.rzm.addons.frame_trace_speed | default(32) | int %}
    {% set length = scene.rzm.addons.frame_trace_length | default(128) | int %}
    {% set threshold = scene.rzm.addons.frame_trace_threshold | default(0.25) | float %}

    {# Locate draw count / index count #}
    {% set ns_vcount = [0] %}
    {% if mod_file and mod_file.components %}
        {% for component in mod_file.components %}
            {% for part in component.parts %}
                {% for entry in part.objects %}
                    {% if entry.name == obj.name %}
                        {% if ns_vcount.append(entry.index_count) %}{% endif %}
                    {% endif %}
                {% endfor %}
            {% endfor %}
        {% endfor %}
    {% endif %}
    {% if ns_vcount[-1] == 0 and rzm_export_cache and rzm_export_cache.components %}
        {% for comp_name, comp_data in rzm_export_cache.components.items() %}
            {% for cache_obj in comp_data.objects %}
                {% if cache_obj.name == obj.name %}
                    {% if ns_vcount.append(cache_obj.ib_count | default(0)) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
    {% endif %}
    {% set final_vcount = ns_vcount[-1] if ns_vcount[-1] > 0 else 1024 %}

[Constants]
global ${{ safe_name }}_Sandevistan_Speed = {{ speed }}
global ${{ safe_name }}_Sandevistan_length = {{ length }}
global ${{ safe_name }}_SandevistanTime = 0
global ${{ safe_name }}_Sandevistan_Base_Interval = 1
;CDC - is Component Draw Count
;CDO - is Component Draw Offset
;global $CDC_{{ safe_name }}_Sandevistan = 0
;global $CDO_{{ safe_name }}_Sandevistan = 0
; Distance threshold (world units) — how far character must move to record next ghost
global ${{ safe_name }}_Sandevistan_Threshold = {{ threshold }}

[Present]
if $first_run
	${{ safe_name }}_SandevistanTime = time + (${{ safe_name }}_Sandevistan_Base_Interval / ${{ safe_name }}_Sandevistan_Speed)
endif

[CustomShader{{ safe_name }}Sandevistan]
vs = /modules/trace_vs_Sandevistan.hlsl
ps = /modules/trace_ps_Sandevistan.hlsl
x0 = $CDC_{{ safe_name }}_Sandevistan
x1 = ${{ safe_name }}_Sandevistan_length
; x2 removed — current_index is now GPU-side at the end of Coords buffer
vs-t1 = Resource_{{ safe_name }}_Sandevistan_MERGED_VB0
vs-t127 = Resource_{{ safe_name }}_Sandevistan_Buffer

drawindexedinstanced = $CDC_{{ safe_name }}_Sandevistan, ${{ safe_name }}_Sandevistan_length, $CDO_{{ safe_name }}_Sandevistan, 0, 0
run = CommandListSwapC0_{{ safe_name }}

[CustomShaderComputeSandevistan_{{ safe_name }}]
; Pure GPU adaptive position recorder — no store, no CPU readback
cs = /modules/ouroboros_adaptive_pos.hlsl
cs-u0 = Resource_{{ safe_name }}_Sandevistan_Buffer
cs-cb1 = vs-cb1
x1 = ${{ safe_name }}_Sandevistan_length
; x3 = distance threshold to advance index
x3 = ${{ safe_name }}_Sandevistan_Threshold
dispatch = 1, 1, 1

[CommandListSwapC0_{{ safe_name }}]
; Timer gates dispatch frequency to avoid driver/API call overhead every frame
if (time) >= ${{ safe_name }}_SandevistanTime
	run = CustomShaderComputeSandevistan_{{ safe_name }}
	run = CustomShaderWriteSandevistan_{{ safe_name }}
	${{ safe_name }}_SandevistanTime = time + (${{ safe_name }}_Sandevistan_Base_Interval / ${{ safe_name }}_Sandevistan_Speed)
endif

[CustomShaderWriteSandevistan_{{ safe_name }}]
; Adaptive VB recorder — skips copy if GPU state indicates no movement
cs-t0 = vb0
cs-u0 = ResourceOutput_{{ safe_name }}
; cs-t1: reads the did_write and write slot index from Coords buffer on GPU
cs-t1 = Resource_{{ safe_name }}_Sandevistan_Buffer
cs = /modules/ouroboros_adaptive_vb.hlsl
x0 = $CDC_{{ safe_name }}_Sandevistan
x1 = ${{ safe_name }}_Sandevistan_length
dispatch = $CDC_{{ safe_name }}_Sandevistan + 1023 // 1024, 1, 1
Resource_{{ safe_name }}_Sandevistan_MERGED_VB0 = cs-u0

[Resource_{{ safe_name }}_Sandevistan_MERGED_VB0]

[Resource_{{ safe_name }}_Sandevistan_Buffer]
type = RWBuffer
format = R32G32B32A32_FLOAT
; We add +1 float4 at the end of the array to store current_write_index, did_write flag and pre-advance slot index
array = {{ length * 4 + 1 }}

[ResourceOutput_{{ safe_name }}]
type = RWStructuredBuffer
stride = 40
array = {{ final_vcount * length }}
;{{final_vcount}}
;{{length}}
{% endfor %}
{% endif %}
{{ generate_blend_resize(mod_file, scene) }}
{% endif %}
{%endmacro%}

{# --- BLEND RESIZE ADDON --- #}
{% macro generate_blend_resize(mod_file, scene) %}
{% if scene.rzm.addons.blend_resize and scene.rzm.addons.blend_resize.is_enabled %}
[Constants]
{# Define 12 master slots #}
{% for group in scene.rzm.addons.blend_resize.groups %}
    {% set var_name = "BR_SLOT_" ~ group.slot_id %}
    global persist ${{ var_name }} = 0
{% endfor %}

[Present]
{% for group in scene.rzm.addons.blend_resize.groups %}
    {% set var_name = "BR_SLOT_" ~ group.slot_id %}
    {% if group.value_link %}
        ${{ var_name }} = ${{ utils.format_var(group.value_link) | trim }}
    {% else %}
        ${{ var_name }} = 0
    {% endif %}
{% endfor %}

[CustomShaderBlendResize]
vs = ./modules/BlendResize.hlsl
{# Pass the 12 slots as scalars in registers 88, 87, 86 #}
{% set groups_by_slot = {} %}
{% for group in scene.rzm.addons.blend_resize.groups %}
    {% set _ = groups_by_slot.update({group.slot_id: group}) %}
{% endfor %}

{# Register 86 (Slots 0-3) #}
x86 = ${{ "BR_SLOT_0" if 0 in groups_by_slot else "PV" }}
y86 = ${{ "BR_SLOT_1" if 1 in groups_by_slot else "PV" }}
z86 = ${{ "BR_SLOT_2" if 2 in groups_by_slot else "PV" }}
w86 = ${{ "BR_SLOT_3" if 3 in groups_by_slot else "PV" }}

{# Register 87 (Slots 4-7) #}
x87 = ${{ "BR_SLOT_4" if 4 in groups_by_slot else "PV" }}
y87 = ${{ "BR_SLOT_5" if 5 in groups_by_slot else "PV" }}
z87 = ${{ "BR_SLOT_6" if 6 in groups_by_slot else "PV" }}
w87 = ${{ "BR_SLOT_7" if 7 in groups_by_slot else "PV" }}

{# Register 88 (Slots 8-11) #}
x88 = ${{ "BR_SLOT_8" if 8 in groups_by_slot else "PV" }}
y88 = ${{ "BR_SLOT_9" if 9 in groups_by_slot else "PV" }}
z88 = ${{ "BR_SLOT_10" if 10 in groups_by_slot else "PV" }}
w88 = ${{ "BR_SLOT_11" if 11 in groups_by_slot else "PV" }}

{# Register 89 (Slots 12-15) #}
x89 = ${{ "BR_SLOT_12" if 12 in groups_by_slot else "PV" }}
y89 = ${{ "BR_SLOT_13" if 13 in groups_by_slot else "PV" }}
z89 = ${{ "BR_SLOT_14" if 14 in groups_by_slot else "PV" }}
w89 = ${{ "BR_SLOT_15" if 15 in groups_by_slot else "PV" }}

ResourceTempT1 = copy vs-t1
{# vs-t1 will be set per-component in rz_MERGED_HOYO.j2 #}
handling = skip
draw = auto
post vs-t1 = ResourceTempT1
[ResourceTempT1]
{% endif %}
{% endmacro %}
    cs-t0 = Resource_Makeup_Mouth.1
elif $FaceDecal_Makeup_Mouth_0Index == 2
    cs-t0 = Resource_Makeup_Mouth.2
elif $FaceDecal_Makeup_Mouth_0Index == 3
    cs-t0 = Resource_Makeup_Mouth.3

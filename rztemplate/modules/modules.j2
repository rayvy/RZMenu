; =======================================================================================
; INPUTS (KEYS)
; =======================================================================================
[KeyTest5]
key = 5
type = cycle
$FaceDecal_Makeup_Mouth_0Index = -1,0,1,2,3,4
[KeyTest6]
key = 6
type = cycle
$FaceDecal_Makeup_EyeShadow_0Index = -1,0,1,2,3
[KeyTest7]
key = 7
type = cycle
$FaceDecal_Makeup_Cheeks_0Index = -1,0,1,3,4
[KeyTest9]
key = 9
type = cycle
[KeyTest10]
key = 0
type = cycle
[KeyTestK]
key = k
type = cycle
$FaceDecal_Cum_Cheeks_0Index = -1,0
$FaceDecal_Cum_Mouth_0Index = -1,0

[KeyTestR]
key = r
$TexWorksFaceFirstInit = 1



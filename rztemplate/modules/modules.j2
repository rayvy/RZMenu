    cs-t0 = Resource_Makeup_Mouth.4
endif
cs-t1 = Resource.TexWorks.Face.Mouth.Config
x44 = $TWFMouthConfigPosX
y44 = $TWFMouthConfigPosY
z44 = $TWFMouthConfigSizeW
w44 = $TWFMouthConfigSizeH
run = CommandListAddons.FaceTexWorks.Material.Null
if $FaceDecal_Makeup_Mouth_0Index >= 0
    dispatch = ($TWFMouthConfigSizeW + 31) // 32, ($TWFMouthConfigSizeH + 31) //32, 1
endif

[CustomShaderDeum.Mouth]

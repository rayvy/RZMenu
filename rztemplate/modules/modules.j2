cs-u0 = ref ResourceFaceDiffuse
cs-t1 = Resource_Makeup_EyeLashes.MASK
x44 = $TWFEyeLashesConfigPosX
y44 = $TWFEyeLashesConfigPosY
z44 = $TWFEyeLashesConfigSizeW
w44 = $TWFEyeLashesConfigSizeH
; HSV Params
x43 = $HSV_H_EYELASHES
y43 = $HSV_S_EYELASHES
z43 = $HSV_V_EYELASHES
w43 = 1
dispatch = ($TWFEyeLashesConfigSizeW + 31) // 32, ($TWFEyeLashesConfigSizeH + 31) //32, 1

; --- MASKS FOR HSV ---
; SECTION: EYEBROWS (Mask Region Only)
[Constants]

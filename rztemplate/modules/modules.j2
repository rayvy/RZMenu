    cs-t0 = Resource_Makeup_Cheeks.4
endif
if $FaceDecal_Makeup_Cheeks_0Index >= 0
    run = CommandListAddons.FaceTexWorks.Material.Null
    ; Pass 1
    cs-t1 = Resource.TexWorks.Face.Cheeks.Config
    x44 = $TWFCheeksConfigPosX
    y44 = $TWFCheeksConfigPosY
    z44 = $TWFCheeksConfigSizeW
    w44 = $TWFCheeksConfigSizeH
    dispatch = ($TWFCheeksConfigSizeW + 31) // 32, ($TWFCheeksConfigSizeH + 31) //32, 1
    ; Pass 2

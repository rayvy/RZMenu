{%- if not (element.disable_export and not element.is_preset) -%}
{%- if element.is_preset == True or element.is_helper == True -%}
;run = CommandListElement{{ element.element_name }}
{% else -%}
run = CommandListElement{{ element.element_name }}
{% endif %}
{%- endif -%}
{%- endfor -%}

{% endif -%}
run = CommandListInteractionManager
run = CommandListNavFinalizeSearch
{% if scene.rzm %}
    {% if scene.rzm.addons %}
        {% if scene.rzm.addons.debugger_info == 1 %}
        run = CommandListElementDebug
        {% endif %}
    {% endif %}
{% endif %}
endif

[CommandListInteractionManager]
if $inputMode == 0
    $clickTriggerID = -1

    if $isMouseButtonDown == 1
        if $capturedID == -1
            if $hoveredID != -1
                $capturedID = $hoveredID
            else
                $capturedID = -2
            endif
            $holdTimer = 0.0
        endif
        
        if $capturedID > -1
            $holdTimer = $holdTimer + $dt
        endif
    else
        if $capturedID != -1
            if $capturedID > -1 && $holdTimer < $holdThreshold
                $clickTriggerID = $capturedID
            endif
            
            $capturedID = -1
            $dragState = 0
            $holdTimer = 0.0
        endif
    endif
endif


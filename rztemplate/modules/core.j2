[CommandListRZMain]
if $ModInitialised != 1
    $initFrame = $initFrame + 1
endif
if $initFrame > 3 && $ModInitialised != 1
{% if scene.rzm %}
    {% if scene.rzm.addons.tex_works == 1 %}
    run = CommandListTexWorks
    ;run = CommandListAddonsFaceTexWorks
    {% endif %}
{% endif %}
    $ModInitialised = 1
endif

if $active
    if $first_run
            {% if scene.rzm.shapes %}
            {% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 %}
                {% if component.strides %}
                    Resource{{ component.fullname }}Position = copy Resource{{ component.fullname }}_Base
                    {% if mod_file.game.name == "HonkaiStarRail" %}
                    Resource{{ component.fullname }}PositionCS = copyResource{{ component.fullname }}CS_Base
                    {% endif %}
                {% endif %}
            {% endfor %}
            run = CustomShaderComputeShapes
        {% endif %}
        $first_run = 0
    endif
    {% if scene.rzm.shapes %}
    ;run = CustomShaderComputeShapes
    {% endif %}
    run = CommandListPreSnippet
    run = CommandListTexWorks
    run = CommandListEntryPoint
    run = CommandListPostSnippet
endif

post $active = 0
post $isGameMenu = 0
post $di_count = 0
post $data_offset = 10

[CommandListEntryPoint]
if $menu
run = CustomShaderDI2D
run = CommandListBaseDataCompute
run = CommandListGamepadProcessInput
x85 = $window0AreaX
w85 = $window0AreaY
z85 = $window0AreaZ
w85 = $window0AreaW
{% if scene.rzm and scene.rzm.elements %}
{%- for element in scene.rzm.elements if element.parent_id == -1 -%}
{%- if not (element.disable_export and not element.is_preset) -%}
{%- if element.is_preset == True or element.is_helper == True -%}
;run = CommandListElement{{ element.element_name }}_{{ element.id }}
{% else -%}
run = CommandListElement{{ element.element_name }}_{{ element.id }}
{% endif %}
{%- endif -%}
{%- endfor -%}

{% endif -%}
run = CommandListInteractionManager
run = CommandListNavFinalizeSearch
{% if scene.rzm %}
    {% if scene.rzm.addons %}
        {% if scene.rzm.addons.debugger_info == 1 %}
        run = CommandListElementDebug
        {% endif %}
    {% endif %}
{% endif %}
endif

[CommandListInteractionManager]
if $inputMode == 0
    $clickTriggerID = -1

    if $isMouseButtonDown == 1
        if $capturedID == -1
            if $hoveredID != -1
                $capturedID = $hoveredID
            else
                $capturedID = -2
            endif
            $holdTimer = 0.0
        endif
        
        if $capturedID > -1
            $holdTimer = $holdTimer + $dt
        endif
    else
        if $capturedID != -1
            if $capturedID > -1 && $holdTimer < $holdThreshold
                $clickTriggerID = $capturedID
            endif
            
            $capturedID = -1
            $dragState = 0
            $holdTimer = 0.0
        endif
    endif
endif


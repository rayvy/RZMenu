{# ========================================================
   RZM HOVER DETECT: per-component CustomShader definitions
   and the global pin CommandList.

   Generated only when the mod has hoverable objects.
   ======================================================== #}
{%macro hoverDetectShaders(mod_file,scene)%}
{# Collect components with hoverable objects #}
{% set _hover_comps = [] %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% set _comp_has = {'found': false} %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _comp_has.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        {% if _comp_has.found %}
            {% if _hover_comps.append(component) %}{% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if _hover_comps | length > 0 %}
; ============================================================
; RZM Hover Detect - per-component bake and detect shaders
; ============================================================

{% for component in _hover_comps %}
[CustomShaderRZMDetect{{ component.fullname }}]
; Component-level GPU cursor hit detector.
; cs-t2 = ObjectMap (hoverable objects in this component)
; cs-u0 = shared accumulator (closest hit across all dispatches)
cs = /modules/rzm_object_detect.hlsl
cs-t0 = vb0
cs-t1 = ib
cs-t2 = ResourceRZMDetect{{ component.fullname }}ObjectMap
cs-t3 = ResourceRZMBakeRT
cs-u0 = ResourceRZMDetectID
x24 = $cursorX
y24 = $cursorY
z24 = $screenW
w24 = $screenH
x25 = $isMouseButtonDown
w26 = 8.0
x27 = $cursorX
y27 = $cursorY
z27 = res_width
w27 = res_height
dispatch = 1, 1, 1

{% for part in component.parts if part.vertex_count > 0 %}
[CustomShaderRZMBake{{ part.fullname }}]
run = BuiltInCommandListUnbindAllRenderTargets
clear = ResourceRZMBakeRT 0.0
{% for slot in range(8) %}
run = CustomShaderRZMBakeSample{{ slot }}_{{ part.fullname }}
{% endfor %}

{% set part_index_count = part.objects | map(attribute='index_count') | sum %}
{% set step_size = (part_index_count // 8) if part_index_count >= 8 else 1 %}
{% for slot in range(8) %}
[CustomShaderRZMBakeSample{{ slot }}_{{ part.fullname }}]
gs = ./modules/rzm_gs_probe.hlsl
gs-t1 = Resource{{ part.fullname }}IB
ps = ./modules/rzm_gs_probe.hlsl
topology = point_list
o0 = set_viewport no_view_cache ResourceRZMBakeRT
x26 = {{ slot }}
y26 = {{ slot * step_size }}
drawindexed = 1, {{ slot * step_size }}, 0

{% endfor %}
{% endfor %}
{% endfor %}

; ============================================================
; RZM Hover Detect - pin shader
; Reads best hit from frame accumulator, writes to pinned
; R32_FLOAT ID buffer and extended info buffer, resets accumulator for next frame.
; ============================================================

[CustomShaderRZMPinDetected]
cs = /modules/rzm_pin_detected.hlsl
cs-u0 = ResourceRZMDetectID
cs-u1 = ResourceRZMPinnedDetectID
cs-u2 = ResourceRZMPinnedDetectInfo
dispatch = 1, 1, 1

; ============================================================
; RZM Hover Detect - throttled store (called via pre run)
; store is expensive (CPU readback). Run at most once per 0.25s.
; ============================================================

[CommandListRZMPinDetected]
local $rzm_detect_next_time
local $rzm_detect_interval = 0.25

if $isMouseButtonDown == 1
    $rzm_detect_next_time = time
endif

if $inputMode == 0

if $hoveredID > 0
	$Detected = -1
    $ObjectDetectAllowed = 0
else
    $ObjectDetectAllowed = 1
	if (time) >= $rzm_detect_next_time
		run = CustomShaderRZMPinDetected
		store = $Detected, ResourceRZMPinnedDetectID, 33
		$rzm_detect_next_time = time + $rzm_detect_interval
	endif
endif

else 
	$Detected = -1
    $ObjectDetectAllowed = 0
endif

{% endif %}
{%endmacro%}

{# ========================================================
   RZM JIGGLE INTERACTION: per-component CustomShader
   Generated when component has objects with rzm.Hover == 7.

   Phase 1: vb0 deformation, identical to prototype.
   Phase 2: per-object params via ResourceRZMJiggleParams (t68).
   ======================================================== #}
{%macro jiggleShaders(mod_file,scene)%}
{% if mod_file and mod_file.components %}
{% for component in mod_file.components if component.draw_vb != "" %}
    {# Collect jiggle objects for this component #}
    {% set _jiggle_objs = [] %}
    {% set _has_mask = {'found': false} %}
    {% for part in component.parts if part.vertex_count > 0 %}
        {% for entry in part.objects if entry.vertex_count > 0 %}
            {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
            {% if real_obj and real_obj.get('rzm.Hover', 0) | int == 7 %}
                {% set obj_id = entry.index_offset if entry.index_offset is defined else 0 %}
                {% if _jiggle_objs.append({'id': obj_id, 'obj': real_obj}) %}{% endif %}
            {% endif %}
            {% if real_obj and real_obj.type == 'MESH' %}
                {% if 'rzm_anticollider_mask' in real_obj.data.attributes or 'rzm_anticollider_mask_f32' in real_obj.data.attributes or 'MASK ANTICOLLIDER' in real_obj.vertex_groups %}
                    {% if _has_mask.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endfor %}

    {% if _jiggle_objs | length > 0 %}
; ============================================================
; RZM Jiggle Interaction — {{ component.fullname }}
; Jiggle colliders: {{ _jiggle_objs | length }}
;   IDs: {% for jo in _jiggle_objs %}{{ jo.id }}{% if not loop.last %}, {% endif %}{% endfor %}

; ============================================================

[CustomShaderRZMJiggle{{ component.fullname }}]
local $CursorXPast
local $CursorYPast
local $WasMouseButtonDown
local $back_x69 = x69
local $back_y69 = y69
local $back_z69 = z69
local $back_w69 = w69

if $isMouseButtonDown == 1
    if $WasMouseButtonDown == 0
        $CursorXPast = $cursorX
        $CursorYPast = $cursorY
        ResourceRZMDetectCapturedID_{{ component.fullname }} = copy ResourceRZMDetectID
    endif
    $WasMouseButtonDown = 1
    w67 = 1
else
    $WasMouseButtonDown = 0
    $CursorXPast = 0
    $CursorYPast = 0
    w67 = 0
endif

cs = ./modules/rzm_jiggle_interaction.hlsl

x67 = $CursorXPast
y67 = $CursorYPast

; Default physics params (overridden per-object in shader via t68)
x68 = 0.5
y68 = 1.00
z68 = 6.0
w68 = 1.00

x69 = $cursorX
y69 = $cursorY
z69 = $screenW
w69 = $screenH

x70 = 0.86
y70 = 0.176
z70 = 0.93
w70 = 0.08

x71 = 0.50
y71 = 1.10
{% if mod_file.game.name in ["ZenlessZoneZero", "GenshinImpact"] %}
z71 = -1.00
{% else %}
z71 = 1.00
{% endif %}
w71 = 0.00

; [72].x = number of jiggle collider entries in ResourceRZMJiggleParams
x72 = {{ _jiggle_objs | length }}
y72 = $rzm_jiggle_mult_radius
z72 = $rzm_jiggle_mult_strength
w72 = $rzm_jiggle_mult_spring
x73 = $rzm_jiggle_mult_damping
{% if mod_file.game.name in ["ZenlessZoneZero", "GenshinImpact"] %}
y73 = -1.00
{% else %}
y73 = 1.00
{% endif %}

cs-t67 = ResourceRZMDetectCapturedID_{{ component.fullname }}
cs-t68 = ResourceRZMJiggleParams_{{ component.fullname }}
cs-t69 = ResourceRZMDetectID
cs-t70 = ResourceRZMJiggleMask_{{ component.fullname }}

cs-u6 = ResourceRZMJiggleState_{{ component.fullname }}

ResourceRZMJiggleTempVB0_{{ component.fullname }} = vb0
cs-t24 = vb0
cs-u5 = copy ResourceRZMJiggleTempVB0_{{ component.fullname }}

Dispatch = ({{ component.vertex_count }} + 255) // 256, 1, 1

vb0 = null
ResourceRZMJiggleTempVB0_{{ component.fullname }} = copy cs-u5

post x69 = $back_x69
post y69 = $back_y69
post z69 = $back_z69
post w69 = $back_w69

    {% endif %}
{% endfor %}
{% endif %}
{%endmacro%}

{%macro baseCompute(mod_file,scene)%}
[CommandListComputeDimensions]
local $pastCursorX
local $pastCursorY
local $cursorJitter
local $cursorJitterThreshold = 4
local $cursorMovingDuration

if $CursorIsMoved == 1
$cursorMovingDuration = $cursorMovingDuration + 1
if $cursorMovingDuration >= 8
$CursorIsMoved = 0
$cursorMovingDuration = 0
endif
endif 
if $inputMode == 0
	if cursor_x > 0 && cursor_y > 0 && cursor_x < 1 && cursor_y < 1
		$cursorX = cursor_x
		$cursorY = 1.0 - cursor_y
	elif cursor_window_x > 0 && cursor_window_y > 0 && cursor_window_x < 1 && cursor_window_y < 1
		$cursorX = cursor_window_x / rt_width
		$cursorY = 1.0 - cursor_window_y / rt_height
	else
		$cursorX = cursor_screen_x / rt_height
		$cursorY = 1.0 - cursor_screen_y / rt_height

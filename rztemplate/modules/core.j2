{%macro baseCompute(mod_file,scene)%}
[CommandListBaseDataCompute]
if $inputMode == 0
    if cursor_x > 0 && cursor_y > 0 && cursor_x < 1 && cursor_y < 1
        $cursorX = cursor_x
        $cursorY = 1.0 - cursor_y
    elif cursor_window_x > 0 && cursor_window_y > 0 && cursor_window_x < 1 && cursor_window_y < 1
        $cursorX = cursor_window_x / rt_width
        $cursorY = 1.0 - cursor_window_y / rt_height
    else
        $cursorX = cursor_screen_x / rt_height
        $cursorY = 1.0 - cursor_screen_y / rt_height
    endif
endif
if window_width != 0 && window_height != 0
  $screenW = window_width
  $screenH = window_height
elif rt_width != 0 && rt_height != 0
  $screenW = rt_width
  $screenH = rt_height
else
  $screenW = res_width
  $screenH = res_height
endif

if $screenW > $screenH
	$ratioCorrection = $screenH / $screenW
else 
	$ratioCorrection = $screenW / $screenH
endif
if $inputMode == 0
    $cursorX = $cursorX * $screenW
    $cursorY = $cursorY * $screenH
endif
{% if scene.rzm %}
    {% for grid in scene.rzm.elements %}
        {% if grid.elem_class == 'GRID_CONTAINER' %}
            ${{ grid.element_name }}_new_frame = 1
        {% endif %}
    {% endfor %}
{% endif %}
$id = -1
if $inputMode == 0
$hoveredID = -1
endif
$dt = time - $ts
$ts = time
{%endmacro%}


{%macro generate_variables(mod_file,scene)%}
;macro generate_variables(mod_file,scene)
{% if scene.rzm %}
    {% if scene.rzm.rzm_values %}
        {% for value in scene.rzm.rzm_values %}
            {% if value.value_name %}
                {% if value.value_type == 'VECTOR' %}
                {% set v_name = utils.format_var(value.value_name) %}
                global persist ${{ v_name }}_X = {{ "%.3f"|format(value.vector_value[0]) }}
                global persist ${{ v_name }}_Y = {{ "%.3f"|format(value.vector_value[1]) }}
                global persist ${{ v_name }}_Z = {{ "%.3f"|format(value.vector_value[2]) }}
                global persist ${{ v_name }}_W = {{ "%.3f"|format(value.vector_value[3]) }}
                {% elif value.value_type == 'INT' or value.int_value %}
                global persist ${{utils.format_var(value.value_name)}} = {%if value.int_value != null%}{{value.int_value}}{%else%}0{%endif%}   
                {% else %}
                global persist ${{utils.format_var(value.value_name)}} = {%if value.float_value != null%}{{value.float_value}}{%else%}0.0{%endif%}    
                {%endif%}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{%endmacro%}

{% macro generate_toggle(mod_file,scene) %}
    ;macro generate_toggle(mod_file,scene)
    {# --- ИЗМЕНЕНО ЗДЕСЬ: Путь к коллекции теперь 'toggle_definitions' --- #}
{% if scene.rzm %}
    {% if scene.rzm.toggle_definitions %}
        {% for toggle in scene.rzm.toggle_definitions %}
            {% if toggle.toggle_name %}
            global persist ${{utils.format_var(toggle.toggle_name)}} = {{toggle.toggle_start_index | default(0) | int}}   
            {%endif%}
                {#{toggle.toggle_length}#}
        {% endfor %}
    {% endif %}
{% endif %}
{% endmacro %}


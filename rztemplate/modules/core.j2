{% set used_font_slots = [0] %}
{% if scene.rzm and scene.rzm.elements %}
    {% for elem in scene.rzm.elements %}
        {% if (elem.elem_class == 'TEXT' or elem.elem_class == 'BUTTON') and not elem.disable_export %}
            {% set slot = elem.font_slot | default(0) | int %}

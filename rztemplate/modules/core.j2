[CommandListInteractionManager]
if $inputMode == 0
    $clickTriggerID = -1

    if $isMouseButtonDown == 1
        if $capturedID == -1
            if $hoveredID != -1
                $capturedID = $hoveredID
            else
                $capturedID = -2
            endif
            $holdTimer = 0.0
        endif
        
        if $capturedID > -1
            $holdTimer = $holdTimer + $dt
        endif
    else
        if $capturedID != -1
            if $capturedID > -1 && $holdTimer < $holdThreshold
                $clickTriggerID = $capturedID
            endif
            
            $capturedID = -1
            $dragState = 0
            $holdTimer = 0.0
        endif
    endif
else
    $clickTriggerID = -1
endif


{% import "modules/utils.j2" as utils with context %}
{% import "modules/shapes_native.j2" as shapes_native with context %}
{% import "modules/weights_native.j2" as weights_native with context %}

{%macro generate_variables(mod_file,scene)%}
;macro generate_variables(mod_file,scene)
{% if scene.rzm %}
    {% if scene.rzm.rzm_values %}
        {% for value in scene.rzm.rzm_values %}
            {% if value.value_name %}
                {% if value.value_type == 'VECTOR' %}
                {% set v_name = utils.format_var(value.value_name) %}
                global persist ${{ v_name }}_X = {{ "%.3f"|format(value.vector_value[0]) }}
                global persist ${{ v_name }}_Y = {{ "%.3f"|format(value.vector_value[1]) }}
                global persist ${{ v_name }}_Z = {{ "%.3f"|format(value.vector_value[2]) }}
                global persist ${{ v_name }}_W = {{ "%.3f"|format(value.vector_value[3]) }}
                {% elif value.value_type == 'INT' or value.int_value %}
                global persist ${{utils.format_var(value.value_name)}} = {%if value.int_value != null%}{{value.int_value}}{%else%}0{%endif%}   
                {% else %}
                global persist ${{utils.format_var(value.value_name)}} = {%if value.float_value != null%}{{value.float_value}}{%else%}0.0{%endif%}    
                {%endif%}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{%endmacro%}

{%macro object_data_runtime(mod_file,scene)%}
{# Runtime hooks that depend on exported object/component data.
   Keep these in MOD-BLOCK so Quick Update preserves them. #}
{% set _hover_comps = [] %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% set _comp_has = {'found': false} %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _comp_has.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        {% if _comp_has.found %}
            {% if _hover_comps.append(component) %}{% endif %}
        {% endif %}
    {% endfor %}
{% endif %}
{% if _hover_comps | length > 0 %}
[Present]
;EGS калл вонючий
if $active == 1
if $ModInitialised == 1
pre run = CommandListRZMPinDetected
endif
endif
{% endif %}
{% if scene.rzm and scene.rzm.shape_configs %}
[CommandListRZMObjectDataInit]
    {% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 %}
        {% if component.strides %}
Resource{{ component.fullname }}Position = copy Resource{{ component.fullname }}_Base
            {% if mod_file.game.name == "HonkaiStarRail" %}
Resource{{ component.fullname }}PositionCS = copyResource{{ component.fullname }}CS_Base
            {% endif %}
            {% set comp_has_uv_anim = [false] %}
            {% if scene and scene.objects %}
                {% for curve in scene.objects if curve.type == 'CURVE' and curve.get('RZM.CURVE_VFX') and curve.rzm_curve_vfx_animated_uv %}
                    {% for col in curve.users_collection %}
                        {% for part in component.parts %}
                            {% for entry in part.objects %}
                                {% for col_obj in col.objects if col_obj.name == entry.name %}
                                    {% if comp_has_uv_anim.append(true) %}{% endif %}
                                {% endfor %}
                            {% endfor %}
                        {% endfor %}
                    {% endfor %}
                {% endfor %}
            {% endif %}
            {% if comp_has_uv_anim[-1] %}
Resource{{ component.fullname }}Texcoord = copy Resource{{ component.fullname }}Texcoord_Base
            {% endif %}
        {% endif %}
    {% endfor %}
run = CustomShaderComputeShapes
{% endif %}
{%endmacro%}

{%macro generate_reset_vector_values(mod_file,scene)%}
[CommandListResetVectorValues]
{% if scene.rzm %}
    {% if scene.rzm.rzm_values %}
        {% for value in scene.rzm.rzm_values %}
            {% if value.value_name and value.value_type == 'VECTOR' %}
                {% set v_name = utils.format_var(value.value_name) %}
                local $Local{{ v_name }}_X = {{ "%.3f"|format(value.vector_value[0]) }}
                local $Local{{ v_name }}_Y = {{ "%.3f"|format(value.vector_value[1]) }}
                local $Local{{ v_name }}_Z = {{ "%.3f"|format(value.vector_value[2]) }}
                local $Local{{ v_name }}_W = {{ "%.3f"|format(value.vector_value[3]) }}
                ${{ v_name }}_X = $Local{{ v_name }}_X
                ${{ v_name }}_Y = $Local{{ v_name }}_Y
                ${{ v_name }}_Z = $Local{{ v_name }}_Z
                ${{ v_name }}_W = $Local{{ v_name }}_W
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{%endmacro%}

{% macro generate_toggle(mod_file,scene) %}
    ;macro generate_toggle(mod_file,scene)
    {# --- ИЗМЕНЕНО ЗДЕСЬ: Путь к коллекции теперь 'toggle_definitions' --- #}
{% if scene.rzm %}
    {% if scene.rzm.toggle_definitions %}
        {% for toggle in scene.rzm.toggle_definitions %}
            {% if toggle.toggle_name %}
            global persist ${{utils.format_var(toggle.toggle_name)}} = {{toggle.toggle_start_index | default(0) | int}}   
            {%endif%}
                {#{toggle.toggle_length}#}
        {% endfor %}
    {% endif %}
{% endif %}
{% endmacro %}

{%macro entryPoint(mod_file,scene)%}
{# --- RZM HOVER DETECT: collect components with hoverable objects --- #}
{% set _hover_comps = [] %}
{% set _cd_flags = {
    'xray': false,
    'xray_custom': false,
    'frametrace': false,
    'rabbit0': false,
    'rabbit1': false,
    'rabbit2': false,
    'rabbit3': false,
    'rabbit4': false,
    'tex0': false,
    'tex1': false,
    'tex2': false,
    'tex3': false,
    'tex4': false,
    'transparent': false,
} %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% set _comp_has = {'found': false} %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _comp_has.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        {% if _comp_has.found %}
            {% if _hover_comps.append(component) %}{% endif %}
        {% endif %}
    {% endfor %}
{% endif %}
{% if scene and scene.objects %}
    {% for obj in scene.objects %}
        {% for key in obj.keys() if key.startswith('CustomDraw.') %}
            {% set cd_name = key[11:] %}
            {% if cd_name in ['XRAY.MASK', 'XRAY.LAYER0', 'XRAY.LAYER1', 'XRAY.LAYER2'] %}
                {% if _cd_flags.update({'xray_custom': true}) %}{% endif %}
            {% elif cd_name.startswith('XRAY') %}
                {% if _cd_flags.update({'xray': true}) %}{% endif %}
            {% elif cd_name.startswith('TRANSPARENT') %}
                {% if _cd_flags.update({'transparent': true}) %}{% endif %}
            {% elif cd_name == 'FRAMETRACE' %}
                {% if _cd_flags.update({'frametrace': true}) %}{% endif %}
            {% elif cd_name == 'RabbitFxPreset0' %}
                {% if _cd_flags.update({'rabbit0': true}) %}{% endif %}
            {% elif cd_name == 'RabbitFxPreset1' %}
                {% if _cd_flags.update({'rabbit1': true}) %}{% endif %}
            {% elif cd_name == 'RabbitFxPreset2' %}
                {% if _cd_flags.update({'rabbit2': true}) %}{% endif %}
            {% elif cd_name == 'RabbitFxPreset3' %}
                {% if _cd_flags.update({'rabbit3': true}) %}{% endif %}
            {% elif cd_name == 'RabbitFxPreset4' %}
                {% if _cd_flags.update({'rabbit4': true}) %}{% endif %}
            {% elif cd_name == 'TexFxPreset0' %}
                {% if _cd_flags.update({'tex0': true}) %}{% endif %}
            {% elif cd_name == 'TexFxPreset1' %}
                {% if _cd_flags.update({'tex1': true}) %}{% endif %}
            {% elif cd_name == 'TexFxPreset2' %}
                {% if _cd_flags.update({'tex2': true}) %}{% endif %}
            {% elif cd_name == 'TexFxPreset3' %}
                {% if _cd_flags.update({'tex3': true}) %}{% endif %}
            {% elif cd_name == 'TexFxPreset4' %}
                {% if _cd_flags.update({'tex4': true}) %}{% endif %}
            {% endif %}
        {% endfor %}
    {% endfor %}
{% endif %}
{% set has_any_hover = _hover_comps | length > 0 %}


{% macro shape_generate(mod_file,scene)%}
[Constants]
global $shape_changed = 0
{% for shape in scene.rzm.shapes %}
global ${{ shape.shape_name | default(Error) | string}}Past
{% endfor %}
{% if scene.rzm.shapes %}
    [Present]
    {% for shape in scene.rzm.shapes %}
    post ${{ shape.shape_name | default(Error) | string}}Past = ${{ shape.shape_name | default(Error) | string}}
    {% endfor %}
    {% for shape in scene.rzm.shapes %}
        {% if shape.shape_type | default(0) | int == 0 %}
            if ${{ shape.shape_name | default(Error) | string}}Past != ${{ shape.shape_name | default(Error) | string}}
                $shape_changed = 1
            endif
        {% endif %}
        {% if shape.shape_type | default(0) | int == 1%}
            if ${{ shape.shape_name | default(Error) | string}} > 0.005
                $shape_changed = 1
            endif
        {% endif %}
    {% endfor %}

    if $shape_changed
        run = CustomShaderComputeShapes
    endif
    post $shape_changed = 0
{% endif %}

{% if scene.rzm.shapes %}
[Constants]
{% for shape in scene.rzm.shapes %}
{% if shape.shape_type | default(0) | int == 1 %}
global ${{ shape.shape_name | default(Error) | string}}Freq
{% endif %}
{% endfor %}
[Present]
local $sppeeedyy = 0.00125
if $dt+$sppeeedyy < $sppeeedyy
{% for shape in scene.rzm.shapes if shape.shape_type | default(0) | int == 1 %}
    {% if shape.anim_condition %}
    if {{ shape.anim_condition }}
        ${{ shape.shape_name | default('Error') | string}}Freq = ${{ shape.shape_name | default('Error') | string}}Freq + ${{ shape.shape_name | default('Error') | string}} * ($sppeeedyy)
    endif
    {% else %}
    ${{ shape.shape_name | default('Error') | string}}Freq = ${{ shape.shape_name | default('Error') | string}}Freq + ${{ shape.shape_name | default('Error') | string}} * ($sppeeedyy)
    {% endif %}
{% endfor %}
else
{% for shape in scene.rzm.shapes if shape.shape_type | default(0) | int == 1 %}
    {% if shape.anim_condition %}
    if {{ shape.anim_condition }}
        ${{ shape.shape_name | default('Error') | string}}Freq = ${{ shape.shape_name | default('Error') | string}}Freq + ${{ shape.shape_name | default('Error') | string}} * ($dt+$sppeeedyy)
    endif
    {% else %}
    ${{ shape.shape_name | default('Error') | string}}Freq = ${{ shape.shape_name | default('Error') | string}}Freq + ${{ shape.shape_name | default('Error') | string}} * ($dt+$sppeeedyy)
    {% endif %}
{% endfor %}
endif

[CustomShaderComputeShapes]
{% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 %}
    {% if component.strides %}
    run = CustomShaderComputeShapes.{{ component.fullname }}
    {% endif %}
{% endfor %}

{% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 %}
    {% if component.strides %}
    [CustomShaderComputeShapes.{{ component.fullname }}]
    cs = ./modules/position_shape_linear.hlsl
    cs-u5 = copy Resource{{ component.fullname }}Position.Base
    {% for shape in scene.rzm.shapes %}
        {% for key in shape.shape_keys %}
            {% if shape.shape_type | default(0) | int == 0 %}
            {% if key.mode == 1 %}
                ;Advanced Key
                x88 = ${{ shape.shape_name | default('Error') | string }}
                {% set range_min = key.input_range_min | default(0.0) | float %}
                {% set range_max = key.input_range_max | default(1.0) | float %}
                {% set multiplier = key.multiplier | default(1.0) | float %}
                {% set range_span = range_max - range_min %}
                if x88 <= {{ range_min }}
                    x88 = 0.0
                else if x88 >= {{ range_max }}
                    x88 = 1.0
                else
                    {% if range_span > 0.0001 %}
                    x88 = (x88 - {{ range_min }}) / {{ range_span }}
                    {% else %}
                    x88 = 0.0
                    {% endif %}
                endif
                x88 = x88 * {{ multiplier }}
                {% else %}
                x88 = ${{ shape.shape_name | default('Error') | string }}
            {% endif %}
            cs-t50 = copy Resource{{ component.fullname }}Position.Base
            cs-t51 = copy Resource{{ component.fullname }}Position.{{ shape.shape_name | default('Error') | string}}_{{ key.key_name }}
            Resource{{ component.fullname }}Position = ref cs-u5
            Dispatch = {{ component.vertex_count }}, 1, 1
            {% endif %}
        {% endfor %}
    {% endfor %}

    run = CustomShaderComputeShapes.{{ component.fullname }}.Anim

    cs-u5 = null
    cs-t50 = null
    cs-t51 = null

    [CustomShaderComputeShapes.{{ component.fullname }}.Anim]
    cs = ./modules/position_shape_anim.hlsl
    {% for shape in scene.rzm.shapes %}
        {% for key in shape.shape_keys %}
            {% if shape.shape_type | default(0) | int == 1 %}
            x88 = ${{ shape.shape_name | default(Error) | string}}Freq
            y88 = {{ key.anim_type_index | default(0) | int }}
            z88 = {{ key.anim_start_frame| default(0.0) | float }}
            w88 = {{ key.anim_end_frame | default(1.0) | float }}
            cs-t50 = copy Resource{{ component.fullname }}Position.Base
            cs-t51 = copy Resource{{ component.fullname }}Position.{{ shape.shape_name | default('Error') | string}}_{{ key.key_name }}
            Resource{{ component.fullname }}Position = ref cs-u5
            Dispatch = {{ component.vertex_count }}, 1, 1
            {% endif %}
        {% endfor %}
    {% endfor %}
    {% endif %}
{% endfor %}


{% endif %}

;BaseShape
{% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 %}
    {% if component.strides %}
        [Resource{{ component.fullname }}Position.Base]
        type = Buffer
        stride = {{ component.strides.position }}
        filename = /0/{{ component.fullname }}Position.buf

        {% if mod_file.game.name == "HonkaiStarRail" %}
            [Resource{{ component.fullname }}PositionCS.Base]
            type = StructuredBuffer
            stride = {{ component.strides.position }}
            filename = /0/{{ component.fullname }}Position.buf
        {% endif %}
    {% endif %}
{% endfor %}

{% for shape in scene.rzm.shapes %}
    {% for key in shape.shape_keys %}
        ;ShapeKey Resource: {{ shape.shape_name }}.{{ key.key_name }}
        {% for component in mod_file.components if component.draw_vb != "" and component.blend_vb != ""  and component.vertex_count > 0 and component.strides %}
        [Resource{{ component.fullname }}Position.{{ shape.shape_name | default('Error') | string}}_{{ key.key_name }}]
        type = Buffer
        stride = {{ component.strides.position }}
        filename = /{{ key.key_name }}/{{ component.fullname }}Position.buf

        {% if mod_file.game.name == "HonkaiStarRail" %}
        [Resource{{ component.fullname }}PositionCS.{{ shape.shape_name | default('Error') | string}}_{{ key.key_name }}]
        type = StructuredBuffer
        stride = {{ component.strides.position }}
        filename = /{{ key.key_name }}/{{ component.fullname }}Position.buf
        {% endif %}
        {% endfor %}
    {% endfor %}
{% endfor %}
{% endmacro %}
{# ========================================================
   RZM HOVER DETECT: per-component CustomShader definitions
   and the global pin CommandList.

   Generated only when the mod has hoverable objects.
   ======================================================== #}
{%macro hoverDetectShaders(mod_file,scene)%}
{# Collect components with hoverable objects #}
{% set _hover_comps = [] %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% set _comp_has = {'found': false} %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _comp_has.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        {% if _comp_has.found %}
            {% if _hover_comps.append(component) %}{% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if _hover_comps | length > 0 %}
; ============================================================
; RZM Hover Detect - per-component detect shaders
; ============================================================

{% for component in _hover_comps %}
[CustomShaderRZMDetect{{ component.fullname }}]
; Component-level GPU cursor hit detector.
; cs-t2 = ObjectMap (hoverable objects in this component)
; cs-u0 = shared accumulator (closest hit across all dispatches)
cs = /modules/rzm_object_detect.hlsl
cs-t0 = vb0
cs-t1 = ib
cs-t2 = ResourceRZMDetect{{ component.fullname }}ObjectMap
cs-cb0 = vs-cb0
cs-cb1 = vs-cb1
cs-u0 = ResourceRZMDetectID
x24 = $cursorX
y24 = $cursorY
z24 = $screenW
w24 = $screenH
x25 = $isMouseButtonDown
x26 = $RZMWorldProfileCB0
y26 = $RZMWorldProfileCB1
z26 = $RZMWorldProfileMode
w26 = 2
if $isGameMenu == 1
    x26 = $RZMMenuProfileCB0
    y26 = $RZMMenuProfileCB1
    z26 = $RZMMenuProfileMode
    w26 = 2
endif
dispatch = 1, 1, 1

{% endfor %}
; ============================================================
; RZM Hover Detect - pin shader
; Reads best hit from frame accumulator, writes to pinned
; R32_FLOAT buffer, resets accumulator for next frame.
; ============================================================

[CustomShaderRZMPinDetected]
cs = /modules/rzm_pin_detected.hlsl
cs-u0 = ResourceRZMDetectID
cs-u1 = ResourceRZMPinnedDetectID
dispatch = 1, 1, 1

; ============================================================
; RZM Hover Detect - throttled store (called via pre run)
; store is expensive (CPU readback). Run once every 30 frames.
; ============================================================

[CommandListRZMPinDetected]
local $rzm_detect_counter
local $rzm_detect_threshold = 60
$rzm_detect_counter = $rzm_detect_counter + 1

if $isMouseButtonDown == 1
    $rzm_detect_counter = $rzm_detect_threshold
endif

if $inputMode == 0

if $hoveredID > 0
	$Detected = -1
    $ObjectDetectAllowed = 0
else
    $ObjectDetectAllowed = 1
	if $rzm_detect_counter >= ($rzm_detect_threshold - $CursorIsMoved * 50)
		run = CustomShaderRZMPinDetected
		store = $Detected, ResourceRZMPinnedDetectID, 0
		$rzm_detect_counter = 0
	endif
endif

else 
	$Detected = -1
    $ObjectDetectAllowed = 0
endif

{% endif %}
{%endmacro%}

{%macro baseCompute(mod_file,scene)%}
[CommandListComputeDimensions]
local $pastCursorX
local $pastCursorY
local $cursorJitter
local $cursorJitterThreshold = 4
local $cursorMovingDuration

if $CursorIsMoved == 1
$cursorMovingDuration = $cursorMovingDuration + 1
if $cursorMovingDuration >= 8
$CursorIsMoved = 0
$cursorMovingDuration = 0
endif
endif 
if $inputMode == 0
	if cursor_x > 0 && cursor_y > 0 && cursor_x < 1 && cursor_y < 1
		$cursorX = cursor_x
		$cursorY = 1.0 - cursor_y
	elif cursor_window_x > 0 && cursor_window_y > 0 && cursor_window_x < 1 && cursor_window_y < 1
		$cursorX = cursor_window_x / rt_width
		$cursorY = 1.0 - cursor_window_y / rt_height
	else
		$cursorX = cursor_screen_x / rt_height
		$cursorY = 1.0 - cursor_screen_y / rt_height
	endif
endif
if window_width != 0 && window_height != 0
	$screenW = window_width
	$screenH = window_height
elif rt_width != 0 && rt_height != 0
	$screenW = rt_width
	$screenH = rt_height
else
	$screenW = res_width
	$screenH = res_height
endif

if $screenW > $screenH
	$ratioCorrection = $screenH / $screenW
else 
	$ratioCorrection = $screenW / $screenH
endif

if $screenW > $screenH
	if $canvas_size_y != $screenH
		$screen_modifier_scale = $canvas_size_y / $screenH
	endif
endif

if $inputMode == 0
	$cursorX = $cursorX * $screenW
	$cursorY = $cursorY * $screenH
endif

$cursorX = $cursorX * $screen_modifier_scale
$cursorY = $cursorY * $screen_modifier_scale
$screenW = $screenW * $screen_modifier_scale
$screenH = $screenH * $screen_modifier_scale

$pastCursorX = $pastCursorX - $cursorX
$mathinA = $pastCursorX
run = CommandListMathABS
$cursorJitter = $cursorJitter + $mathout

$pastCursorY = $pastCursorY - $cursorY
$mathinA = $pastCursorY
run = CommandListMathABS
$cursorJitter = $cursorJitter + $mathout

if $cursorJitter > $cursorJitterThreshold && $CursorIsMoved == 0
	$CursorIsMoved = 1
	$cursorJitter = 0
endif

$pastCursorX = $cursorX
$pastCursorY = $cursorY

[CommandListBaseDataCompute]
;run = CommandListComputeDimensions
{% if scene.rzm %}
    {% for grid in scene.rzm.elements %}
        {% if grid.elem_class == 'GRID_CONTAINER' and not (grid.disable_export and not grid.is_preset) %}
            ${{ grid.element_name }}_new_frame = 1
        {% endif %}
    {% endfor %}
{% endif %}
$id = -1
if $inputMode == 0
$hoveredID = -1
endif
$dt = time - $ts
$dtCustom = time - $ts
$dtCustom = $dtCustom * {{ scene.rzm.config.custom_interpolation_speed | default (16.0) }}
$ts = time
{%endmacro%}

{% macro menuDrawUi(mod_file,scene)%}
{% set rzm = scene.rzm %}
{% set has_anim_tracker = [false] %}
{% if rzm %}
    {% set anim_ids = [] %}
    {% for img in rzm.images if img.source_type == 'ANIMATED' %}
        {% set _ = anim_ids.append(img.id) %}
    {% endfor %}
    {% if anim_ids %}
        {% for elem in rzm.elements %}
            {% if elem.image_id in anim_ids or elem.hover_image_id in anim_ids or elem.extramap_image_id in anim_ids %}
                {% set _ = has_anim_tracker.pop() %}{% set _ = has_anim_tracker.append(true) %}
            {% else %}
                {% for c_img in elem.conditional_images %}
                    {% if c_img.image_id in anim_ids %}
                        {% set _ = has_anim_tracker.pop() %}{% set _ = has_anim_tracker.append(true) %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{% set has_anim = has_anim_tracker[0] %}


local $interpolateCursorPosX
local $interpolateCursorPosY
$interpolateCursorPosX = $interpolateCursorPosX + ($CursorX - $interpolateCursorPosX) * ($dtCustom + 0.0069)
$interpolateCursorPosY = $interpolateCursorPosY + ($CursorY - $interpolateCursorPosY) * ($dtCustom + 0.0069)
x99 = $interpolateCursorPosX / $ScreenW
y99 = $interpolateCursorPosY / $ScreenH
run = CustomShaderDI2D.SYSTEM.PROC

[CustomShaderDI2D.SYSTEM.PROC]
vs = /modules/system_draw.hlsl
ps = /modules/system_draw.hlsl
ps-t82 = ResourceFont0
ps-t63 = ResourceRZMSys_SlotHint
ps-t64 = ResourceRZMSys_SlotHint2

if $inputMode == 1
    ps-t58 = ResourceRZMSys_SlotButtonMode
else
    ps-t58 = ResourceRZMSys_SlotMouseMode
endif

blend = ADD SRC_ALPHA INV_SRC_ALPHA
cull = none
topology = triangle_list
o0 = set_viewport no_view_cache bb
draw = 3, 0

[ResourceRZMSys_SlotHint]
type = Buffer
format = R32_UINT
data = 82 83 104 105 102 116 32 45 32 115 119 105 116 99 104 32 109 111 100 101

[ResourceRZMSys_SlotHint2]
type = Buffer
format = R32_UINT
data = 82 67 116 114 108 32 45 32 99 97 112 116 117 114 101 32 101 108 101 109 101 110 116

[ResourceRZMSys_SlotButtonMode]
type = Buffer
format = R32_UINT
data = 66 117 116 116 111 110 77 111 100 101

[ResourceRZMSys_SlotMouseMode]
type = Buffer
format = R32_UINT
data = 77 111 117 115 101 77 111 100 101

[ResourceRZMSys_GM_ON]
type = Buffer
format = R32_UINT
data = 71 97 109 101 112 97 100 32 79 78

[ResourceRZMSys_GM_OFF]
type = Buffer
format = R32_UINT
data = 75 101 121 98 111 97 114 100 32 79 78

[ResourceRZMSys_NO_API]
type = Buffer
format = R32_UINT
data = 78 111 32 65 80 73

[ResourceRZMSys_TestNotice]
type = Buffer
format = R32_UINT
data = 84 101 115 116 32 78 111 116 105 99 101


[ResourceIndexBuffer]
type = RWBuffer
format = R32_UINT
array = 2048

[ResourceDataBuffer]
type = RWBuffer
format = R32G32B32A32_FLOAT
array = 8192

[ResourceText]

{% set CLASS_NAME_MAP = {
    0: 'CONTAINER',
    1: 'GRID_CONTAINER',
    2: 'ANCHOR',
    3: 'BUTTON',
    4: 'SLIDER',
    5: 'TEXT',
} %}
{% macro format_var(input_string) -%}
    {%- if input_string -%}
        {#- Список "неправильных" символов, которые нужно удалить с начала строки -#}
        {%- set chars_to_strip = '$@#%' -%}
        {#- Убираем все неправильные символы с начала и добавляем один $ впереди -#}
        {{- '$' ~ input_string.lstrip(chars_to_strip) -}}
    {%- endif -%}
{%- endmacro %}

{%macro generate_variables(mod_file,scene)%}
;macro generate_variables(mod_file,scene)
{% if scene.rzm %}
    {% if scene.rzm.rzm_values %}
        {% for value in scene.rzm.rzm_values %}
            {% if value.value_name %}
                {% if value.int_value %}
                global persist {{format_var(value.value_name)}} = {%if int_value != null%}{{value.int_value}}{%else%}0{%endif%}   
                {% else %}
                global persist {{format_var(value.value_name)}} = {%if float_value != null%}{{value.float_value}}{%else%}0.0{%endif%}    
                {%endif%}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{%endmacro%}

{% macro generate_toggle(mod_file,scene) %}
    ;macro generate_toggle(mod_file,scene)
    {# --- ИЗМЕНЕНО ЗДЕСЬ: Путь к коллекции теперь 'toggle_definitions' --- #}
{% if scene.rzm %}
    {% if scene.rzm.toggle_definitions %}
        {% for toggle in scene.rzm.toggle_definitions %}
            {% if toggle.toggle_name %}
            global persist ${{ toggle.toggle_name }} = 0   
            {%endif%}
                {#{toggle.toggle_length}#}
        {% endfor %}
    {% endif %}
{% endif %}
{% endmacro %}


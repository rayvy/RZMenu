{% set DEBUG = true %}
{% import "modules/container.j2" as class_container with context %}
{% import "modules/utils.j2" as utils with context %}

{% set CLASS_NAME_MAP = {
    0: 'CONTAINER',
    1: 'GRID_CONTAINER',
    2: 'ANCHOR',
    3: 'BUTTON',
    4: 'SLIDER',
    5: 'TEXT',
} %}

{% set CLASS_ATTRIBUTES = {
    'ANCHOR': ['isMovable'],
    'GRID_CONTAINER': ['isResizable'],
    'BUTTON': ['isClickable', 'isHoldable', 'hadPopup'],
    'SLIDER': ['isClickable', 'isHoldable']
} %}

{% set FN_MAP = {
    0: 'AlignCenterXY',
    1: 'AlignCenterX',
    2: 'AlignCenterY',
    3: 'AlignLeft',
    4: 'AlignRight',
    5: 'AlignBottom',
    6: 'AlignTop',
    7: 'FixAspectRatio',
} %}

{% set FX_MAP = {
    'CommandListCoreFxBoxRound': 'BoxRound',
    'CommandListCoreFxBoxCircle': 'BoxCircle',
    'CommandListCoreFxGradient': 'Gradient',
    'CommandListCoreFxShadow': 'Shadow',
    'CommandListCoreFxBlur': 'Blur',
    'CommandListCoreFxOutline': 'Outline',
    'CommandListCoreFxHover': 'Hover',
    'CommandListCoreFxHover3D': 'Hover3D',
    'CommandListCoreFxGpuAnimRotate': 'GpuAnimRotate'
} %}

{# format_var macro removed - using utils.j2 version instead #}

{% macro elements_generate(mod_file,scene) %}
    {% if scene.rzm and scene.rzm.elements %}
        {% for element in scene.rzm.elements %}
            {% if not (element.disable_export and not element.is_preset) %}
            {% set parent_element = {'element_name': [], 'elem_class': [], 'grid_wrap_mode': [], 'value_link': []} %}


            {% if element.parent_id > -1 %}
                {% for potential_parent in scene.rzm.elements %}
                    {% if potential_parent.id == element.parent_id %}
                        {% set _ = parent_element['element_name'].insert(0, potential_parent.element_name) %}
                        {% set _ = parent_element['elem_class'].insert(0, potential_parent.elem_class) %}
                        {% set _ = parent_element['grid_wrap_mode'].insert(0, potential_parent.grid_wrap_mode) %}
                        {% if potential_parent.value_link and potential_parent.value_link|length > 0 %}
                            {% set _ = parent_element['value_link'].insert(0, potential_parent.value_link[0].value_name) %}
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endif %}

            {# --- PROGENITOR TRAVERSAL (TEST PHASE) --- #}
            {% set prog_ns = namespace(item=element) %}
            {% for i in range(10) %}
                {% if prog_ns.item.parent_id > -1 %}
                    {% for p in scene.rzm.elements %}
                        {% if p.id == prog_ns.item.parent_id %}
                            {% set prog_ns.item = p %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endfor %}
            {% set progenitor_element = prog_ns.item %}
            {#MainClass#}
            ;{{element.elem_class}}
            {#%if CLASS_NAME_MAP[element.elem_class] == 'BUTTON'%}
                {{class_button.main(element,parent_element,mod_file,scene)}}
            {%elif CLASS_NAME_MAP[element.elem_class] == 'SLIDER'%}
                {{class_slider.main(element,parent_element,mod_file,scene)}}
            {%else%}
                {{class_container.main(element,parent_element,mod_file,scene)}}
            {%endif%#}
            {#%if CLASS_NAME_MAP[element.elem_class] == 'ANCHOR' %}
                {{class_anchor.main(element,parent_element,mod_file,scene)}}
            {%elif CLASS_NAME_MAP[element.elem_class] == 'GRID_CONTAINER' %}
                {{class_grid_container.main(element,parent_element,mod_file,scene)}}
                {{class_grid_container.generate_grid_scroller(element)}}
            {%elif CLASS_NAME_MAP[element.elem_class] == 'BUTTON'%}
                {{class_button.main(element,parent_element,mod_file,scene)}}
            {%elif CLASS_NAME_MAP[element.elem_class] == 'SLIDER'%}
                {{class_slider.main(element,parent_element,mod_file,scene)}}
            {%if CLASS_NAME_MAP[element.elem_class] == 'TEXT'%}
                {{class_text.main(element,parent_element,mod_file,scene)}}
            {%else%}
                {{class_container.main(element,parent_element,mod_file,scene)}}
            {%endif%#}
            ;{{element.tag}}
            {% if element.tag == 'ControllerCursor'%}
            {{class_container.ControllerCursor(element,parent_element,mod_file,scene,progenitor_element)}}
            {% elif element.tag == 'HSVColorPicker' %}
            {{class_container.HSVColorPicker(element,parent_element,mod_file,scene,progenitor_element)}}
            {% else %}
            {% if element.is_helper %}{%else%}{{class_container.main(element,parent_element,mod_file,scene,progenitor_element)}}{%endif%}
            {% endif %}
            {% endif %}
        {% endfor %}

    {{elements_additional_generate(mod_file,scene)}}
    {% endif %}
{% endmacro %}


{%macro elements_additional_generate(mod_file,scene)%}
{% for element in scene.rzm.elements %}
    {% if not (element.disable_export and not element.is_preset) %}
    ;{{element.elem_class}}
    {%if element.elem_class == 'GRID_CONTAINER' %}
    {{generate_grid_scroller(element)}}
    {%elif element.elem_class == 'SLIDER' and element.value_link%}
    {{generate_slider_helper(element)}}
    {%endif%}
    {% endif %}
{% endfor %}

{# ─── HELPER DEFINITIONS ─── #}
{# Для каждого host-элемента с helper_ids генерируем отдельный CommandList блок хелпера #}
{% for host_element in scene.rzm.elements %}
    {% if not host_element.is_preset and not host_element.is_helper and not host_element.disable_export %}
        {% if host_element.helper_ids %}
            {# --- PROGENITOR TRAVERSAL FOR HELPERS (TEST PHASE) --- #}
            {% set h_prog_ns = namespace(item=host_element) %}
            {% for i in range(10) %}
                {% if h_prog_ns.item.parent_id > -1 %}
                    {% for p in scene.rzm.elements %}
                        {% if p.id == h_prog_ns.item.parent_id %}
                            {% set h_prog_ns.item = p %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endfor %}
            {% set host_progenitor = h_prog_ns.item %}
            {% for ref in host_element.helper_ids %}
                {% set helper_item = scene.rzm.elements | selectattr('id', 'equalto', ref.helper_id) | first %}
                {% if helper_item %}
{{ class_container.generate_helper_definition(helper_item, host_element, mod_file, scene, host_progenitor) }}
                {% endif %}
            {% endfor %}
        {% endif %}
    {% endif %}
{% endfor %}

{%endmacro%}


{% macro generate_grid_scroller(grid) %}
[CommandList{{ grid.element_name }}Scroller]
; --- Фаза 1: Настройка и вычисление геометрии ---
$id = {{ grid.id }} + 1000
local $thumb_width = 50

;local $container_pos_x = ${{ grid.element_name }}PositionX
;local $container_pos_y = ${{ grid.element_name }}PositionY
local $container_pos_x = $PositionX
local $container_pos_y = $PositionY
local $container_width = ${{ grid.element_name }}SizeX
local $container_height = ${{ grid.element_name }}SizeY

$positionX = $container_pos_x
$positionY = $container_pos_y
$sizeX = $container_width
$sizeY = $rzmUIRenderSettings_ScrollBarThiccnkess

run = CommandListCoreFNUpdateHoverState
run = CommandListCoreFNHandleClick
run = CommandListCoreFNHandleHold

if $capturedID == $id || $clickTriggerID == $id
	local $target_scroll
	local $progress = ($cursorX - $positionX) / $sizeX
	if $progress < 0.0
		$progress = 0.0
	endif
	if $progress > 1.0
		$progress = 1.0
	endif
	$target_scroll = $progress

	if $clickTriggerID == $id
		${{ grid.element_name }}scroll = $target_scroll
	endif

	if $capturedID == $id
		if w33 > $holdThreshold
			local $current_scroll = ${{ grid.element_name }}scroll
			${{ grid.element_name }}scroll = $current_scroll + ($target_scroll - $current_scroll) * 0.4
		endif
	endif
endif

$colorR = 0.1
$colorG = 0.1
$colorB = 0.1
$colorA = 0.7
run = CustomShaderRCI2D

local $track_width = $sizeX - $thumb_width
if $track_width < 0
	$track_width = 0
endif
$PositionX = $positionX + (${{ grid.element_name }}scroll * $track_width)
$SizeX = $thumb_width
$colorR = 0.8
$colorG = 0.8
$colorB = 0.8
$colorA = 0.7
run = CustomShaderRCI2D
$positionX = $container_pos_x
$positionY = $container_pos_y
$sizeX = $container_width
$sizeY = $container_height
{% endmacro %}

{% macro generate_slider_helper(element) %}
[CommandList{{ element.element_name }}Helper]

{# --- MASTER из element.value_link[0] (если есть) --- #}
{% if element.value_link is defined and element.value_link|length > 0 %}
    {% set master = element.value_link[0] %}
    {% set master_name = master.value_name | default('') %}
    {% set master_min = master.value_min | default(0.0) | float %}
    {% set master_max = master.value_max | default(1.0) | float %}
    {% set master_var = '$' ~ utils.get_var_name(master_name, scene) %}
{% else %}
    {% set master = none %}
    {% set master_name = '' %}
    {% set master_min = 0.0 %}
    {% set master_max = 1.0 %}
    {% set master_var = '' %}
{% endif %}

local $TargetValue = ${{utils.get_var_name(master_name, scene)}}
local $range_span = {{ master_max }} - {{ master_min }}

if $capturedID == $id || $clickTriggerID == $id
    if $range_span > 0.0001
        $TargetValue = {{ master_min }} + (($cursorX - $positionX) / $sizeX) * $range_span
    else
        $TargetValue = {{ master_min }}
    endif
endif

{# RZM_SLIDER_LIMIT: Привязка к динамическому диапазону min/max #}
if $TargetValue < {{ master_min }}
    $TargetValue = {{ master_min }}
else if $TargetValue > {{ master_max }}
    $TargetValue = {{ master_max }}
endif

local $smoothing_factor = 0.25

{% if master_name %}
    if {{ master_var }} != $TargetValue
        {{ master_var }} = {{ master_var }} + ($TargetValue - {{ master_var }}) * $smoothing_factor
    endif

    {# Gamepad управление для MASTER с учетом диапазона #}
    if $isGamepadEditing == 1 && $GamepadEditedID == $id
        local $tap_step = $range_span * 0.1
        local $hold_speed = $range_span * 0.5

        if $Gamepad_Interaction_Increase == 1
            if $Gamepad_Interaction_Type == 1
                {{ master_var }} = {{ master_var }} + $tap_step
            else if $Gamepad_Interaction_Type == 2
                {{ master_var }} = {{ master_var }} + ($hold_speed * $dt)
            endif
        else if $Gamepad_Interaction_Decrease == 1
            if $Gamepad_Interaction_Type == 1
                {{ master_var }} = {{ master_var }} - $tap_step
            else if $Gamepad_Interaction_Type == 2
                {{ master_var }} = {{ master_var }} - ($hold_speed * $dt)
            endif
        endif
    endif

    {# RZM_SLIDER_LIMIT: Финальная привязка MASTER к его min/max параметрам #}
    if {{ master_var }} > {{ master_max }}
        {{ master_var }} = {{ master_max }}
    else if {{ master_var }} < {{ master_min }}
        {{ master_var }} = {{ master_min }}
    endif
{% else %}
    {# Нет master — ничего не делаем (фоллбек) #}
{% endif %}

{# --- SLAVE: все остальные value_link копируют MASTER --- #}
{% if element.value_link is defined and element.value_link|length > 1 and master_name %}
    {% for slave in element.value_link[1:] %}
        {% set slave_name = slave.value_name | default('') %}
        {% if slave_name %}
${{ utils.get_var_name(slave_name, scene) }} = {{ master_var }}
        {% endif %}
    {% endfor %}
{% endif %}
{% endmacro %}

{% macro anchors_generate(mod_file,scene) %}
{% if scene.rzm and scene.rzm.elements %}
    {% for element in scene.rzm.elements %}
        {% if not element.is_preset and not element.disable_export %}
            {% if utils.get_cls(element)|trim == 'GRID_CONTAINER'%}
            global persist ${{element.element_name}}scroll = 0
            {% endif%}
            {% if element.trackable or utils.get_cls(element)|trim in ['GRID_CONTAINER', 'ANCHOR'] %}
            global persist ${{element.element_name}}PositionX = {{ (element.position | default([0,0]))[0] }}
            global persist ${{element.element_name}}PositionY = {{ (element.position | default([0,0]))[1] }}
            global persist ${{element.element_name}}SizeX = {{ (element.size | default([0,0]))[0] }}
            global persist ${{element.element_name}}SizeY = {{ (element.size | default([0,0]))[1] }}
            {% endif %}
        {% endif %}
    {% endfor %}
{% endif %}
{% endmacro %}

{% macro special_generate(mod_file,scene) %}
{% if scene.rzm and scene.rzm.elements %}
    {% for element in scene.rzm.elements %}
        {% if element.tag == 'HSVColorPicker' and not (element.disable_export and not element.is_preset) %}
        global persist ${{element.element_name}}_{{element.id}}_X = 0.0
        global persist ${{element.element_name}}_{{element.id}}_Y = 1.0
        global persist ${{element.element_name}}_{{element.id}}_Z = 1.0
        {% elif utils.get_cls(element)|trim == 'VECTOR_BOX' and not (element.disable_export and not element.is_preset) %}
        {% if element.value_link|length > 3 %}
        global persist ${{element.element_name}}_X = 0.0
        global persist ${{element.element_name}}_Y = 0.0
        global persist ${{element.element_name}}_Z = 0.0
        global persist ${{element.element_name}}_W = 0.0
        {% endif %}
        {% endif %}
    {% endfor %}
{% endif %}
{% endmacro %}

{% macro customDrawVars(mod_file,scene) %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% for key, value in entry.obj.items() %}
                    {% if key.startswith('CustomDraw') %}
                        {% if key == 'CustomDraw.FRAMETRACE' %}
                            {% set safe_name = utils.format_from_idiot(entry.name) %}
                        global $CDC_{{ safe_name }}_Sandevistan = {{ entry.index_count }}
                        global $CDO_{{ safe_name }}_Sandevistan = {{ entry.index_offset }}
                        {% elif 'XRAY' not in key and 'TRANSPARENT' not in key %}
                        ;global $CDC_{{ key|replace('CustomDraw', '') }} = {{ entry.index_count }}
                        ;global $CDO_{{ key|replace('CustomDraw', '') }} = {{ entry.index_offset }}
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endfor %}
        {% endfor %}
    {% endfor %}
{%endmacro%}

{# ============================================================
   hoverDetectVars: Generates global Constants needed by the
   RZM hover detection system.

   Transform profiles per-game (config map):
     World profile : cb0, cb1, mode used outside menu
     Menu  profile : cb0, cb1, mode used in menu (when $isGameMenu == 1)

   mode = localMode * 10 + clipMode
     localMode: 0=raw vb0, 1=basis cb1, 2=row-dot cb1
     clipMode:  0=basis cb0, 1=row-dot cb0, 2=basis cb0 + viewport offset
   ============================================================ #}
{% macro hoverDetectVars(mod_file, scene) %}
{% set game_name = (scene.rzm.game.name if (scene and scene.rzm and scene.rzm.game) else (mod_file.game.name if (mod_file and mod_file.game) else 'Default')) %}

{# Per-game transform profile config map #}
{% set HOVER_PROFILE_MAP = {
    'ZenlessZoneZero': {
        'world': {'cb0': 125, 'cb1': 0, 'mode': 10},
        'menu':  {'cb0': 127, 'cb1': 0, 'mode': 12}
    },
    'GenshinImpact': {
        'world': {'cb0': 64, 'cb1': 0, 'mode': 10},
        'menu':  {'cb0': 64, 'cb1': 0, 'mode': 10}
    },
    'HonkaiStarRail': {
        'world': {'cb0': 32, 'cb1': 0, 'mode': 10},
        'menu':  {'cb0': 32, 'cb1': 0, 'mode': 10}
    },
    'ArknightsEndfield': {
        'world': {'cb0': 16, 'cb1': 0, 'mode': 10},
        'menu':  {'cb0': 16, 'cb1': 0, 'mode': 10}
    }
} %}
{% set profile = HOVER_PROFILE_MAP.get(game_name, {'world': {'cb0': 0, 'cb1': 0, 'mode': 10}, 'menu': {'cb0': 0, 'cb1': 0, 'mode': 10}}) %}
{% set world_p = profile.get('world') %}
{% set menu_p  = profile.get('menu') %}

{# Check if any component has hoverable objects (rzm.Hover int > 0) #}
{% set _has_hover = {'found': false} %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _has_hover.update({'found': true}) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
    {% endfor %}
{% endif %}

{% if _has_hover.found %}
[Constants]
; RZM Hover Detect — transform profiles
global $RZMWorldProfileCB0 = {{ world_p.cb0 }}
global $RZMWorldProfileCB1 = {{ world_p.cb1 }}
global $RZMWorldProfileMode = {{ world_p.mode }}
global $RZMMenuProfileCB0 = {{ menu_p.cb0 }}
global $RZMMenuProfileCB1 = {{ menu_p.cb1 }}
global $RZMMenuProfileMode = {{ menu_p.mode }}
{% endif %}
{% endmacro %}

{# ============================================================
   hoverDetectResources: Generates per-component ObjectMap
   resources for all components with hoverable objects.

   ObjectMap layout (R32G32B32A32_FLOAT buffer):
     [0]     = objectCount, 0, 0, 0
     [1 + i] = firstIndex, indexCount, baseVertex, objectID

   If objectID == 0, shader uses firstIndex as the ID.
   ============================================================ #}
{% macro hoverDetectResources(mod_file, scene) %}
{% if mod_file and mod_file.components %}
    {% for component in mod_file.components if component.draw_vb != "" %}
        {# Collect hoverable/clickable entries in this component into a plain list #}
        {% set _hover_entries = [] %}
        {% for part in component.parts if part.vertex_count > 0 %}
            {% for entry in part.objects if entry.vertex_count > 0 %}
                {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
                {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                    {% if _hover_entries.append((entry, real_obj.get('rzm.Hover', 0) | int)) %}{% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}

        {% if _hover_entries | length > 0 %}
            {% set obj_count = _hover_entries | length %}
[ResourceRZMDetect{{ component.fullname }}ObjectMap]
type = Buffer
format = R32G32B32A32_FLOAT
array = {{ obj_count + 1 }}
; [0] = objectCount={{ obj_count }}, 0, 0, 0
; [1+i] = firstIndex, indexCount, mode, objectID
data = {{ obj_count }} 0 0 0  {% for item in _hover_entries %}{% set entry = item[0] %}{% set mode = item[1] %}{{ entry.index_offset if entry.index_offset is defined else entry.first_index if entry.first_index is defined else 0 }} {{ entry.index_count }} {{ mode }} 0  {% endfor %}

        {% endif %}
    {% endfor %}

; RZM Hover Detect accumulator buffers (shared across all components)
{% set _any_hover = {'found': false} %}
{% for component in mod_file.components if component.draw_vb != "" %}
    {% for part in component.parts if part.vertex_count > 0 %}
        {% for entry in part.objects if entry.vertex_count > 0 %}
            {% set real_obj = scene.objects.get(entry.name) if scene and scene.objects else none %}
            {% if real_obj and real_obj.get('rzm.Hover', 0) | int > 0 %}
                {% if _any_hover.update({'found': true}) %}{% endif %}
            {% endif %}
        {% endfor %}
    {% endfor %}
{% endfor %}
{% if _any_hover.found %}
[ResourceRZMDetectID]
type = RWBuffer
format = R32G32B32A32_FLOAT
array = 1

[ResourceRZMPinnedDetectID]
type = RWBuffer
format = R32_FLOAT
array = 1
{% endif %}
{% endif %}
{% endmacro %}

{% macro shape_generate(mod_file,scene) %}
    {% for shape in scene.rzm.shapes %}
        {% set shape_tags = utils.tier_tags(shape) %}
        {% if shape_tags %}
        ;[META-INFO] [START] [DELETE] [SHAPE] [{{ shape.shape_name }}] {{ shape_tags }}
        {% endif %}
        global persist ${{utils.format_var(shape.shape_name | default(Error) | string)}} = 0
        {% if shape_tags %}
        ;[META-INFO] [END] [DELETE] [SHAPE] [{{ shape.shape_name }}] {{ shape_tags }}
        {% endif %}
    {% endfor %}
{% endmacro%}

{% macro generate_profiles(mod_file, scene) %}
{%- if scene.rzm and scene.rzm.addons and scene.rzm.addons.use_in_game_profiles %}
{% set profile_count = scene.rzm.addons.in_game_profile_count | default(1) | int %}
; ─── IN-GAME PROFILES ───────────────────────────────────────────────────────
[Constants]
; Active profile index (0-based). Persist so the game remembers last selection.
global persist $RZProfile = 0

; ── Per-Variable profile slots ───────────────────────────────────────────────
; Variables
{% if scene.rzm.rzm_values %}
{% for value in scene.rzm.rzm_values if value.value_name %}
{% for n in range(profile_count) %}
global persist $RZProfile_{{ n }}_{{ utils.format_var(value.value_name) | replace('$','') }} = 0
{% endfor %}
{% endfor %}
{% endif %}

; Toggles
{% if scene.rzm.toggle_definitions %}
{% for toggle in scene.rzm.toggle_definitions if toggle.toggle_name %}
{% for n in range(profile_count) %}
global persist $RZProfile_{{ n }}_{{ utils.format_var(toggle.toggle_name) | replace('$','') }} = {{ toggle.toggle_start_index | default(0) | int }}
{% endfor %}
{% endfor %}
{% endif %}

; Shapes
{% if scene.rzm.shapes %}
{% for shape in scene.rzm.shapes if shape.shape_name %}
{% for n in range(profile_count) %}
global persist $RZProfile_{{ n }}_{{ utils.format_var(shape.shape_name) | replace('$','') }} = 0
{% endfor %}
{% endfor %}
{% endif %}

; ── Save / Load CommandLists ──────────────────────────────────────────────────
[CommandListRZSaveProfile]
; Called when user wants to save current variable state into the active profile slot.
{% if scene.rzm.rzm_values %}
{% for value in scene.rzm.rzm_values if value.value_name %}
{% set vn = utils.format_var(value.value_name) | replace('$','') %}
{% for n in range(profile_count) %}
if $RZProfile == {{ n }}
    $RZProfile_{{ n }}_{{ vn }} = {{ utils.format_var(value.value_name) }}
endif
{% endfor %}
{% endfor %}
{% endif %}
{% if scene.rzm.toggle_definitions %}
{% for toggle in scene.rzm.toggle_definitions if toggle.toggle_name %}
{% set tn = utils.format_var(toggle.toggle_name) | replace('$','') %}
{% for n in range(profile_count) %}
if $RZProfile == {{ n }}
    $RZProfile_{{ n }}_{{ tn }} = {{ utils.format_var(toggle.toggle_name) }}
endif
{% endfor %}
{% endfor %}
{% endif %}
{% if scene.rzm.shapes %}
{% for shape in scene.rzm.shapes if shape.shape_name %}
{% set sn = utils.format_var(shape.shape_name) | replace('$','') %}
{% for n in range(profile_count) %}
if $RZProfile == {{ n }}
    $RZProfile_{{ n }}_{{ sn }} = {{ utils.format_var(shape.shape_name) }}
endif
{% endfor %}
{% endfor %}
{% endif %}

[CommandListRZLoadProfile]
; Restores variable state from the active profile slot.
{% if scene.rzm.rzm_values %}
{% for value in scene.rzm.rzm_values if value.value_name %}
{% set vn = utils.format_var(value.value_name) | replace('$','') %}
{% for n in range(profile_count) %}
if $RZProfile == {{ n }}
    {{ utils.format_var(value.value_name) }} = $RZProfile_{{ n }}_{{ vn }}
endif
{% endfor %}
{% endfor %}
{% endif %}
{% if scene.rzm.toggle_definitions %}
{% for toggle in scene.rzm.toggle_definitions if toggle.toggle_name %}
{% set tn = utils.format_var(toggle.toggle_name) | replace('$','') %}
{% for n in range(profile_count) %}
if $RZProfile == {{ n }}

{% import "modules/base.j2" as base with context %}
{% import "modules/utils.j2" as utils with context %}
{% import "modules/elements_helpers.j2" as elements_helpers with context %}

{%macro base(element,parent_element,mod_file,scene)%}
{% if debug == true%}{{base.debug_info(element)}}{% endif%}
$classType = {{ utils.get_cls_id(element) }}
{% if not element.is_preset %}
$id = {{ element.id }}
$isPreset = 0
{% else %}
$isPreset = 1
{% endif %}
local $LocalVisibility
{% if not element.is_preset %}
local $ValueX24Interpolated
{% endif %}
$LocalVisibility = 0
local $hoverInterpolate
local $clickInterpolate
{% if element.visibility_mode == 'CONDITIONAL' %}
if {{ utils.normalize_all_vars(element.visibility_condition, parent_element, scene) }}
    $LocalVisibility = 1
endif
{% elif element.visibility_mode == 'HIDED' %}
    $LocalVisibility = 0
{% else %}
    $LocalVisibility = 1
{% endif %}
run = CommandListRestoreElement
{% if element.font_slot != 0 %}
$fontSlot = {{ element.font_slot | default(0) }}
{% endif %}
if $LocalVisibility
local $LocalHoverTimer
local $LocalHoldTimer
if $LocalHoldTimer > 0
    $LocalHoldTimer = $LocalHoldTimer - $dt  
endif
local $P_PX
local $P_PY
local $P_SX
local $P_SY
{% set class_name = utils.get_cls(element)|trim %}
{% set parent_class_name = utils.get_cls(parent_element)|trim if parent_element else none %}
{% if parent_class_name == 'GRID_CONTAINER' and (class_name == 'BUTTON' or class_name == 'SLIDER') %}
Local $target_positionX
Local $target_positionY
Local $target_sizeX
Local $target_sizeY
Local $current_positionX
Local $current_positionY
Local $current_sizeX
Local $current_sizeY
{% endif %}
{%endmacro%}

{#MAINSTUFF#}
{%macro main(element,parent_element,mod_file,scene)%}
    {% set class_name = utils.get_cls(element)|trim %}
    {% set parent_class_name = utils.get_cls(parent_element)|trim if parent_element else none %}
    {% set element_tags = utils.tier_tags(element) %}
    {% if element_tags %}
    ;[META-INFO] [START] [DELETE] [ELEMENT] [{{ element.element_name }}_{{ element.id }}] {{ element_tags }}
    {% endif %}
    [CommandListElement{{ element.element_name }}_{{ element.id }}]
    {{base(element,parent_element,mod_file,scene)}}
    {% if parent_class_name == 'GRID_CONTAINER' and (class_name == 'BUTTON' or class_name == 'SLIDER') %}
    {% else %}
        {{generate_position_and_size(element,parent_element,mod_file,scene)}}
    {% endif %}
    $P_PX = $PositionX
    $P_PY = $PositionY
    $P_SX = $SizeX
    $P_SY = $SizeY
    ;Underlayer Presets
    {% if not element.is_preset%}
    w23 = $hoverInterpolate
    z23 = $clickInterpolate
    {% endif %}
    {{generate_underlayer_presets(element,mod_file,scene)}}
    {%if element.color%}{{generate_color(element,parent_element, scene)}}{%endif%}
    {%if element.fn%}{{generate_fn(element)}}{%endif%}
    {% if parent_class_name == 'GRID_CONTAINER' and (class_name == 'BUTTON' or class_name == 'SLIDER') %}
        {{ handle_element_in_grid(element, parent_element, mod_file,scene) }}
    {% endif %}
    {%if element.properties %}
        {%for props in element.properties%}
            ;{{props.key}}
            {{props.string_value}}
        {%endfor%}
    {%endif%}
    if $LocalVisibility
    $positionX = $P_PX
    $positionY = $P_PY
    $sizeX = $P_SX
    $sizeY = $P_SY
    $element_align = {{ utils.ALIGNMENT_MAP.get(element.alignment, 0) }}
    run = CommandListCoreAlignment.Check
    {{generate_interactions(element, parent_element, scene)}}
    {%if class_name == 'SLIDER'%}
        {{generate_image(element,parent_element,scene)}}
        {{generate_fx(element)}}
        {{ handle_slider_logic(element, parent_element, mod_file,scene) }}
            $slider_node_disable_nums = {{ 1 if element.disable_slider_nums else 0 }}
            $slider_node_disable_blur = {{ 1 if element.disable_slider_blur else 0 }}
            {% if element.disable_slider_prebuild_render %}
            run = CustomShaderRCI2D
            {% elif element.text_id or (element.text_mode != 'SINGLE' and element.conditional_texts|length > 0) %}
            {{ generate_text(element) }}
            run = CustomShaderRCI2D_SLIDER.TEXT
            {% else %}
            run = CustomShaderRCI2D_SLIDER
            {% endif %}
    {%elif class_name == 'VECTOR_BOX'%}
        {{generate_image(element,parent_element,scene)}}
        {{generate_fx(element)}}
        run = CommandList{{ element.element_name }}_{{ element.id }}Helper
        run = CustomShaderRCI2D
    {%elif class_name == 'TEXT'%}
        {{generate_text(element)}}
        {{generate_fx(element)}}
        ;run = CustomShaderRCI2D_TEXT_{{element.text_align | default ('LEFT')}}
        run = CustomShaderRCI2D_TEXT
    {%else%}
        {{generate_image(element,parent_element,scene)}}
        {{generate_fx(element)}}
        ;val {{utils.format_var("~PV",parent_element, scene)}}
        run = CustomShaderRCI2D
    {%endif%}
    {% if class_name == 'GRID_CONTAINER' %}
            {{ handle_grid_container_logic(element, mod_file,scene) }}
    {% elif class_name == 'BUTTON' %}
            {{ handle_button_logic(element, parent_element, mod_file,scene) }}
    {% endif %}
    {{generate_hovertext(element)}}
    {% if element.trackable or utils.get_cls(element)|trim in ['GRID_CONTAINER', 'ANCHOR'] %}
    ${{element.element_name}}PositionX = $PositionX
    ${{element.element_name}}PositionY = $PositionY
    ${{element.element_name}}SizeX = $SizeX
    ${{element.element_name}}SizeY = $SizeY
    {% endif %}
    if ($cursorX >= $positionX && $cursorX <= ($positionX + $sizeX) && $cursorY >= $positionY && $cursorY <= ($positionY + $sizeY))
    $hoverInterpolate = $hoverInterpolate + (1 - $hoverInterpolate) * ($dtCustom + 0.0069)
    else
    $hoverInterpolate = $hoverInterpolate + (0 - $hoverInterpolate) * ($dtCustom + 0.0069)
    endif
    $clickInterpolate = $clickInterpolate + (0 - $clickInterpolate) * ($dtCustom + 0.0069)
    ;Presets
    {% if not element.is_preset and element.value_link %}
    x24 = $ValueX24Interpolated
    {% endif %}
    {% if not element.is_preset%}
    w23 = $hoverInterpolate
    z23 = $clickInterpolate
    {% endif %}
    {{generate_presets(element,mod_file,scene)}}
    {{generate_helpers(element,mod_file,scene)}}
    {% if not element.is_preset%}
    z23 = 0
    w23 = 0
    {% endif %}
    {{generate_child(element,mod_file,scene)}}
    endif
    endif
    {% if element_tags %}
    ;[META-INFO] [END] [DELETE] [ELEMENT] [{{ element.element_name }}_{{ element.id }}] {{ element_tags }}
    {% endif %}
{%- endmacro -%}
{#MAINSTUFF#}

{%macro generate_presets(element, mod_file, scene)%}
    {% for ref in element.preset_ids %}
        {% set preset_item = scene.rzm.elements | selectattr('id', 'equalto', ref.preset_id) | first %}
        {% if preset_item %}

            $positionX = $P_PX
            $positionY = $P_PY
            $sizeX = $P_SX
            $sizeY = $P_SY
            run = CommandListElement{{preset_item.element_name }}_{{ preset_item.id }}
        {% endif %}
    {% endfor %}
{%endmacro%}

{%macro generate_underlayer_presets(element, mod_file, scene)%}
    {% for ref in element.underlayer_preset_ids %}
    ;Underlayer: {{ref.preset_id}}
        {% set preset_item = scene.rzm.elements | selectattr('id', 'equalto', ref.preset_id) | first %}
        {% if preset_item %}

            $positionX = $P_PX
            $positionY = $P_PY
            $sizeX = $P_SX
            $sizeY = $P_SY
            run = CommandListElement{{preset_item.element_name }}_{{ preset_item.id }}
        {% endif %}
    {% endfor %}
{%endmacro%}

{# ─── HELPERS ──────────────────────────────────────────────────────────────── #}
{#
  generate_helpers — вызывает CommandList хелперов из host-элемента.
  Хелперы генерируются как отдельные CommandList секции в data.j2 (или elements_helpers.j2),
  поэтому здесь только run-вызовы с правильным нейминг-ключом.
  Нейминг: {host_name}_{helper_name_lstrip_underscore}
  Example: host=ButtonB, helper=_helper_arrow → ButtonB_helper_arrow
#}
{%macro generate_helpers(element, mod_file, scene)%}
    {% if not element.is_preset and not element.is_helper %}
        {% for ref in element.helper_ids %}
            {% set helper_item = scene.rzm.elements | selectattr('id', 'equalto', ref.helper_id) | first %}
            {% if helper_item %}
                {%- set h_raw_name = helper_item.element_name -%}
                {%- set h_clean = h_raw_name.lstrip('_') -%}
                {%- set h_name = element.element_name ~ "_" ~ element.id ~ "_" ~ h_clean ~ "_" ~ helper_item.id -%}

                $positionX = $P_PX
                $positionY = $P_PY
                $sizeX = $P_SX
                $sizeY = $P_SY
                run = CommandListElement{{h_name}}
            {% endif %}
        {% endfor %}
    {% endif %}
{%endmacro%}

{# ─── HELPER ELEMENT DEFINITION ─────────────────────────────────────────────
  generate_helper_definition — генерирует полный CommandList блок для одного хелпера,
  привязанного к конкретному host-элементу.
  Вызывается из elements_helpers.j2 по каждому уникальному host+helper паре.
  
  Параметры:
    helper_item   — элемент-хелпер (из scene.rzm.elements, is_helper=True)
    host_item     — host-элемент, к которому привязан хелпер
    mod_file      — имя модфайла
    scene         — сцена
    
  Нейминг: host_element_name + '_' + helper_element_name.lstrip('_')
  ID: helper_item.id + 3500  (оффсет для уникальности в 3DMigoto)
#}
{%macro generate_helper_definition(helper_item, host_item, mod_file, scene)%}
    {%- set h_raw_name = helper_item.element_name -%}
    {%- set h_clean = h_raw_name.lstrip('_') -%}
    {%- set h_name = host_item.element_name ~ "_" ~ host_item.id ~ "_" ~ h_clean ~ "_" ~ helper_item.id -%}
    {%- set h_id = helper_item.id + host_item.id * 2 + 6969 -%}

    {% if helper_item.export_tiers | length > 0 %}
    ;[META-INFO] [START] [DELETE] [ELEMENT] [{{ h_name }}] {{ utils.tier_tags(helper_item) }}
    {% endif %}
[CommandListElement{{h_name}}]
$id = {{h_id}}
$classType = {{ utils.get_cls_id(helper_item) }}
local $LocalVisibility
local $hoverInterpolate
local $clickInterpolate
    {% if helper_item.visibility_mode == 'CONDITIONAL' %}
if {{ utils.normalize_all_vars(helper_item.visibility_condition, host_item, scene) }}
    $LocalVisibility = 1
endif
    {% elif helper_item.visibility_mode == 'HIDED' %}
    $LocalVisibility = 0
    {% else %}
    $LocalVisibility = 1
    {% endif %}
if $LocalVisibility
    {{generate_position_and_size(helper_item, host_item, mod_file, scene)}}
    {{generate_interactions_for_helper(helper_item, host_item, scene)}}
    {%if helper_item.color%}{{generate_color(helper_item,parent_element, scene)}}{%endif%}
    {{generate_image(helper_item, host_item, scene)}}
    {%if helper_item.fx%}{{generate_fx(helper_item)}}{%endif%}
    {%- set h_cls = utils.get_cls(helper_item)|trim -%}
    {% if h_cls == 'SLIDER' %}
        {{ handle_slider_logic(helper_item, host_item, mod_file, scene) }}
        run = CustomShaderRCI2D_SLIDER
    {% elif h_cls == 'TEXT' %}
        {{generate_text(helper_item, host_item)}}
        ;run = CustomShaderRCI2D_TEXT_{{helper_item.text_align | default('LEFT')}}
    {% elif h_cls == 'VECTOR_BOX' %}
        run = CommandList{{ helper_item.element_name }}_{{ helper_item.id }}Helper
        run = CustomShaderRCI2D
    {% else %}
        run = CustomShaderRCI2D
    {% endif %}
    {% if h_cls == 'GRID_CONTAINER' %}
        {{ handle_grid_container_logic(helper_item, mod_file, scene) }}
    {% elif h_cls == 'BUTTON' %}
        {{ handle_button_logic(helper_item, host_item, mod_file, scene) }}
    {% endif %}
    {{generate_hovertext(helper_item, host_item)}}
endif
    {% if helper_item.export_tiers | length > 0 %}
    ;[META-INFO] [END] [DELETE] [ELEMENT] [{{ h_name }}] {{ utils.tier_tags(helper_item) }}
    {% endif %}
{%endmacro%}

{# Interactions для хелпера — аналог generate_interactions, но с normalize_all_vars и parent_element #}
{%macro generate_interactions_for_helper(element, parent_element, scene)%}
    {% if utils.has_any_attribute(element) or element.hover_event_enabled or element.click_event_enabled %}
    run = CommandListCoreFNUpdateHoverState
    {% endif %}
    {% if utils.has_attribute(element, 'isClickable') or utils.has_attribute(element, 'isHoldable')%}
    run = CommandListNavProcessElement
    {%endif%}
    {% if utils.has_attribute(element, 'isClickable') %}
        run = CommandListCoreFNHandleClick
    {% endif %}
    {% if utils.has_attribute(element, 'isHoldable') %}
        run = CommandListCoreFNHandleHold
    {% endif %}

    {% if element.hover_event_enabled and element.hover_event_formula %}
    if $hoveredID == $id || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
    {{ utils.normalize_all_vars(element.hover_event_formula, parent_element, scene) }}
    endif
    {% endif %}

    {% if element.click_event_enabled and element.click_event_formula %}
    if $id == $clickTriggerID
    {{ utils.normalize_all_vars(element.click_event_formula, parent_element, scene) }}
    endif
    {% endif %}
{%endmacro%}


{# OTHER STUFF#}
{%macro generate_position_and_size(element,parent_element,mod_file,scene)%}
    {% set class_name = utils.get_cls(element)|trim %}
    
    {% if element.is_preset %}
        {# ЛОГИКА ДЛЯ ПРЕСЕТОВ: Либо наследуют всё, либо применяют формулу поверх наследства #}
        
        {% if element.position_is_formula %}
        $positionX = {{ utils.normalize_all_vars(element.position_formula_x, parent_element, scene) }}
        $positionY = {{ utils.normalize_all_vars(element.position_formula_y, parent_element, scene) }}
        {% endif %}

        {% if element.size_is_formula %}
        $sizeX = {{ utils.normalize_all_vars(element.size_formula_x, parent_element, scene) | default('$sizeX') }}
        $sizeY = {{ utils.normalize_all_vars(element.size_formula_y, parent_element, scene) | default('$sizeY') }}
        {% endif %}
        {% if element.rotation_is_formula %}
        $rotation = {{ utils.normalize_all_vars(element.rotation_formula,parent_element, scene) }}
        {% elif element.rotation != 0.0 %}
        $rotation = {{ element.rotation }}
        {% endif %}
        {% if element.flip_x == 1%}
        ;$flipX = 1
        {% endif %}
        {% if element.flip_y == 1%}
        ;$flipY = 1
        {% endif %}
    {% else %}
        {# СТАНДАРТНАЯ ЛОГИКА ДЛЯ ОБЫЧНЫХ ЭЛЕМЕНТОВ #}
        {% set parent_class_name = utils.get_cls(parent_element)|trim if parent_element else none %}
        {% set grid_child = (scene.rzm.elements | selectattr('parent_id', 'equalto', element.id) | selectattr('elem_class', 'equalto', 1)) | first %}
        
        {% if element.position_is_formula %}
            $positionX = ({{ utils.normalize_all_vars(element.position_formula_x, parent_element, scene) }})
            $positionY = ({{ utils.normalize_all_vars(element.position_formula_y, parent_element, scene) }})
        {% elif element.parent_id > -1%}
            $positionX = $positionX + {{ element.position[0] if element.position else 0}}
            $positionY = $positionY + {{ element.position[1] if element.position else 0}}
        {% elif utils.has_attribute(element, 'isMovable')%}
            $positionX = ${{element.element_name}}PositionX
            $positionY = ${{element.element_name}}PositionY
        {% else %}
            $positionX = {{ element.position[0] if element.position else 0}}
            $positionY = {{ element.position[1] if element.position else 0}}
        {% endif %}

        {% if class_name == 'GRID_CONTAINER' and element.parent_id > -1%}
            ${{element.element_name}}PositionX = $positionX
            ${{element.element_name}}PositionY = $positionY
        {%endif%}

        {% if class_name == 'ANCHOR' and grid_child %}
            ${{ element.element_name }}SizeX = ${{grid_child.element_name}}SizeX
            $sizeX = ${{ element.element_name }}SizeX
            $sizeY = {{ element.size[1] | default(0) | int}}
        {% elif element.size_is_formula %}
            $sizeX = ({{ utils.normalize_all_vars(element.size_formula_x, parent_element, scene) | default('(100) * $sizeMultiplier')}}) * $sizeMultiplier
            $sizeY = ({{ utils.normalize_all_vars(element.size_formula_y, parent_element, scene) | default('(100) * $sizeMultiplier')}}) * $sizeMultiplier
        {% elif utils.has_attribute(element, 'isResizable')%}
            $sizeX = (${{ element.element_name | default('noname') }}SizeX) * $sizeMultiplier
            $sizeY = (${{ element.element_name | default('noname') }}SizeY) * $sizeMultiplier
        {% elif element.size and element.size|length == 2 %}
            $sizeX = ({{ element.size[0] }}) * $sizeMultiplier
            $sizeY = ({{ element.size[1] }}) * $sizeMultiplier
        {% else %}
            $sizeX = (100) * $sizeMultiplier
            $sizeY = (100) * $sizeMultiplier
        {% endif %}

        {% if element.rotation_is_formula %}
        $rotation = {{ utils.normalize_all_vars(element.rotation_formula,parent_element, scene)}}
        {% elif element.rotation != 0.0 %}
        $rotation = {{ element.rotation }}
        {% endif %}
        {% if element.flip_x == 1%}
        $flipX = 1
        {% endif %}
        {% if element.flip_y == 1%}
        $flipY = 1
        {% endif %}
    {% endif %}

    {% if element.transform_is_formula %}
    {{ utils.normalize_all_vars(element.transform_formula, parent_element, scene) }}
    {% else %}
    {% endif %}
{%endmacro%}
{%macro generate_interactions(element, parent_element, scene)%}
    {% set is_child_of_grid = parent_element and utils.get_cls(parent_element)|trim == 'GRID_CONTAINER' %}
    {% if not is_child_of_grid %}
        {% if utils.has_any_attribute(element) or element.hover_event_enabled or element.click_event_enabled %}
        run = CommandListCoreFNUpdateHoverState
        {% endif %}
        {% if utils.has_attribute(element, 'isClickable') or utils.has_attribute(element, 'isHoldable')%}
        run = CommandListNavProcessElement
        {%endif%}
        {% if utils.has_attribute(element, 'isMovable') %}
            run = CommandListCoreFNComputeMouseInteractions.Move
        {% endif %}
        {% if utils.has_attribute(element, 'isResizable') %}
            run = CommandListCoreFNComputeMouseInteractions.Resize
        {% endif %}
        {% if utils.has_attribute(element, 'isClickable') %}
            run = CommandListCoreFNHandleClick
        {% endif %}
        {% if utils.has_attribute(element, 'isHoldable') %}
            run = CommandListCoreFNHandleHold
            if w33 > 0.2
            $LocalHoldTimer = ($LocalHoldTimer + w33) + $dt
            endif
        {% endif %}

        {# --- Новые блоки кастомных событий --- #}
        {% if element.hover_event_enabled and element.hover_event_formula %}
        {# Выполняется, когда мышь над элементом #}
        if $hoveredID == $id || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
        {{ utils.normalize_all_vars(element.hover_event_formula, parent_element, scene) }}
        endif
        {% endif %}

        {% if element.click_event_enabled and element.click_event_formula %}
        {# Выполняется при клике #}
        if $id == $clickTriggerID
        {{ utils.normalize_all_vars(element.click_event_formula, parent_element, scene) }}
        $clickInterpolate = 1
        endif
        {% endif %}
    {% endif %}

    {% if utils.has_attribute(element, 'isMovable')%}
        run = CommandListCoreAlignment.ANTICHECK
        ${{element.element_name}}PositionX = $positionX 
        ${{element.element_name}}PositionY = $positionY
        run = CommandListCoreAlignment.Check
    {% endif %}
    {% if utils.has_attribute(element, 'isResizable')%}
        ${{element.element_name}}SizeX = $SizeX
        ${{element.element_name}}SizeY = $SizeY
    {% endif %}
{%endmacro%}

{%macro generate_color(element,parent_element, scene)%}
    {% if element.color_is_formula %}
    {# Режим формулы: полная свобода #}
    $colorR = {{ utils.normalize_all_vars(element.color_formula_r,parent_element, scene) }}
    $colorG = {{ utils.normalize_all_vars(element.color_formula_g,parent_element, scene) }}
    $colorB = {{ utils.normalize_all_vars(element.color_formula_b,parent_element, scene) }}
    $colorA = {{ utils.normalize_all_vars(element.color_formula_a,parent_element, scene) }}
    {% else %}
    {# Старый режим: статические значения #}
    {% if element.color and element.color|length == 4 %}
    $colorR = {{ element.color[0] | float}}
    $colorG = {{ element.color[1] | float}}
    $colorB = {{ element.color[2] | float}}
    $colorA = {{ element.color[3] | float}}
    {% else %}
    $colorR = 0.0
    $colorG = 0.0
    $colorB = 0.0
    $colorA = 0.5
    {% endif %}
    {% endif %}
{%endmacro%}

{% macro generate_image(element, parent_element, scene) %}
    {% set img_map = scene.rzm.image_mapping %}
    {% set eid = element.id | string %}

    {# --- Resolve safe_img_mode --- #}
    {% set raw_mode = element.image_mode[0] if element.image_mode is iterable and element.image_mode is not string else element.image_mode %}
    {% if raw_mode == 'SINGLE' %}
        {% set safe_img_mode = 0 %}
    {% elif raw_mode == 'CONDITIONAL' or raw_mode == 'LIST' or raw_mode == 'CONDITIONAL_LIST' %}
        {% set safe_img_mode = 1 %}
    {% elif raw_mode == 'INDEX' or raw_mode == 'INDEX_LIST' %}
        {% set safe_img_mode = 2 %}
    {% else %}
        {% set safe_img_mode = 0 %}
    {% endif %}

    {# --- DEBUG --- #}
    {% if scene.rzm.addons.debugger_info == 1 %}
    ; ===IMAGE=== elem={{ element.element_name }} mode={{ raw_mode }} img={{ element.image_id }}
    {% endif %}

    {# ── SINGLE ── #}
    {% if safe_img_mode == 0 and element.image_id is defined and element.image_id != -1 %}
        {% set inst_id = img_map['elements'].get(eid) %}
        {% if inst_id is not none %}
$imageID = {{ inst_id }}
        {% endif %}

    {# ── CONDITIONAL_LIST ── #}
    {% elif safe_img_mode == 1 and element.conditional_images %}
        {% for item in element.conditional_images %}
            {% set ckey = eid ~ '_img_' ~ item.image_id %}
            {% set inst_id = img_map['elements'].get(ckey, img_map['elements'].get(eid)) %}
        {% if loop.first %}if {{ utils.normalize_all_vars(item.condition, parent_element, scene) }}
        {% else %}elif {{ utils.normalize_all_vars(item.condition, parent_element, scene) }}
        {% endif %}
            $imageID = {{ inst_id if inst_id is not none else 0 }}
        {% endfor %}
    else
        {% set fb = img_map['elements'].get(eid ~ '_img_' ~ element.conditional_images[0].image_id, img_map['elements'].get(eid)) %}
        $imageID = {{ fb if fb is not none else 0 }}
    endif

    {# ── INDEX_LIST ── #}
    {% elif safe_img_mode == 2 and element.conditional_images and element.value_link %}
        {% set var_name = utils.format_var(element.value_link[0].value_name) %}
        {% for item in element.conditional_images %}
            {% set ckey = eid ~ '_img_' ~ item.image_id %}
            {% set inst_id = img_map['elements'].get(ckey, img_map['elements'].get(eid)) %}

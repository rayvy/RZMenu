{% macro handle_grid_container_logic(element, mod_file,scene) %}
    {# Логика ограничения размера для Grid'а #}
    {% if element.grid_wrap_mode == "SCROLL" %}
    if ${{element.element_name}}SizeX < ({{ element.grid_cell_size }} * 4)
    ${{element.element_name}}sizeX = ({{ element.grid_cell_size }} * 4)+2
    endif
    if ${{element.element_name}}SizeY < ({{ element.grid_cell_size }} * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess)
    ${{element.element_name}}sizeY = ({{ element.grid_cell_size }} * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess*2)
    endif
    if ${{element.element_name}}SizeX > ({{ element.grid_cell_size }} * 24)
    ${{element.element_name}}sizeX = ({{ element.grid_cell_size }} * 24)+2
    endif
    if ${{element.element_name}}SizeY > ({{ element.grid_cell_size }} * 3 * 1)+ 12
    ${{element.element_name}}sizeY = ({{ element.grid_cell_size }} * 3 * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess*2)
    endif
    {% endif %}

    {# Логика скролла для Grid'а #}
    {% if element.grid_wrap_mode == "SCROLL" %}
    if ${{ element.element_name }}ScrollActive == 1
        Local $loordsX
        if $capturedID == $id
            if $dragState == 0
                $dragState = 1
                $loordsX = $cursorX - $positionX
            else if $dragState == 1
                ${{element.element_name}}Scroll = ($cursorX - $loordsX) / $SizeX
                if ${{element.element_name}}Scroll < 0
                ${{element.element_name}}Scroll = 0
                else if ${{element.element_name}}Scroll > 1
                ${{element.element_name}}Scroll = 1
                endif
                ${{element.element_name}}Scroll = 1 - ${{element.element_name}}Scroll
            endif
        endif
    endif
    if ${{ element.element_name }}ScrollActive == 1
        run = CommandList{{element.element_name}}_{{element.id}}Scroller
    endif
    {% endif %}
{% endmacro %}

{% macro handle_button_logic(element, parent_element, mod_file, scene) %}
    {# --- Визуальная подсветка --- #}
    if $hoveredID == $id || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
        y110 = 1
    endif

    {# --- Логика для value_link (если он есть) --- #}
    {% if element.value_link %}
        {% set first_link = element.value_link[0] %}
        {% set target_var = utils.format_var(first_link.value_name,parent_element, scene) %}
        {% set target_var_is_toggle = 0 %}
        {% if first_link.value_name.startswith('@') %}{% set target_var_is_toggle = 1 %}{% endif %}
        {% if not element.is_preset %}
        $ValueX24Interpolated = $ValueX24Interpolated + (${{ target_var }} - $ValueX24Interpolated) * ($dtCustom + 0.0069)
        {% if target_var.target_var_is_toggle == 1%}
        if $ValueX24Interpolated > {{ target_var.toggle_length - 1 }}
        ${{ target_var }} = {{ target_var.toggle_length - 1 }}
        elif $ValueX24Interpolated < 0
        $ValueX24Interpolated = 0
        endif
        {% else %}
        if $ValueX24Interpolated < {{ target_var.value_min | default(0.0) | float }}
        $ValueX24Interpolated = {{ target_var.value_min | default(0.0) | float }}
        elif $ValueX24Interpolated > {{ target_var.value_max | default(0.0) | float }}
        $ValueX24Interpolated = {{ target_var.value_max | default(0.0) | float }}
        endif
        {% endif %}
        {% endif %}

        {# Отображение цифрового значения на кнопке #}
        {% if not element.disable_button_nums %}
        x24 = ${{ target_var }}
        run = CommandListCoreFXRenderButtonNumbers
        {% endif %}
    
        {# --- Логика клика --- #}
        if $id == $clickTriggerID
        
            {# 1. СТАНДАРТНАЯ ЛОГИКА (Выполняется всегда первой) #}
            {% if first_link.value_name and target_var_is_toggle == 1 %}
                {% for toggle in scene.rzm.toggle_definitions %}
                    {% if toggle.toggle_name == target_var %}
                        if ${{ target_var }} < {{ toggle.toggle_length - 1 }}
                            ${{ target_var }} = ${{ target_var }} + 1
                        else
                            ${{ target_var }} = 0
                        endif
                    {% endif %}
                {% endfor %}
            {% else %}
                {% set min_val = first_link.value_min | default(0.0) | float %}
                {% set max_val = first_link.value_max | default(1.0) | float %}
                ; Cycling logic for range [{{ min_val }}, {{ max_val }}]
                if ${{ target_var }} < {{ max_val }}
                    ${{ target_var }} = ${{ target_var }} + 1
                else
                    ${{ target_var }} = {{ min_val }}
                endif
            {% endif %}

            {# 2. ЛОГИКА ФОРМУЛЫ (Добавляется ПОСЛЕ стандартной логики) #}
            {% if element.value_link_is_formula %}
                {{ utils.normalize_all_vars(element.value_link_formula, parent_element, scene) }}
            {% endif %}
            
            {# 3. ПРИВЯЗКА RUN LINK #}
            {% if element.run_link_id is defined and element.run_link_id != -1 %}
                {% set target_rl = scene.rzm.run_links | selectattr('id', 'equalto', element.run_link_id) | first %}
                {% if target_rl and target_rl.name %}
            run = CommandList{{ target_rl.name }}
                {% endif %}
            {% endif %}
            
            $clickInterpolate = 1
        endif
    
        {# Логика вызова попапа #}
        {% if utils.has_attribute(element, 'hadPopup') and not element.disable_button_popup %}
            if w33 > 0.4 || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
                run = CommandListElement{{ element.element_name }}_{{ element.id }}Popup
            endif
        {# Логика для геймпада, если попап отключен #}
        {% else %}
            if $isGamepadEditing == 1 && $GamepadEditedID == $id
                if $Gamepad_Interaction_Type == 1
                    ${{ target_var }} = 1 - ${{ target_var }}
                endif
            endif
        {% endif %}
    {% else %}
        {# --- Логика для простой кнопки БЕЗ value_link --- #}
        if $id == $clickTriggerID
            
            {# Здесь просто выполняем формулу, так как переменных нет #}
            {% if element.value_link_is_formula %}
                {{ utils.normalize_all_vars(element.value_link_formula, parent_element, scene) }}
            {% endif %}
            
            {# ПРИВЯЗКА RUN LINK #}
            {% if element.run_link_id is defined and element.run_link_id != -1 %}
                {% set target_rl = scene.rzm.run_links | selectattr('id', 'equalto', element.run_link_id) | first %}
                {% if target_rl and target_rl.name %}
            run = CommandList{{ target_rl.name }}
                {% endif %}
            {% endif %}
            
            $clickInterpolate = 1
        endif
    {% endif %}

    {# --- MASTER/SLAVE синхронизация value_link --- #}
    {% if element.value_link and element.value_link|length > 1 %}
        {% set master_link = element.value_link[0] %}
        {% set master_var = utils.format_var(master_link.value_name,parent_element, scene) %}
        {% for slave in element.value_link[1:] %}
            {% if slave.value_name %}
                ${{ utils.format_var(slave.value_name,parent_element, scene) }} = ${{ master_var }}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endmacro %}

{% macro handle_element_in_grid(element, parent_element, mod_file,scene) %}
$request_weight = {{ 4 if utils.get_cls(element)|trim == 'SLIDER' else 1 }}
$current_positionX = $current_positionX + ($target_positionX - $current_positionX) * ($dt*8)
$current_positionY = $current_positionY + ($target_positionY - $current_positionY) * ($dt*8)

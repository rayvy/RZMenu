    if $ValueX24Interpolated < {{ (first_link.value_min| default(0.0) | float) }}
    $ValueX24Interpolated = {{ (first_link.value_min| default(0.0) | float) }}
    elif $ValueX24Interpolated > {{ (first_link.value_max| default(0.0) | float) }}
    $ValueX24Interpolated = {{ (first_link.value_min| default(0.0) | float) }}
    endif
{% endif %}
{% endmacro %}


{% macro generate_text(element) %}
    {% if element.text_id or (element.text_mode != 'SINGLE' and element.conditional_texts|length > 0) %}
        run = CommandListGetTextElement{{ element.id }}
    {% endif %}
    
    {% if element.text_align == 1 %}
        $texSizeX = 1
    {% elif element.text_align == 2 %}
        $texSizeX = 2
    {% else %}
        $texSizeX = 0
    {% endif %}
{% endmacro %}

{%macro generate_hovertext(element)%}
    {% if element.hover_text_id %}
        if $CursorX > $PositionX && $CursorX < ($PositionX + $SizeX) && $CursorY > $PositionY && $CursorY < ($PositionY + $SizeY)
        y24 = 1
        run  = CommandListGetTextHoverElement{{ element.id }}
        endif
    {%endif%}
{%endmacro%}

{%macro generate_child(element,mod_file,scene)%}
    {% for child in scene.rzm.elements %}
        {% if child.parent_id == element.id and not child.is_preset and not child.disable_export %}

            $PositionX = $P_PX
            $PositionY = $P_PY
            $SizeX = $P_SX
            $SizeY = $P_SY
            run = CommandListElement{{child.element_name}}
        {% endif %}
    {% endfor %}
{%endmacro%}

{% macro handle_grid_container_logic(element, mod_file,scene) %}
    {# Логика ограничения размера для Grid'а #}
    {% if element.grid_wrap_mode == "SCROLL" %}
    if ${{element.element_name}}SizeX < ({{ element.grid_cell_size }} * 4)
    ${{element.element_name}}sizeX = ({{ element.grid_cell_size }} * 4)+2
    endif
    if ${{element.element_name}}SizeY < ({{ element.grid_cell_size }} * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess)
    ${{element.element_name}}sizeY = ({{ element.grid_cell_size }} * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess*2)
    endif
    if ${{element.element_name}}SizeX > ({{ element.grid_cell_size }} * 24)
    ${{element.element_name}}sizeX = ({{ element.grid_cell_size }} * 24)+2
    endif
    if ${{element.element_name}}SizeY > ({{ element.grid_cell_size }} * 3 * 1)+ 12
    ${{element.element_name}}sizeY = ({{ element.grid_cell_size }} * 3 * 1)+($rzmUIRenderSettings_ScrollBarThiccnkess*2)
    endif
    {% endif %}

    {# Логика скролла для Grid'а #}
    {% if element.grid_wrap_mode == "SCROLL" %}
    if ${{ element.element_name }}ScrollActive == 1
        Local $loordsX
        if $capturedID == $id
            if $dragState == 0
                $dragState = 1
                $loordsX = $cursorX - $positionX
            else if $dragState == 1
                ${{element.element_name}}Scroll = ($cursorX - $loordsX) / $SizeX
                if ${{element.element_name}}Scroll < 0
                ${{element.element_name}}Scroll = 0
                else if ${{element.element_name}}Scroll > 1
                ${{element.element_name}}Scroll = 1
                endif
                ${{element.element_name}}Scroll = 1 - ${{element.element_name}}Scroll
            endif
        endif
    endif
    if ${{ element.element_name }}ScrollActive == 1
        run = CommandList{{element.element_name}}Scroller
    endif
    {% endif %}
{% endmacro %}

{% macro handle_button_logic(element, parent_element, mod_file, scene) %}
    {# --- Визуальная подсветка --- #}
    if $hoveredID == $id || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
        y110 = 1
    endif

    {# --- Логика для value_link (если он есть) --- #}
    {% if element.value_link %}
        {% set first_link = element.value_link[0] %}
        {% set target_var = utils.format_var(first_link.value_name) %}
        {% set target_var_is_toggle = 0 %}
        {% if first_link.value_name.startswith('@') %}{% set target_var_is_toggle = 1 %}{% endif %}

        {# Отображение цифрового значения на кнопке #}
        {% if not element.disable_button_nums %}
        x24 = ${{ target_var }}
        run = CommandListCoreFXRenderButtonNumbers
        {% endif %}
    
        {# --- Логика клика --- #}
        if $id == $clickTriggerID
        
            {# 1. СТАНДАРТНАЯ ЛОГИКА (Выполняется всегда первой) #}
            {% if first_link.value_name and target_var_is_toggle == 1 %}
                {% for toggle in scene.rzm.toggle_definitions %}
                    {% if toggle.toggle_name == target_var %}
                        if ${{ target_var }} < {{ toggle.toggle_length - 1 }}
                            ${{ target_var }} = ${{ target_var }} + 1
                        else
                            ${{ target_var }} = 0
                        endif
                    {% endif %}
                {% endfor %}
            {% else %}
                {% set min_val = first_link.value_min | default(0.0) | float %}
                {% set max_val = first_link.value_max | default(1.0) | float %}
                ; Cycling logic for range [{{ min_val }}, {{ max_val }}]
                if ${{ target_var }} < {{ max_val }}
                    ${{ target_var }} = ${{ target_var }} + 1
                else
                    ${{ target_var }} = {{ min_val }}
                endif
            {% endif %}

            {# 2. ЛОГИКА ФОРМУЛЫ (Добавляется ПОСЛЕ стандартной логики) #}
            {% if element.value_link_is_formula %}
                {{ element.value_link_formula }}
            {% endif %}

        endif
    
        {# Логика вызова попапа #}
        {% if utils.has_attribute(element, 'hadPopup') and not element.disable_button_popup %}
            if w33 > 0.4 || ($isGamepadEditing == 1 && $GamepadEditedID == $id)
                run = CommandListElement{{ element.element_name }}Popup
            endif
        {# Логика для геймпада, если попап отключен #}
        {% else %}
            if $isGamepadEditing == 1 && $GamepadEditedID == $id
                if $Gamepad_Interaction_Type == 1
                    ${{ target_var }} = 1 - ${{ target_var }}
                endif
            endif
        {% endif %}

    {% else %}
        {# --- Логика для простой кнопки БЕЗ value_link --- #}
        if $id == $clickTriggerID
            ; Click registered for simple action button: {{ element.element_name }}
            
            {# Здесь просто выполняем формулу, так как переменных нет #}
            {% if element.value_link_is_formula %}
                {{ element.value_link_formula }}
            {% endif %}
        endif
    {% endif %}

    {# --- MASTER/SLAVE синхронизация value_link --- #}
    {% if element.value_link and element.value_link|length > 1 %}
        {% set master_link = element.value_link[0] %}
        {% set master_var = utils.format_var(master_link.value_name) %}
        {% for slave in element.value_link[1:] %}
            {% if slave.value_name %}
                ${{ utils.format_var(slave.value_name) }} = ${{ master_var }}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endmacro %}

{% macro handle_element_in_grid(element, parent_element, mod_file,scene) %}
$request_weight = {{ 4 if utils.get_cls(element)|trim == 'SLIDER' else 1 }}
$current_positionX = $current_positionX + ($target_positionX - $current_positionX) * ($dt*8)
$current_positionY = $current_positionY + ($target_positionY - $current_positionY) * ($dt*8)
$current_sizeX     = $current_sizeX     + ($target_sizeX     - $current_sizeX) * ($dt*8)
$current_sizeY     = $current_sizeY     + ($target_sizeY     - $current_sizeY) * ($dt*8)

{% if parent_element.grid_wrap_mode[0] == "SCROLL" %}
    run = CommandList{{parent_element.element_name[0]}}AdaptiveUnlimitedSizeAndScroll
{% else %}
    run = CommandList{{parent_element.element_name[0]}}AdaptiveUnlimitedCount
{% endif %}
;Изменить нижние 4 строки
$target_positionX = $PositionX
$target_positionY = $PositionY
$target_sizeX = $SizeX
$target_sizeY = $SizeY
$positionX = $current_positionX
$positionY = $current_positionY
$sizeX = $current_sizeX
$sizeY = $current_sizeY
run = CommandListCoreFNUpdateHoverState
{% if utils.has_attribute(element, 'isClickable') %}
    run = CommandListCoreFNHandleClick
{% endif %}
{% if utils.has_attribute(element, 'isHoldable') %}
    run = CommandListCoreFNHandleHold
{% endif %}

if $hoveredID == $id 
    y110 = 1
endif
if ($PositionX+($SizeX/2)-5) > ${{ parent_element.element_name[0] }}PositionX && ($PositionX + ($SizeX/2)+5) < ${{ parent_element.element_name[0] }}PositionX + ${{ parent_element.element_name[0] }}SizeX
    $LocalVisibility = 1
else 
    $LocalVisibility = 0
endif
{% endmacro %}


{% macro handle_slider_logic(element, parent_element, mod_file,scene) %}
;slider
{% if element.value_link %}
    {% set first_link = element.value_link[0] %}
    run = CommandList{{element.element_name}}Helper
    {# RZM_SLIDER_LIMIT: Визуализация — приведение значения к 0.0-1.0 для отображения ползунка #}
    local $range_span_display = {{ (first_link.value_max | default(1.0) | float) }} - {{ (first_link.value_min| default(0.0) | float) }}
    if $range_span_display > 0.0001
        x24 = (${{utils.format_var(first_link.value_name)}} - {{ (first_link.value_min| default(0.0) | float) }}) / $range_span_display
    else
        x24 = 0.0
    endif

    run = CommandListCoreFNHandleHold
{% endif %}
{% endmacro %}

{%macro ControllerCursor(element,parent_element,mod_file,scene)%}
    [CommandListElement{{ element.element_name }}]
    $id = {{ element.id }}
    local $LocalVisibility
    if $inputMode
    $LocalVisibility = 1
    else
    $LocalVisibility = 0
    endif
    $drawType = 0
    w33 = 0
    local $cursorTargetPosX
    local $cursorTargetPosY
    $cursorTargetPosX = $cursorTargetPosX + ($cursorX - $cursorTargetPosX) * ($dt*8)
    $cursorTargetPosY = $cursorTargetPosY + ($cursorY - $cursorTargetPosY) * ($dt*8)
    $positionX = $cursorTargetPosX - 16
    $positionY = $cursorTargetPosY - 16
    $sizeX = (32) * $sizeMultiplier
    $sizeY = (32) * $sizeMultiplier
    if $LocalVisibility
        run = CommandListGetImageCords{{element.image_id}}
        if $TexPosX + $TexPosY + $TexSizeX + $TexSizeY <= 0
            if $DrawType != 1
            $drawType = 0
            $colorR = 1.0
            $colorG = 0.0
            $colorB = 0.0
            $colorA = 1.0
            endif
        endif
        x110 = 1
        y110 = 6
        $scissorX = 0
        $scissorY = 0
        $scissorZ = 0
        $scissorW = 0
        run = CustomShaderRCI2D
    endif
{%endmacro%}
{% macro HSVColorPicker(element, parent_element, mod_file, scene) %}
    {# --- НАСТРОЙКА ИМЕН И ПЕРЕМЕННЫХ --- #}
    {% set element_id_name = element.element_name %}
    
    {# Переменные для логики Multi-Link #}
    {% set is_multi_link = false %}
    {% set state_var = "" %}
    {% set link_targets = [] %}

    {# Определение префикса переменных (var_prefix) #}
    {% if element.value_link %}
        {% if element.value_link|length == 1 %}
            {# СЦЕНАРИЙ 2: Одинарная ссылка. Заменяем префикс переменных на имя ссылки #}
            {% set var_prefix = utils.format_var(element.value_link[0].value_name) %}
        {% else %}
            {# СЦЕНАРИЙ 3: Мульти-ссылка. Префикс локальный (буфер), включаем логику свитча #}
            {% set var_prefix = element_id_name %}
            {% set is_multi_link = true %}
            {# 0-й индекс - переменная состояния #}
            {% set state_var = "$" + utils.format_var(element.value_link[0].value_name) %}
            {# Остальные - цели #}
            {% set link_targets = element.value_link[1:] %}
        {% endif %}
    {% else %}
        {# СЦЕНАРИЙ 1: Нет ссылок. Префикс берется от имени элемента #}
        {% set var_prefix = element_id_name %}
    {% endif %}

    {# Формируем итоговые имена переменных H/S/V #}
    {% set var_H = "$" + var_prefix + "_X" %}
    {% set var_S = "$" + var_prefix + "_Y" %}
    {% set var_V = "$" + var_prefix + "_Z" %}
    
    ; --- ГЛАВНЫЙ ЭЛЕМЕНТ (Квадрат Saturation/Value) ---
    [CommandListElement{{ element_id_name }}]
    $id = {{ element.id }}
    local $LocalVisibility
    {% if element.visibility_mode == 'CONDITIONAL' %}
    $LocalVisibility = 0
    if {{element.visibility_condition}}
        $LocalVisibility = 1
    endif
    {% elif element.visibility_mode == 'HIDED' %}
        $LocalVisibility = 0
    {% else %}
        $LocalVisibility = 1
    {% endif %}
    
    ; Переменные для хранения "родительских" координат квадрата
    local $P_PX
    local $P_PY
    local $P_SX
    local $P_SY

    if $LocalVisibility
        
        ; --- [СЦЕНАРИЙ 3] LOAD LOGIC: Загружаем данные из целей в буфер ---
        {% if is_multi_link %}
            {% for target in link_targets %}
                {% set t_name = utils.format_var(target.value_name) %}
                {% if loop.first %}
        if {{ state_var }} == {{ loop.index0 }}
                {% else %}
        elif {{ state_var }} == {{ loop.index0 }}
                {% endif %}
            {{ var_H }} = ${{ t_name }}_X
            {{ var_S }} = ${{ t_name }}_Y
            {{ var_V }} = ${{ t_name }}_Z
            {% endfor %}
        endif
        {% endif %}
        ; ------------------------------------------------------------------

        ; 1. Генерируем позицию и размер стандартным методом движка
        {{generate_position_and_size(element,parent_element,mod_file,scene)}}

        ; 2. СРАЗУ сохраняем эти данные.
        $P_PX = $PositionX
        $P_PY = $PositionY
        $P_SX = $SizeX
        $P_SY = $SizeY
        $PositionY = $PositionY + ($SizeY * 0.10)
        $SizeY = $SizeY * 0.9

        ; --- Взаимодействие (Квадрат) ---
        run = CommandListCoreFNUpdateHoverState
        run = CommandListNavProcessElement
        run = CommandListCoreFNHandleClick
        run = CommandListCoreFNHandleHold
        ; Хелпер меняет локальные var_H/S/V (или целевые, если сценарий 2)
        run = CommandListElement{{ element_id_name }}_Helper

        ; --- Отрисовка HSV квадрата ---
        $drawType = 728386
        $texPosX = {{ var_H }}
        $colorA = 1.0
        run = CustomShaderRCI2D

        ; --- Отрисовка курсора внутри квадрата ---
        local $cursorPosX = $P_PX + ($P_SX * {{ var_S }})
        local $cursorPosY = $P_PY + ($P_SY * (1.0 - {{ var_V }}))
        
        ; Тень курсора
        $drawType = 728387
        $positionX = $cursorPosX - 6
        $positionY = $cursorPosY - 6
        $sizeX = 12
        $sizeY = 12
        $colorR = 0.0
        $colorG = 0.0
        $colorB = 0.0
        $colorA = 0.7
        run = CustomShaderRCI2D
        
        ; Сам курсор
        $positionX = $cursorPosX - 5
        $positionY = $cursorPosY - 5
        $sizeX = 10
        $sizeY = 10
        $colorR = 1.0
        $colorG = 1.0
        $colorB = 1.0
        $colorA = 1.0
        run = CustomShaderRCI2D

        ; 3. ВАЖНО: Восстанавливаем координаты КВАДРАТА для слайдера
        $PositionX = $P_PX
        $PositionY = $P_PY
        $SizeX = $P_SX
        $SizeY = $P_SY

        ; --- Вызов слайдера Hue ---
        ; Слайдер может изменить var_H
        run = CommandListElement{{ element_id_name }}_HueSlider

        ; --- [СЦЕНАРИЙ 3] SAVE LOGIC: Выгружаем буфер обратно в цели ---
        ; Делаем это ПОСЛЕ helpers и HueSlider, чтобы сохранить свежие изменения
        {% if is_multi_link %}
            {% for target in link_targets %}
                {% set t_name = utils.format_var(target.value_name) %}
                {% if loop.first %}
        if {{ state_var }} == {{ loop.index0 }}
                {% else %}
        elif {{ state_var }} == {{ loop.index0 }}
                {% endif %}
            ${{ t_name }}_X = {{ var_H }}
            ${{ t_name }}_Y = {{ var_S }}
            ${{ t_name }}_Z = {{ var_V }}
            {% endfor %}
        endif
        {% endif %}
        ; ---------------------------------------------------------------

    endif

    ; --- ХЕЛПЕР ГЛАВНОГО ЭЛЕМЕНТА ---
    [CommandListElement{{ element_id_name }}_Helper]
    if $capturedID == {{ element.id }}
        local $s_val = ($cursorX - $positionX) / $sizeX
        local $v_val = 1.0 - (($cursorY - $positionY) / $sizeY)
        
        if $s_val < 0.0
            $s_val = 0.0
        endif
        if $s_val > 1.0
            $s_val = 1.0
        endif
        if $v_val < 0.0
            $v_val = 0.0
        endif
        if $v_val > 1.0
            $v_val = 1.0
        endif
        
        {{ var_S }} = $s_val
        {{ var_V }} = $v_val
    endif

    if $isGamepadEditing == 1 && $GamepadEditedID == {{ element.id }}
        local $hold_speed = 0.35
        if $nav_key_request_right == 1
            {{ var_S }} = {{ var_S }} + ($hold_speed * $dt * 2)
        endif
        if $nav_key_request_left == 1
            {{ var_S }} = {{ var_S }} - ($hold_speed * $dt * 2)
        endif
        if $nav_key_request_down == 1
            {{ var_V }} = {{ var_V }} + ($hold_speed * $dt * 2)
        endif
        if $nav_key_request_up == 1
            {{ var_V }} = {{ var_V }} - ($hold_speed * $dt * 2)
        endif
        if {{ var_S }} > 1.0
            {{ var_S }} = 1.0
        endif
        if {{ var_S }} < 0.0
            {{ var_S }} = 0.0
        endif
        if {{ var_V }} > 1.0
            {{ var_V }} = 1.0
        endif
        if {{ var_V }} < 0.0
            {{ var_V }} = 0.0
        endif
    endif

    ; --- ЭЛЕМЕНТ: СЛАЙДЕР HUE ---
    [CommandListElement{{ element_id_name }}_HueSlider]
    $id = {{ element.id + 10000 }}
    local $LocalVisibility
    $LocalVisibility = 1

    if $LocalVisibility
        ; Сдвигаем Y: Позиция Y квадрата + Высота квадрата + Отступ (20)
        $positionY = $positionY

        ; Высота слайдера фиксированная, ширина такая же как у квадрата
        $sizeY = $SizeY * 0.10

        ; --- Взаимодействие ---
        run = CommandListCoreFNUpdateHoverState
        run = CommandListNavProcessElement
        run = CommandListCoreFNHandleClick
        run = CommandListCoreFNHandleHold
        run = CommandListElement{{ element_id_name }}_HueSlider_Helper

        ; --- Отрисовка градиента ---
        $drawType = 728388
        $colorA = 1.0
        run = CustomShaderRCI2D

        ; --- Курсор слайдера ---
        local $cursorPosX = $positionX + ($sizeX * {{ var_H }})
        
        $drawType = 0
        $positionX = $cursorPosX - 2
        $positionY = $positionY - 2
        $sizeX = 4
        $sizeY = $sizeY + 4
        
        $colorR = 1.0
        $colorG = 1.0
        $colorB = 1.0
        $colorA = 1.0
        run = CustomShaderRCI2D
    endif

    ; --- ХЕЛПЕР СЛАЙДЕРА HUE ---
    [CommandListElement{{ element_id_name }}_HueSlider_Helper]
    if $capturedID == {{ element.id + 10000 }}
        local $h_val = ($cursorX - $positionX) / $sizeX
        if $h_val < 0.0
            $h_val = 0.0
        endif
        if $h_val > 1.0
            $h_val = 1.0
        endif
        {{ var_H }} = $h_val
    endif
    
    if $isGamepadEditing == 1 && $GamepadEditedID == {{ element.id + 10000 }}
        local $hold_speed = 0.35
        if $nav_key_request_right == 1
            {{ var_H }} = {{ var_H }} + ($hold_speed * $dt)
        endif
        if $nav_key_request_left == 1
            {{ var_H }} = {{ var_H }} - ($hold_speed * $dt)
        endif
        if {{ var_H }} > 1.0
            {{ var_H }} = 1.0
        endif
        if {{ var_H }} < 0.0
            {{ var_H }} = 0.0
        endif
    endif
{% endmacro %}
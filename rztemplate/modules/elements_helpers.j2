{% set DEBUG = true %}
{% import "modules/utils.j2" as utils with context %}

{# ─── НОВЫЕ МАКРОСЫ ДЛЯ ГЕНЕРАЦИИ ТЕКСТОВЫХ БЛОКОВ ─── #}

{% macro generate_text_resource_block(element, scene, text_offset_tracker, processed_ids, host=none) %}
    {%- set t_id = element.text_id | default('') | string -%}
    {# Редирект для ~PT: если хелпер просто хочет текст родителя, мы НЕ генерируем для него статический буфер здесь #}
    {%- set is_pure_redirect = host and (t_id == "~PT" or t_id == "~pt" or t_id == "~PText") -%}
    
    {% if t_id and not is_pure_redirect %}
        {%- set combined_id = (element.id ~ "_" ~ host.id) if (host and element.is_helper) else element.id -%}
        {% if combined_id not in processed_ids['text_elements'] %}
            {# Resolve ~meta_var system variables at export time with parent override #}
            {% set fallback_text = utils.resolve_meta_var(element.text_id | default("NO_TEXT"), scene, element, host) %}
            {% set resources_to_generate = [] %}
            
            {# --- Логика для CONDITIONAL_LIST --- #}
            {% if element.text_mode == 'CONDITIONAL_LIST' and element.conditional_texts %}
                {% set host_id = host.id if host else -1 %}
                {% for item in element.conditional_texts %}
                    {% set lookup_key = element.id ~ ":" ~ host_id ~ ":" ~ loop.index0 %}
                    {% set text_info = scene.rzm.text_mapping['conditional'].get(lookup_key, [0, 0]) %}
                    {% set text_id = text_info[0] %}

                    {% if loop.first %}if {{ utils.normalize_all_vars(item.condition, element, scene) }}
                    {% else %}elif {{ utils.normalize_all_vars(item.condition, element, scene) }}{% endif %}
                    {% if element.text_id_is_data %}
                        $TextIsData = 1
                        $TextID = {{ item.text_id }}
                        $texPosY = {{ element.text_id_data_length | default(1) }}
                    {% else %}
                        
                        $TextID = {{ text_id }}
                    {% endif %}
                {% endfor %}
                else
                {% set lookup_key = element.id ~ ":" ~ host_id %}
                {% set text_info = scene.rzm.text_mapping['single'].get(lookup_key, [0, 0]) %}
                {% set text_id = text_info[0] %}

                    {% if element.text_id_is_data %}
                        $TextIsData = 1
                        $TextID = {{ fallback_text }}
                        $texPosY = {{ element.text_id_data_length | default(1) }}
                    {% else %}
                        $TextID = {{ text_id }}
                    {% endif %}
                endif

            {# --- Логика для SINGLE --- #}
            {% else %}
                {% set host_id = host.id if host else -1 %}
                {% set lookup_key = element.id ~ ":" ~ host_id %}
                {% set text_info = scene.rzm.text_mapping['single'].get(lookup_key, [0, 0]) %}
                {% set text_id = text_info[0] %}

                {% if element.text_id_is_data %}
                    $TextIsData = 1
                    $TextID = {{ fallback_text }}
                    $texPosY = {{ element.text_id_data_length | default(1) }}
                {% else %}

                    $TextID = {{ text_id }}
                {% endif %}
            {% endif %}

            {# --- Ресурсы (ОТКЛЮЧЕНЫ - используем texts.bin) --- #}
            {#
            {% for res in resources_to_generate %}
            [ResourceTextElement{{ combined_id }}.{{ res.sub_id }}]
            type = Buffer
            data = "{{ res.content }}"
            {% endfor %}
            #}

            {% set _ = processed_ids['text_elements'].append(combined_id) %}
        {% endif %}
    {% endif %}
{% endmacro %}

{% macro generate_hover_text_resource_block(element, scene, text_offset_tracker, processed_ids, host=none) %}
    {%- set h_id_val = element.hover_text_id | default('') | string -%}
    {%- set is_pure_redirect = host and (h_id_val == "~PH" or h_id_val == "~ph" or h_id_val == "~PHover") -%}

    {% if h_id_val and not is_pure_redirect %}
        {%- set combined_id = (element.id ~ "_" ~ host.id) if (host and element.is_helper) else element.id -%}
        {% if combined_id not in processed_ids['hover_text_elements'] %}
            {% set text_content = utils.resolve_meta_var(element.hover_text_id, scene, element, host) %}
            {% set text_length = text_content | length %}
            {% set current_offset = text_offset_tracker[0] %}

            ;[CommandListGetTextHoverElement{{ combined_id }}]
            {% set host_id = host.id if host else -1 %}
            {% set lookup_key = element.id ~ ":" ~ host_id ~ ":hover" %}
            {% set text_info = scene.rzm.text_mapping['single'].get(lookup_key, [0, 0]) %}
            {% set text_id = text_info[0] %}
            {% set text_len = text_info[1] %}

            {% if element.hover_text_id_is_data %}
                $TextIsData = 1
                $TextID = {{ element.hover_text_id }}
                $textLength = {{ element.hover_text_id_data_length | default(1) }}
            {% else %}
                $TextID = {{ text_id }}
                $textLength = {{ text_len }}
            {% endif %}
            run = CustomShaderRCI2D_HOVERTEXT
            ;[ResourceTextHoverElement{{ combined_id }}]
            ;type = Buffer
            ;data = "{{ text_content }}"

            {% set _ = text_offset_tracker.pop(0) %}{% set _ = text_offset_tracker.append(current_offset + text_length) %}
            {% set _ = processed_ids['hover_text_elements'].append(combined_id) %}
        {% endif %}
    {% endif %}
{% endmacro %}

{# ─── МАКРОС RESOURCES_GENERATE (ОБНОВЛЕННЫЙ) ─── #}

{% macro resources_generate(mod_file,scene) %}
{% set text_offset_tracker = [0] %}
{% set processed_ids = {'text_elements': [], 'hover_text_elements': [], 'images': []} %}

{% if scene.rzm and scene.rzm.elements %}
    {# 1. Обработка ОБЫЧНЫХ элементов #}
    {% for element in scene.rzm.elements if not element.is_helper %}
        {{ generate_text_resource_block(element, scene, text_offset_tracker, processed_ids) }}
        {{ generate_hover_text_resource_block(element, scene, text_offset_tracker, processed_ids) }}
    {% endfor %}

    {# 2. Обработка ХЕЛПЕРОВ (уникально для каждого хоста) #}
    {% for host in scene.rzm.elements if host.helper_ids %}
        {% for ref in host.helper_ids %}
            {% set helper = scene.rzm.elements | selectattr('id', 'equalto', ref.helper_id) | first %}
            {% if helper %}
                {{ generate_text_resource_block(helper, scene, text_offset_tracker, processed_ids, host) }}
                {{ generate_hover_text_resource_block(helper, scene, text_offset_tracker, processed_ids, host) }}
            {% endif %}
        {% endfor %}
    {% endfor %}

    {# 3. Картинки (буферная логика) #}
    {% set img_map = scene.rzm.image_mapping %}
    {% for image in scene.rzm.images %}
        {% if image.id not in processed_ids['images'] %}
            {% set img_id_str = image.id | string %}
            {% if image.source_type == 'ANIMATED' %}
                {% set frame_indices = img_map['animated'].get(img_id_str, []) %}
                {% if frame_indices | length > 0 %}
                [CommandListGetImageCords{{ image.id }}]
                $drawType = 1
                local $anim_t = time % {{ "%.6f" | format(image.anim_total_duration / (image.anim_speed_multiplier|default(1.0))) }}

                {% set ns = {'t': 0.0, 'is_first': true} %}
                {% for seq in image.anim_sequence %}
                    {% set t_start = ns['t'] %}
                    {% set t_end = t_start + seq.duration / (image.anim_speed_multiplier|default(1.0)) %}
                    {% set img_idx = frame_indices[loop.index0] | default(0) %}
                    
                    {% if ns['is_first'] %}if $anim_t >= {{ "%.6f" | format(t_start) }} && $anim_t < {{ "%.6f" | format(t_end) }}
                        {% if ns.update({'is_first': false}) %}{% endif %}
                    {% else %}
                    elif $anim_t >= {{ "%.6f" | format(t_start) }} && $anim_t < {{ "%.6f" | format(t_end) }}
                    {% endif %}
                        $imageID = {{ img_idx }}
                    {% if ns.update({'t': t_end}) %}{% endif %}
                {% endfor %}
                endif
                {% endif %}
            {% elif image.source_type == 'VECTOR' %}
                {% set var_map = img_map['vector'].get(img_id_str, {}) %}
                {% if var_map %}
                [CommandListGetImageCords{{ image.id }}]
                $drawType = 1
                {% set ns = {'is_first': true} %}
                {% for eid, img_idx in var_map.items() %}
                    {% if ns['is_first'] %}if $id == {{ eid }}
                        {% if ns.update({'is_first': false}) %}{% endif %}
                    {% else %}
                    elif $id == {{ eid }}
                    {% endif %}
                    $imageID = {{ img_idx }}
                {% endfor %}
                else
                    {# Fallback to first available variation #}
                    $imageID = {{ var_map.values() | first | default(0) }}
                endif
                {% else %}
                [CommandListGetImageCords{{ image.id }}]
                $drawType = 0
                {% endif %}
            {% else %}
                {% set img_idx = img_map['static'].get(img_id_str, 0) %}
                [CommandListGetImageCords{{ image.id }}]
                $drawType = 1
                $imageID = {{ img_idx }}
            {% endif %}
            {% set _ = processed_ids['images'].append(image.id) %}
        {% endif %}
    {% endfor %}
{% endif %}
{% endmacro %}

{% macro popup_helpers_generate(mod_file,scene) %}
    {% for element in scene.rzm.elements %}
        {% if utils.has_attribute(element, 'hadPopup') and not element.is_helper and (element.value_link is defined and (element.value_link|length) > 0) %}

            {# ------------------ MASTER/SLAVE Init ------------------ #}
            {% set popup_elements_count = {'elements': [2]} %}
            {% set master_link = element.value_link[0] %}
            {% set master_name = master_link.value_name | default('') %}
            {% set target_variable_str = utils.format_var(master_name) %}

            {# Получаем Min и Max из UI. Приводим к int, так как popup работает с целыми шагами #}
            {% set val_min = master_link.value_min | default(0.0) | int %}
            {% set val_max = master_link.value_max | default(1.0) | int %}

            {# --- 1) Определение количества элементов --- #}
            {% if master_name.startswith('@') %}
                {# ЛОГИКА ДЛЯ TOGGLE (@) #}
                {% set target_toggle_name = master_name[1:] %}
                {% for toggle_def in scene.rzm.toggle_definitions or [] %}
                    {% if toggle_def.toggle_name == target_toggle_name %}
                        {% set _ = popup_elements_count['elements'].pop(0) %}
                        {% set _ = popup_elements_count['elements'].insert(0, toggle_def.toggle_length|int) %}
                    {% endif %}
                {% endfor %}
            {% else %}
                {# ЛОГИКА ДЛЯ ПЕРЕМЕННЫХ ($) ИЛИ ШЕЙПОВ (#) #}
                {# Считаем диапазон. Например: Min=1, Max=3. Итого: 1,2,3 -> (3 - 1) + 1 = 3 элемента. #}
                {# Если Max=1, Min=0 -> 2 элемента. #}
                {% set calc_count = val_max - val_min + 1 %}
                
                {# Защита от дурака: минимум 2 элемента #}
                {% if calc_count < 2 %}{% set calc_count = 2 %}{% endif %}

                {% set _ = popup_elements_count['elements'].pop(0) %}
                {% set _ = popup_elements_count['elements'].insert(0, calc_count) %}
            {% endif %}

[CommandListElement{{ element.element_name }}Popup]
local $popupShown
local $popupIconSize = 50
$popupShown = w33 * 2
if $popupShown > 1
    $popupShown = 1
endif
$id = 12
$drawType = 0
; Центрируем Popup относительно кнопки
$positionX = ($positionX + ($SizeX/2)) - ($popupIconSize * {{ popup_elements_count['elements'][0] }})/2
$positionY = $positionY + ($SizeY * 1.1 * ($popupShown))
$sizeX = $popupIconSize * {{ popup_elements_count['elements'][0] }}
if $popupShown < 0.8
    $sizeY = 0
else
    $sizeY = ($popupIconSize)  * ($popupShown) * 1.1
endif
$colorR = 0.0
$colorG = 0.0
$colorB = 0.0
$colorA = 0.55

$drawType = 0
y110 = 3
$PositionX = $positionX
$PositionY = $positionY
run = CustomShaderRCI2D_POPUP
run = CommandList{{ element.element_name }}PopupInteraction

[CommandList{{ element.element_name }}PopupInteraction]

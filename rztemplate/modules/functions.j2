{%macro ButtonNumbers()%}
[CommandListCoreFXRenderButtonNumbers]
if $rzmUIRenderSettings_ButtonNumbers == 1
	local $LocalPosX
	local $LocalPosY
	local $LocalSizeX
	local $LocalSizeY
	$LocalPosX = $positionX
	$LocalPosY = $positionY
	$LocalSizeX = $sizeX
	$LocalSizeY = $sizeY
	$drawType = 4
	$TexPosX = x24
	$TexPosY = 0

	$positionX = $LocalPosX + ($LocalSizeX * 0.75) - 4
	$positionY = $LocalPosY + ($LocalSizeY * 0.75)
	$sizeX = $LocalSizeX * 0.25
	$sizeY = $LocalSizeY * 0.25
	run = CommandListCoreFnAlignCenterX

	$colorR = $colorR + ($colorR * 3) + (0.1)
	$colorG = $colorG + ($colorG * 3) + (0.1)
	$colorB = $colorB + ($colorB * 3) + (0.1)
	$colorA = 1.0


	run = CustomShaderRCI2D

	$positionX = $LocalPosX
	$positionY = $LocalPosY
	$sizeX = $LocalSizeX
	$sizeY = $LocalSizeY
endif


$positionY = $positionY + $sizeY
[CommandListCoreFnFixAspectRatio]
if $screenW > $screenH
	$sizeX = $sizeX * ($screenH / $screenW)
else 
	$sizeY = $sizeY * ($screenW / $screenH)
endif


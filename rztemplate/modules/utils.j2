{# --- UTILS.J2 (WHITESPACE SAFE VERSION) --- #}

{% set CLASS_NAME_MAP = {
    0: 'CONTAINER',
    1: 'GRID_CONTAINER',
    2: 'ANCHOR',
    3: 'BUTTON',
    4: 'SLIDER',
    5: 'TEXT',
} %}

{% set CLASS_ID_MAP = {
    'CONTAINER': 0,
    'GRID_CONTAINER': 1,
    'ANCHOR': 2,
    'BUTTON': 3,
    'SLIDER': 4,
    'TEXT': 5,
    'VECTOR_BOX': 6
} %}

{% set CLASS_ATTRIBUTES = {
    'ANCHOR': ['isMovable'],
    'GRID_CONTAINER': ['isResizable'],
    'BUTTON': ['isClickable', 'isHoldable', 'hadPopup'],
    'SLIDER': ['isClickable', 'isHoldable']
} %}

{% set FN_MAP = {
    0: 'AlignCenterXY',
    1: 'AlignCenterX',
    2: 'AlignCenterY',
    3: 'AlignLeft',
    4: 'AlignRight',
    5: 'AlignBottom',
    6: 'AlignTop',
    7: 'FixAspectRatio',
} %}

{% set ALIGNMENT_MAP = {
    'BOTTOM_LEFT': 0,
    'BOTTOM_CENTER': 1,
    'BOTTOM_RIGHT': 2,
    'CENTER_LEFT': 3,
    'CENTER': 4,
    'CENTER_RIGHT': 5,
    'TOP_LEFT': 6,
    'TOP_CENTER': 7,
    'TOP_RIGHT': 8
} %}

{% set TEXT_ALIGN_MAP = {
    'LEFT': 0,
    'CENTER': 1,
    'RIGHT': 2,
    'FREE_LEFT': 3,
    'FREE_CENTER': 4,
    'FREE_RIGHT': 5
} %}

{% set FX_MAP = {
    'CommandListCoreFxBoxRound': 'BoxRound',
    'CommandListCoreFxBoxCircle': 'BoxCircle',
    'CommandListCoreFxGradient': 'Gradient',
    'CommandListCoreFxShadow': 'Shadow',
    'CommandListCoreFxBlur': 'Blur',
    'CommandListCoreFxOutline': 'Outline',
    'CommandListCoreFxHover': 'Hover',
    'CommandListCoreFxHover3D': 'Hover3D',
    'CommandListCoreFxGpuAnimRotate': 'GpuAnimRotate'
} %}

{# --- УМНЫЕ МАКРОСЫ (С ЗАЩИТОЙ ОТ ПРОБЕЛОВ) --- #}

{%- macro get_cls_id(element) -%}
    {{- CLASS_ID_MAP.get(get_cls(element)|trim, 0) -}}
{%- endmacro -%}

{%- macro get_cls(element) -%}
    {%- if element.elem_class is defined -%}
        {%- set raw = element.elem_class -%}
        {#- Разворачиваем список -#}
        {%- if raw is iterable and raw is not string -%}
            {%- set raw = raw[0] if raw|length > 0 else none -%}
        {%- endif -%}

        {#- Определяем тип -#}
        {%- if raw is number -%}
             {{- CLASS_NAME_MAP.get(raw|int, 'UNKNOWN') -}}
        {%- elif raw is string -%}
             {%- if raw.isdigit() -%}
                 {{- CLASS_NAME_MAP.get(raw|int, 'UNKNOWN') -}}
             {%- else -%}
                 {{- raw -}}
             {%- endif -%}
        {%- else -%}
             {{- raw|string -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro -%}

{%- macro has_attribute(element, attribute_name) -%}
    {%- set class_name = get_cls(element)|trim -%}
    {%- if class_name and attribute_name in CLASS_ATTRIBUTES.get(class_name, []) -%}
        true
    {%- endif -%}
{%- endmacro -%}

{%- macro has_any_attribute(element) -%}
    {%- set class_name = get_cls(element)|trim -%}
    {%- if class_name in CLASS_ATTRIBUTES -%}
        true
    {%- endif -%}
{%- endmacro -%}

{%- macro resolve_parent_min_max(element, scene, type='MAX') -%}
    {%- if element and element.value_link and element.value_link|length > 0 -%}
        {%- set first_link = element.value_link[0] -%}
        {%- set v_name = first_link.value_name | default('') -%}
        
        {# @ = Toggle (Project) #}
        {%- if v_name.startswith('@') -%}
            {%- if type == 'MIN' -%}
                0.0
            {%- else -%}
                {# Ищем длину тоггла в дефинициях сцены #}
                {%- set t_name = v_name.lstrip('@') -%}
                {%- set found_max = [1.0] -%}
                {%- if scene and scene.rzm and scene.rzm.toggle_definitions -%}
                    {%- for t in scene.rzm.toggle_definitions if t.toggle_name == t_name -%}
                        {%- set _ = found_max.pop() -%}
                        {%- set _ = found_max.append(t.toggle_length) -%}
                    {%- endfor -%}
                {%- endif -%}
                {{- found_max[0] -}}
            {%- endif -%}
        {%- else -%}
            {# Шейпы (#) и обычные значения ($) используют min/max диапазон линка #}
            {%- if type == 'MIN' -%}
                {{- first_link.value_min | default(0.0) -}}
            {%- else -%}
                {{- first_link.value_max | default(1.0) -}}
            {%- endif -%}
        {%- endif -%}
    {%- else -%}
        {{- '0.0' if type == 'MIN' else '1.0' -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro format_from_idiot(input_string) -%}
    {%- if input_string -%}
        {%- set forbidden = " !@#$%^&*()+-={}|[]\\:\";'<>?,./" -%}
        {%- set result = {'v': input_string} -%}
        {%- for char in forbidden -%}
            {%- if char in result.v -%}
                {%- if result.update({'v': result.v | replace(char, '_')}) -%}{%- endif -%}
            {%- endif -%}
        {%- endfor -%}
        {{- result.v -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro format_var(input_string, element=none, scene=none) -%}
    {%- if input_string -%}
        {%- set result = input_string -%}
        
        {# 1. Продвинутый режим: подставляем данные родителя #}
        {%- if element and element.value_link -%}
            {%- set p_val = get_first_value_link_var(element)|trim -%}
            {%- set p_min = resolve_parent_min_max(element, scene, 'MIN')|trim -%}
            {%- set p_max = resolve_parent_min_max(element, scene, 'MAX')|trim -%}
            {%- set p_name = element.element_name | default('') | string -%}
            {%- set p_text = element.text_id | default('') | string -%}
            {%- set p_hover = element.hover_text_id | default('') | string -%}
            {%- set p_color_r = element.color[0]|string if element.color else '1.0' -%}
            {%- set p_color_g = element.color[1]|string if element.color else '1.0' -%}
            {%- set p_color_b = element.color[2]|string if element.color else '1.0' -%}
            {%- set p_color_a = element.color[3]|string if element.color else '1.0' -%}
            {%- set p_color = p_color_r ~ ',' ~ p_color_g ~ ',' ~ p_color_b ~ ',' ~ p_color_a -%}
            
            {%- set result = result 
                | replace('~ParentValueMin', p_min) | replace('~PVMin', p_min) | replace('~PVmin', p_min) | replace('~pvmin', p_min) | replace('~PVMIN', p_min)
                | replace('~ParentValueMax', p_max) | replace('~PVMax', p_max) | replace('~PVmax', p_max) | replace('~pvmax', p_max) | replace('~PVMAX', p_max)
                | replace('~ParentValue', p_val)    | replace('~PV', p_val)    | replace('~pv', p_val) 
                | replace('~PName', p_name) | replace('~Pname', p_name) | replace('~PN', p_name) | replace('~pn', p_name)
                | replace('~PText', p_text) | replace('~Ptext', p_text) | replace('~PT', p_text) | replace('~pt', p_text)
                | replace('~PHover', p_hover) | replace('~Phover', p_hover) | replace('~PH', p_hover) | replace('~ph', p_hover)
                | replace('~PColor.r', p_color_r) | replace('~PColor.R', p_color_r) | replace('~PC.r', p_color_r) | replace('~PC.R', p_color_r)
                | replace('~PColor.g', p_color_g) | replace('~PColor.G', p_color_g) | replace('~PC.g', p_color_g) | replace('~PC.G', p_color_g)
                | replace('~PColor.b', p_color_b) | replace('~PColor.B', p_color_b) | replace('~PC.b', p_color_b) | replace('~PC.B', p_color_b)
                | replace('~PColor.a', p_color_a) | replace('~PColor.A', p_color_a) | replace('~PC.a', p_color_a) | replace('~PC.A', p_color_a)
                | replace('~PColor', p_color) | replace('~Pcolor', p_color) | replace('~PC', p_color) | replace('~pc', p_color)
            -%}
        {%- endif -%}
        
        {# 2. Базовый режим: удаляем спецсимволы и заменяем пробелы на подчеркивания (коллапсим кратные пробелы) #}
        {{- result.lstrip('$@#~').split() | join('_') -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro normalize_all_vars(input_string, element=none, scene=none) -%}
    {%- if input_string -%}
        {%- set result = input_string | string -%}
        
        {# 1. Продвинутый режим: подставляем имя (или value_link) элемента, если он передан #}
        {%- if element and element.value_link -%}
            {%- set p_val = '$' ~ get_first_value_link_var(element)|trim -%}
            {%- set p_min = resolve_parent_min_max(element, scene, 'MIN')|trim -%}
            {%- set p_max = resolve_parent_min_max(element, scene, 'MAX')|trim -%}
            {%- set p_name = element.element_name | default('') | string -%}
            {%- set p_text = element.text_id | default('') | string -%}
            {%- set p_hover = element.hover_text_id | default('') | string -%}
            {%- set p_color_r = element.color[0]|string if element.color else '1.0' -%}
            {%- set p_color_g = element.color[1]|string if element.color else '1.0' -%}
            {%- set p_color_b = element.color[2]|string if element.color else '1.0' -%}
            {%- set p_color_a = element.color[3]|string if element.color else '1.0' -%}
            {%- set p_color = p_color_r ~ ',' ~ p_color_g ~ ',' ~ p_color_b ~ ',' ~ p_color_a -%}
            {%- set result = result | replace('~ParentValueMin', p_min) | replace('~PVMin', p_min) | replace('~PVmin', p_min) | replace('~pvmin', p_min) | replace('~PVMIN', p_min)
                                    | replace('~ParentValueMax', p_max) | replace('~PVMax', p_max) | replace('~PVmax', p_max) | replace('~pvmax', p_max) | replace('~PVMAX', p_max)
                                    | replace('~ParentValue', p_val)    | replace('~PV', p_val)    | replace('~pv', p_val) 
                                    | replace('~PName', p_name) | replace('~Pname', p_name) | replace('~PN', p_name) | replace('~pn', p_name)
                                    | replace('~PText', p_text) | replace('~Ptext', p_text) | replace('~PT', p_text) | replace('~pt', p_text)
                                    | replace('~PHover', p_hover) | replace('~Phover', p_hover) | replace('~PH', p_hover) | replace('~ph', p_hover)
                                    | replace('~PColor.r', p_color_r) | replace('~PColor.R', p_color_r) | replace('~PC.r', p_color_r) | replace('~PC.R', p_color_r)
                                    | replace('~PColor.g', p_color_g) | replace('~PColor.G', p_color_g) | replace('~PC.g', p_color_g) | replace('~PC.G', p_color_g)
                                    | replace('~PColor.b', p_color_b) | replace('~PColor.B', p_color_b) | replace('~PC.b', p_color_b) | replace('~PC.B', p_color_b)
                                    | replace('~PColor.a', p_color_a) | replace('~PColor.A', p_color_a) | replace('~PC.a', p_color_a) | replace('~PC.A', p_color_a)
                                    | replace('~PColor', p_color) | replace('~Pcolor', p_color) | replace('~PC', p_color) | replace('~pc', p_color) -%}
        {%- endif -%}
        
        {# 2. Базовый режим: заменяем префиксы @, #, ~ на стандартный $ и исправляем возможные дубликаты $$ #}
        {%- set result = result | replace('@', '$') | replace('#', '$') | replace('~', '$') | replace('$$', '$') | replace('$$', '$') -%}
        
        {{- result -}}
    {%- endif -%}
{%- endmacro -%}

{% macro get_first_value_link_var(element) -%}
    {%- if element.value_link and element.value_link|length > 0 -%}
        {%- set first_link = element.value_link[0] -%}
        {# Проверяем, если это строка (уже проброшенная), отдаем её. Если объект — берем свойство #}
        {%- if first_link is string -%}
            {{- first_link.lstrip('$@#~') -}}
        {%- else -%}
            {{- first_link.value_name.lstrip('$@#~') -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro %}

{%- macro get_var_name(name, scene, auto_x=true) -%}
    {%- if not name -%}{%- else -%}
        {%- set base = name.lstrip('$@#') -%}
        {%- set found = {'type': 'FLOAT'} -%}
        {%- if scene.rzm and scene.rzm.rzm_values -%}
            {%- for v in scene.rzm.rzm_values if v.value_name.lstrip('$@#') == base -%}
                {%- if found.update({'type': v.value_type}) -%}{%- endif -%}
            {%- endfor -%}
        {%- endif -%}
        {%- if found.type == 'VECTOR' and auto_x -%}
            {{- base ~ '_X' -}}
        {%- else -%}
            {{- base -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro -%}

{#
    resolve_meta_var(text_id, scene)
    ─────────────────────────────────────────────────────────────────────────────
    Resolves system meta-variables (~prefix) inside text_id strings for export.
    This is the INI-side counterpart to the Qt viewport preview in read.py.
    
    Supported variables (~ prefix, case-insensitive):
        ~author_name      → meta_data.author_name
        ~character_name   → meta_data.character_name
        ~outfit_name      → meta_data.outfit_name
        ~version_num      → meta_data.version_num
        ~mod_name         → export_settings.mod_name
        ~game_name        → game.name
        ~menu_keybind     → meta_data.menu_keybind
        ~requirements     → meta_data.requirements
        ~community_respect → meta_data.community_respect
        ~description      → meta_data.description
    
    If the entire text_id is a single ~var, returns just the resolved value.
    If no ~ is present, returns the input unchanged (zero overhead).
#}
{%- macro resolve_meta_var(text_id, scene, element=none, parent_override=none) -%}
    {%- if "~" not in text_id -%}
        {{- text_id -}}
    {%- else -%}
        {%- set meta = scene.rzm.meta_data -%}
        {%- set author = scene.rzm.meta_data.author_name if scene.rzm.meta_data and scene.rzm.meta_data.author_name else "UNKNOWN" -%}
        
        {%- set vars_map = {
            '~author_name':       author,
            '~character_name':    meta.character_name,
            '~outfit_name':       meta.outfit_name,
            '~version_num':       meta.version_num,
            '~mod_name':          meta.character_name ~ " (" ~ meta.outfit_name ~ ")",
            '~game_name':         scene.rzm.game.selection,
            '~menu_keybind':      meta.menu_keybind,
            '~requirements':      meta.requirements,
            '~community_respect': meta.community_respect,
            '~description':       meta.description
        } -%}
        
        {%- if element or parent_override -%}
            {%- set ns = {'parent': parent_override} -%}
            {%- if not ns.parent -%}
                {%- for el in scene.rzm.elements -%}
                    {%- if el.id == element.parent_id -%}
                        {%- set _ = ns.update({'parent': el}) -%}
                    {%- else -%}
                        {%- for h in el.helper_ids | default([]) if h.helper_id == element.id -%}
                            {%- set _ = ns.update({'parent': el}) -%}
                        {%- endfor -%}
                        {%- for p in el.preset_ids | default([]) if p.preset_id == element.id -%}
                            {%- set _ = ns.update({'parent': el}) -%}
                        {%- endfor -%}
                        {%- for u in el.underlayer_preset_ids | default([]) if u.preset_id == element.id -%}
                            {%- set _ = ns.update({'parent': el}) -%}
                        {%- endfor -%}
                    {%- endif -%}
                {%- endfor -%}
            {%- endif -%}
            {%- set parent = ns.parent if ns.parent else element -%}
            {%- if parent -%}
                {%- set p_name = parent.element_name | default('') | string -%}
                {%- set p_text = parent.text_id | default('') | string -%}
                {%- set p_hover = parent.hover_text_id | default('') | string -%}
                {%- set p_color_r = parent.color[0]|string if parent.color else '1.0' -%}
                {%- set p_color_g = parent.color[1]|string if parent.color else '1.0' -%}
                {%- set p_color_b = parent.color[2]|string if parent.color else '1.0' -%}
                {%- set p_color_a = parent.color[3]|string if parent.color else '1.0' -%}
                {%- set p_color = p_color_r ~ ',' ~ p_color_g ~ ',' ~ p_color_b ~ ',' ~ p_color_a -%}
                
                {%- set _ = vars_map.update({
                    '~PColor.r': p_color_r, '~PColor.R': p_color_r, '~PC.r': p_color_r, '~PC.R': p_color_r,
                    '~PColor.g': p_color_g, '~PColor.G': p_color_g, '~PC.g': p_color_g, '~PC.G': p_color_g,
                    '~PColor.b': p_color_b, '~PColor.B': p_color_b, '~PC.b': p_color_b, '~PC.B': p_color_b,
                    '~PColor.a': p_color_a, '~PColor.A': p_color_a, '~PC.a': p_color_a, '~PC.A': p_color_a,
                    '~PColor': p_color, '~Pcolor': p_color, '~PC': p_color, '~pc': p_color,
                    '~PName': p_name, '~Pname': p_name, '~PN': p_name, '~pn': p_name,
                    '~PText': p_text, '~Ptext': p_text, '~PT': p_text, '~pt': p_text,
                    '~PHover': p_hover, '~Phover': p_hover, '~PH': p_hover, '~ph': p_hover
                }) -%}
            {%- endif -%}
        {%- endif -%}
        
        {%- set res = {'v': text_id} -%}
        {%- for var_key, var_val in vars_map.items() -%}
            {%- if var_key in res.v -%}
                {%- set _ = res.update({'v': res.v | replace(var_key, var_val | default('') | string)}) -%}
            {%- endif -%}
        {%- endfor -%}
        {{- res.v -}}
    {%- endif -%}
{%- endmacro -%}


{%- macro clean_resource(input_string) -%}
{%- if input_string -%}
{%- if input_string[:8]|lower == 'resource' -%}
{{- input_string[8:] -}}
{%- else -%}
{{- input_string -}}
{%- endif -%}
{%- endif -%}
{%- endmacro -%}

{%- macro clean_ws(max_empty=1) -%}
    {%- set raw_content = caller() -%}
    {%- set lines = raw_content.split('\n') -%}
    {%- set ns = {'count': 0} -%}
    {%- for line in lines -%}
        {%- if line.strip()|length == 0 -%}
            {%- if ns.update({'count': ns.count + 1}) -%}{%- endif -%}
            {%- if ns.count <= max_empty -%}
                {{- '\n' -}}
            {%- endif -%}
        {%- else -%}
            {%- if ns.update({'count': 0}) -%}{%- endif -%}
            {{- line ~ '\n' -}}
        {%- endif -%}
    {%- endfor -%}
{%- endmacro -%}

{% macro deduplicate(text)%}
{% set string = text %}
{% set string_array = [] %}
{# 1. Разбиваем строку на массив по строкам #}
{% set string_array = string.split('\n') %}

{% set unique_strings = [] %}

{# 2. Удаляем дубликаты #}
{% for line in string_array %}
    {% if line not in unique_strings %}
        {% set _ = unique_strings.append(line) %}
    {% endif %}
{% endfor %}

{% for line in unique_strings %}
{{ line }}
{% endfor %}
{%endmacro%}

{% macro merge_strings(a, b) -%}
{{ a ~ '\n' ~ b }}
{%- endmacro %}
{%- macro get_img_res(image_id, scene) -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for img in scene.rzm.images if img.id == image_id -%}
            {{- img -}}
        {%- endfor -%}
    {%- endif -%}
{%- endmacro -%}

{%- macro get_svg_config_key(element, image_id, scene) -%}
    {%- set img = none -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for i in scene.rzm.images if i.id == image_id -%}{%- set img = i -%}{%- endfor -%}
    {%- endif -%}
    
    {%- if img and img.source_type == 'VECTOR' -%}
        {%- set scale = element.svg_scale | round(2) -%}
        {%- set off_x = element.svg_offset[0] | round(2) -%}
        {%- set off_y = element.svg_offset[1] | round(2) -%}
        {%- set color_key = "ORIG" -%}
        {%- if not img.svg_preserve_color -%}
            {%- set r = (element.color[0] * 255) | int -%}
            {%- set g = (element.color[1] * 255) | int -%}
            {%- set b = (element.color[2] * 255) | int -%}
            {%- set color_key = "%02x%02x%02x" | format(r, g, b) -%}
        {%- endif -%}
        {{- "SVG_" ~ image_id ~ "_" ~ scale ~ "_" ~ off_x ~ "_" ~ off_y ~ "_" ~ color_key -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro get_image_cords_name(element, image_id, scene) -%}
    {%- set img = none -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for i in scene.rzm.images if i.id == image_id -%}{%- set img = i -%}{%- endfor -%}
    {%- endif -%}
    
    {%- if img and img.source_type == 'VECTOR' -%}
        {{- "GetImageCords_" ~ get_svg_config_key(element, image_id, scene) -}}
    {%- else -%}
        {{- "GetImageCords" ~ image_id -}}
    {%- endif -%}
{%- endmacro -%}

{% macro tier_tags(entity, scene=none) -%}
    {%- set tags = [] -%}
    {%- set all_tiers = scene.rzm.addons.tier_definitions if (scene and scene.rzm and scene.rzm.addons) else [] -%}
    {%- for t_ref in entity.export_tiers -%}
        {%- set current = {'id': t_ref.tier_id, 'seen': []} -%}
        {%- for i in range(5) -%}
            {%- if current.id and current.id not in current.seen -%}
                {%- set _ = current.seen.append(current.id) -%}
                {%- set _ = tags.append("[" ~ current.id ~ "]") -%}
                {%- set next_id = {'v': none} -%}
                {%- for d in all_tiers if d.tier_id == current.id -%}
                    {%- if d.parent_tier_id -%}{%- set _ = next_id.update({'v': d.parent_tier_id}) -%}{%- endif -%}
                {%- endfor -%}
                {%- set _ = current.update({'id': next_id.v}) -%}
            {%- endif -%}
        {%- endfor -%}
    {%- endfor -%}
    {{- tags | unique | join(' ') -}}
{%- endmacro %}

{% macro tier_tags_mesh(component, scene) -%}
    {%- set name = component.fullname | default(component.name) | default(component) -%}
    {%- set obj = none -%}
    {%- if name is string -%}
        {%- set obj = scene.objects.get(name) -%}
    {%- else -%}
        {%- set obj = component -%}
    {%- endif -%}
    {%- if obj and obj.rzm_tier_list -%}
        {%- set tags = [] -%}
        {%- set all_tiers = scene.rzm.addons.tier_definitions if (scene and scene.rzm and scene.rzm.addons) else [] -%}
        {%- for t_ref in obj.rzm_tier_list -%}
            {%- set current = {'id': t_ref.tier_id, 'seen': []} -%}
            {%- for i in range(5) -%}
                {%- if current.id and current.id not in current.seen -%}
                    {%- set _ = current.seen.append(current.id) -%}
                    {%- set _ = tags.append("[" ~ current.id ~ "]") -%}
                    {%- set next_id = {'v': none} -%}
                    {%- for d in all_tiers if d.tier_id == current.id -%}
                        {%- if d.parent_tier_id -%}{%- set _ = next_id.update({'v': d.parent_tier_id}) -%}{%- endif -%}
                    {%- endfor -%}
                    {%- set _ = current.update({'id': next_id.v}) -%}
                {%- endif -%}
            {%- endfor -%}
        {%- endfor -%}
        {{- tags | unique | join(' ') -}}
    {%- endif -%}
{%- endmacro %}


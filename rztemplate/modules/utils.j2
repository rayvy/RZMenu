{# --- UTILS.J2 (WHITESPACE SAFE VERSION) --- #}

{% set CLASS_NAME_MAP = {
    0: 'CONTAINER',
    1: 'GRID_CONTAINER',
    2: 'ANCHOR',
    3: 'BUTTON',
    4: 'SLIDER',
    5: 'TEXT',
} %}

{% set CLASS_ATTRIBUTES = {
    'ANCHOR': ['isMovable'],
    'GRID_CONTAINER': ['isResizable'],
    'BUTTON': ['isClickable', 'isHoldable', 'hadPopup'],
    'SLIDER': ['isClickable', 'isHoldable']
} %}

{% set FN_MAP = {
    0: 'AlignCenterXY',
    1: 'AlignCenterX',
    2: 'AlignCenterY',
    3: 'AlignLeft',
    4: 'AlignRight',
    5: 'AlignBottom',
    6: 'AlignTop',
    7: 'FixAspectRatio',
} %}

{% set ALIGNMENT_MAP = {
    'BOTTOM_LEFT': 0,
    'BOTTOM_CENTER': 1,
    'BOTTOM_RIGHT': 2,
    'CENTER_LEFT': 3,
    'CENTER': 4,
    'CENTER_RIGHT': 5,
    'TOP_LEFT': 6,
    'TOP_CENTER': 7,
    'TOP_RIGHT': 8
} %}

{% set FX_MAP = {
    'CommandListCoreFxBoxRound': 'BoxRound',
    'CommandListCoreFxBoxCircle': 'BoxCircle',
    'CommandListCoreFxGradient': 'Gradient',
    'CommandListCoreFxShadow': 'Shadow',
    'CommandListCoreFxBlur': 'Blur',
    'CommandListCoreFxOutline': 'Outline',
    'CommandListCoreFxHover': 'Hover',
    'CommandListCoreFxHover3D': 'Hover3D',
    'CommandListCoreFxGpuAnimRotate': 'GpuAnimRotate'
} %}

{# --- УМНЫЕ МАКРОСЫ (С ЗАЩИТОЙ ОТ ПРОБЕЛОВ) --- #}

{%- macro get_cls(element) -%}
    {%- if element.elem_class is defined -%}
        {%- set raw = element.elem_class -%}
        {#- Разворачиваем список -#}
        {%- if raw is iterable and raw is not string -%}
            {%- set raw = raw[0] if raw|length > 0 else none -%}
        {%- endif -%}

        {#- Определяем тип -#}
        {%- if raw is number -%}
             {{- CLASS_NAME_MAP.get(raw|int, 'UNKNOWN') -}}
        {%- elif raw is string -%}
             {%- if raw.isdigit() -%}
                 {{- CLASS_NAME_MAP.get(raw|int, 'UNKNOWN') -}}
             {%- else -%}
                 {{- raw -}}
             {%- endif -%}
        {%- else -%}
             {{- raw|string -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro -%}

{%- macro has_attribute(element, attribute_name) -%}
    {%- set class_name = get_cls(element)|trim -%}
    {%- if class_name and attribute_name in CLASS_ATTRIBUTES.get(class_name, []) -%}
        true
    {%- endif -%}
{%- endmacro -%}

{%- macro has_any_attribute(element) -%}
    {%- set class_name = get_cls(element)|trim -%}
    {%- if class_name in CLASS_ATTRIBUTES -%}
        true
    {%- endif -%}
{%- endmacro -%}

{%- macro resolve_parent_min_max(element, scene, type='MAX') -%}
    {%- if element and element.value_link and element.value_link|length > 0 -%}
        {%- set first_link = element.value_link[0] -%}
        {%- set v_name = first_link.value_name | default('') -%}
        
        {# @ = Toggle (Project) #}
        {%- if v_name.startswith('@') -%}
            {%- if type == 'MIN' -%}
                0.0
            {%- else -%}
                {# Ищем длину тоггла в дефинициях сцены #}
                {%- set t_name = v_name.lstrip('@') -%}
                {%- set found_max = [1.0] -%}
                {%- if scene and scene.rzm and scene.rzm.toggle_definitions -%}
                    {%- for t in scene.rzm.toggle_definitions if t.toggle_name == t_name -%}
                        {%- set _ = found_max.pop() -%}
                        {%- set _ = found_max.append(t.toggle_length) -%}
                    {%- endfor -%}
                {%- endif -%}
                {{- found_max[0] -}}
            {%- endif -%}
        {%- else -%}
            {# Шейпы (#) и обычные значения ($) используют min/max диапазон линка #}
            {%- if type == 'MIN' -%}
                {{- first_link.value_min | default(0.0) -}}
            {%- else -%}
                {{- first_link.value_max | default(1.0) -}}
            {%- endif -%}
        {%- endif -%}
    {%- else -%}
        {{- '0.0' if type == 'MIN' else '1.0' -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro format_var(input_string, element=none, scene=none) -%}
    {%- if input_string -%}
        {%- set result = input_string -%}
        
        {# 1. Продвинутый режим: подставляем имя (или value_link) элемента, если он передан #}
        {%- if element and element.value_link -%}
            {%- set p_val = get_first_value_link_var(element)|trim -%}
            {%- set p_min = resolve_parent_min_max(element, scene, 'MIN')|trim -%}
            {%- set p_max = resolve_parent_min_max(element, scene, 'MAX')|trim -%}
            {%- set result = result | replace('~ParentValueMin', p_min) | replace('~PVMin', p_min) | replace('~PVmin', p_min) | replace('~pvmin', p_min) | replace('~PVMIN', p_min)
                                    | replace('~ParentValueMax', p_max) | replace('~PVMax', p_max) | replace('~PVmax', p_max) | replace('~pvmax', p_max) | replace('~PVMAX', p_max)
                                    | replace('~ParentValue', p_val)    | replace('~PV', p_val)    | replace('~pv', p_val) -%}
        {%- endif -%}
        
        {# 2. Базовый режим: удаляем спецсимволы в начале строки #}
        {{- result.lstrip('$@#~') -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro normalize_all_vars(input_string, element=none, scene=none) -%}
    {%- if input_string -%}
        {%- set result = input_string | string -%}
        
        {# 1. Продвинутый режим: подставляем имя (или value_link) элемента, если он передан #}
        {%- if element and element.value_link -%}
            {%- set p_val = '$' ~ get_first_value_link_var(element)|trim -%}
            {%- set p_min = resolve_parent_min_max(element, scene, 'MIN')|trim -%}
            {%- set p_max = resolve_parent_min_max(element, scene, 'MAX')|trim -%}
            {%- set result = result | replace('~ParentValueMin', p_min) | replace('~PVMin', p_min) | replace('~PVmin', p_min) | replace('~pvmin', p_min) | replace('~PVMIN', p_min)
                                    | replace('~ParentValueMax', p_max) | replace('~PVMax', p_max) | replace('~PVmax', p_max) | replace('~pvmax', p_max) | replace('~PVMAX', p_max)
                                    | replace('~ParentValue', p_val)    | replace('~PV', p_val)    | replace('~pv', p_val) -%}
        {%- endif -%}
        
        {# 2. Базовый режим: заменяем префиксы @, #, ~ на стандартный $ и исправляем возможные дубликаты $$ #}
        {%- set result = result | replace('@', '$') | replace('#', '$') | replace('~', '$') | replace('$$', '$') | replace('$$', '$') -%}
        
        {{- result -}}
    {%- endif -%}
{%- endmacro -%}

{% macro get_first_value_link_var(element) -%}
    {%- if element.value_link and element.value_link|length > 0 -%}
        {%- set first_link = element.value_link[0] -%}
        {# Проверяем, если это строка (уже проброшенная), отдаем её. Если объект — берем свойство #}
        {%- if first_link is string -%}
            {{- first_link.lstrip('$@#~') -}}
        {%- else -%}
            {{- first_link.value_name.lstrip('$@#~') -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro %}

{%- macro get_var_name(name, scene, auto_x=true) -%}
    {%- if not name -%}{%- else -%}
        {%- set base = name.lstrip('$@#') -%}
        {%- set found = {'type': 'FLOAT'} -%}
        {%- if scene.rzm and scene.rzm.rzm_values -%}
            {%- for v in scene.rzm.rzm_values if v.value_name.lstrip('$@#') == base -%}
                {%- if found.update({'type': v.value_type}) -%}{%- endif -%}
            {%- endfor -%}
        {%- endif -%}
        {%- if found.type == 'VECTOR' and auto_x -%}
            {{- base ~ '_X' -}}
        {%- else -%}
            {{- base -}}
        {%- endif -%}
    {%- endif -%}
{%- endmacro -%}

{#
    resolve_meta_var(text_id, scene)
    ─────────────────────────────────────────────────────────────────────────────
    Resolves system meta-variables (~prefix) inside text_id strings for export.
    This is the INI-side counterpart to the Qt viewport preview in read.py.
    
    Supported variables (~ prefix, case-insensitive):
        ~author_name      → meta_data.author_name
        ~character_name   → meta_data.character_name
        ~outfit_name      → meta_data.outfit_name
        ~version_num      → meta_data.version_num
        ~mod_name         → export_settings.mod_name
        ~game_name        → game.name
        ~menu_keybind     → meta_data.menu_keybind
        ~requirements     → meta_data.requirements
        ~community_respect → meta_data.community_respect
        ~description      → meta_data.description
    
    If the entire text_id is a single ~var, returns just the resolved value.
    If no ~ is present, returns the input unchanged (zero overhead).
#}
{%- macro resolve_meta_var(text_id, scene) -%}
    {%- if text_id and '~' in text_id -%}
        {%- set meta = scene.rzm.meta_data -%}
        {%- set exp  = scene.rzm.export_settings -%}
        {%- set game = scene.rzm.game -%}
        {%- set SYS_VARS = {
            '~author_name':       meta.author_name,
            '~character_name':    meta.character_name,
            '~outfit_name':       meta.outfit_name,
            '~version_num':       meta.version_num,
            '~mod_name':          exp.mod_name,
            '~game_name':         game.name,
            '~menu_keybind':      meta.menu_keybind,
            '~requirements':      meta.requirements,
            '~community_respect': meta.community_respect,
            '~description':       meta.description
        } -%}
        {%- set result = {'v': text_id} -%}
        {%- for var_key, var_val in SYS_VARS.items() -%}
            {%- if var_key in result.v -%}
                {%- if result.update({'v': result.v | replace(var_key, var_val | default('') | string)}) -%}{%- endif -%}
            {%- endif -%}
        {%- endfor -%}
        {{- result.v -}}
    {%- else -%}
        {{- text_id -}}
    {%- endif -%}
{%- endmacro -%}


{%- macro clean_resource(input_string) -%}
{%- if input_string -%}
{%- if input_string[:8]|lower == 'resource' -%}
{{- input_string[8:] -}}
{%- else -%}
{{- input_string -}}
{%- endif -%}
{%- endif -%}
{%- endmacro -%}

{%- macro clean_ws(max_empty=1) -%}
    {%- set raw_content = caller() -%}
    {%- set lines = raw_content.split('\n') -%}
    {%- set ns = {'count': 0} -%}
    {%- for line in lines -%}
        {%- if line.strip()|length == 0 -%}
            {%- if ns.update({'count': ns.count + 1}) -%}{%- endif -%}
            {%- if ns.count <= max_empty -%}
                {{- '\n' -}}
            {%- endif -%}
        {%- else -%}
            {%- if ns.update({'count': 0}) -%}{%- endif -%}
            {{- line ~ '\n' -}}
        {%- endif -%}
    {%- endfor -%}
{%- endmacro -%}

{% macro deduplicate(text)%}
{% set string = text %}
{% set string_array = [] %}
{# 1. Разбиваем строку на массив по строкам #}
{% set string_array = string.split('\n') %}

{% set unique_strings = [] %}

{# 2. Удаляем дубликаты #}
{% for line in string_array %}
    {% if line not in unique_strings %}
        {% set _ = unique_strings.append(line) %}
    {% endif %}
{% endfor %}

{% for line in unique_strings %}
{{ line }}
{% endfor %}
{%endmacro%}

{% macro merge_strings(a, b) -%}
{{ a ~ '\n' ~ b }}
{%- endmacro %}
{%- macro get_img_res(image_id, scene) -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for img in scene.rzm.images if img.id == image_id -%}
            {{- img -}}
        {%- endfor -%}
    {%- endif -%}
{%- endmacro -%}

{%- macro get_svg_config_key(element, image_id, scene) -%}
    {%- set img = none -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for i in scene.rzm.images if i.id == image_id -%}{%- set img = i -%}{%- endfor -%}
    {%- endif -%}
    
    {%- if img and img.source_type == 'VECTOR' -%}
        {%- set scale = element.svg_scale | round(2) -%}
        {%- set off_x = element.svg_offset[0] | round(2) -%}
        {%- set off_y = element.svg_offset[1] | round(2) -%}
        {%- set color_key = "ORIG" -%}
        {%- if not img.svg_preserve_color -%}
            {%- set r = (element.color[0] * 255) | int -%}
            {%- set g = (element.color[1] * 255) | int -%}
            {%- set b = (element.color[2] * 255) | int -%}
            {%- set color_key = "%02x%02x%02x" | format(r, g, b) -%}
        {%- endif -%}
        {{- "SVG_" ~ image_id ~ "_" ~ scale ~ "_" ~ off_x ~ "_" ~ off_y ~ "_" ~ color_key -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro get_image_cords_name(element, image_id, scene) -%}
    {%- set img = none -%}
    {%- if scene.rzm and scene.rzm.images -%}
        {%- for i in scene.rzm.images if i.id == image_id -%}{%- set img = i -%}{%- endfor -%}
    {%- endif -%}
    
    {%- if img and img.source_type == 'VECTOR' -%}
        {{- "GetImageCords_" ~ get_svg_config_key(element, image_id, scene) -}}
    {%- else -%}
        {{- "GetImageCords" ~ image_id -}}
    {%- endif -%}
{%- endmacro -%}

{% macro tier_tags(entity) -%}
    {%- set tags = [] -%}
    {%- for t in entity.export_tiers -%}
        {%- set _ = tags.append("[" ~ t.tier_id ~ "]") -%}
    {%- endfor -%}
    {{- tags | join(' ') -}}
{%- endmacro %}

{% macro tier_tags_mesh(component, scene) -%}
    {%- set name = component.fullname | default(component.name) | default(component) -%}
    {%- set obj = none -%}
    {%- if name is string -%}
        {%- set obj = scene.objects.get(name) -%}
    {%- else -%}
        {%- set obj = component -%}
    {%- endif -%}
    {%- if obj and obj.rzm_tier_list -%}
        {%- set tags = [] -%}
        {%- for t in obj.rzm_tier_list -%}
            {%- set _ = tags.append("[" ~ t.tier_id ~ "]") -%}
        {%- endfor -%}
        {{- tags | join(' ') -}}
    {%- endif -%}
{%- endmacro %}

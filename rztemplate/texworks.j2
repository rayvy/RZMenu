{% import "modules/utils.j2" as utils with context %}
{% set TW_ZZMI_SLOT_MAP = {
    'diffuse': 'Diffuse',
    'd': 'Diffuse',
    'normal': 'NormalMap',
    'normalmap': 'NormalMap',
    'normal map': 'NormalMap',
    'n': 'NormalMap',
    'light': 'LightMap',
    'lightmap': 'LightMap',
    'light map': 'LightMap',
    'l': 'LightMap',
    'material': 'MaterialMap',
    'materialmap': 'MaterialMap',
    'material map': 'MaterialMap',
    'm': 'MaterialMap',
    'glowgradient': 'GlowGradient',
    'glow gradient': 'GlowGradient',
    'glowmap': 'GlowMap',
    'glow map': 'GlowMap',
    'glowmap2': 'GlowMap2',
    'glow map2': 'GlowMap2',
    'glow map 2': 'GlowMap2',
    'glowmap3': 'GlowMap3',
    'glow map3': 'GlowMap3',
    'glow map 3': 'GlowMap3',
    'wenginefx': 'WengineFx',
    'wengine fx': 'WengineFx',
    'wenginefx2': 'WengineFx2',
    'wengine fx2': 'WengineFx2',
    'wengine fx 2': 'WengineFx2',
    'wenginefx3': 'WengineFx3',
    'wengine fx3': 'WengineFx3',
    'wengine fx 3': 'WengineFx3',
} %}

{% macro generate_texworks(mod_file, scene) %}
{% set rzm = scene.rzm %}


; =======================================================================================
;                                     TEXWORKS CORE (v3.5.6)
; =======================================================================================
[Constants]
global $x43val
global $y43val
global $z43val
global $w43val
global $TWInitialised = 0

[CommandListTexWorks.SaveTexWorksVALS]
$x43val = x43
$y43val = y43
$z43val = z43
$w43val = w43
x43 = 0.0
y43 = 0.0
z43 = 0.0
w43 = 0.0

[CommandListTexWorks.RestoreTexWorksVALS]
x43 = $x43val
y43 = $y43val
z43 = $z43val
w43 = $w43val

; --- 1. GLOBAL RESOURCES ---
{% for res in rzm.tw_resources %}
[Resource{{ utils.clean_resource(res.name) }}]
{% if res.type == 'ON_DISK' %}
filename = Textures\{{ res.path.split('\\')[-1] if '.' in res.path.split('\\')[-1] else res.path.split('\\')[-1] ~ '.dds' }}
{% elif res.type == 'VIRTUAL' %}
type = RWTexture2D
width = {{ res.resolution[0] }}
height = {{ res.resolution[1] }}
format = {{ res.format }}
array = 1
msaa = 1
mips = 1
{% endif %}
{% endfor %}

; --- 2. GLOBAL OVERRIDES (Atlas Protection) ---
{% for over in rzm.tw_overrides %}
[TextureOverride{{ over.name }}]
hash = {{ over.hash }}
{% if over.override_mode == 'IB_DIRECT' %}
if $TWInitialised == 1
{% if over.bindings|length > 0 %}
{% set preset_bindings = over.bindings | rejectattr('custom_target') | list %}
{% for binding in over.bindings %}
{% set tw_slot = (binding.tex_type or 'Diffuse')|trim %}
{% set tw_slot_l = tw_slot|lower %}
{% if binding.custom_target %}
{{ tw_slot }} = ref Resource{{ utils.clean_resource(binding.resource_name) }}
{% else %}
Resource\ZZMI\{{ TW_ZZMI_SLOT_MAP.get(tw_slot_l, tw_slot) }} = ref Resource{{ utils.clean_resource(binding.resource_name) }}
{% endif %}
{% endfor %}
{% if preset_bindings|length > 0 %}
run = CommandList\ZZMI\SetTextures
{% endif %}
{% else %}
{% set tw_slot = (over.slot_target or 'Diffuse')|trim %}
{% set tw_slot_l = tw_slot|lower %}
{% if tw_slot_l[:4] == 'ps-t' %}
{{ tw_slot }} = ref Resource{{ utils.clean_resource(over.resource_name) }}
{% else %}
Resource\ZZMI\{{ TW_ZZMI_SLOT_MAP.get(tw_slot_l, tw_slot) }} = ref Resource{{ utils.clean_resource(over.resource_name) }}
run = CommandList\ZZMI\SetTextures
{% endif %}
{% endif %}
endif
{% else %}
{% if over.resource_name %}
local $TW_override_is_initialised
if $TW_override_is_initialised != 1
$TW_override_is_initialised = 0
endif
if $TW_override_is_initialised > 0
this = Resource{{ utils.clean_resource(over.resource_name) }}
run = CommandListSafeTexWorks.{{ utils.clean_resource(over.resource_name) }}.CHECK
endif
$TW_override_is_initialised = 1
{% endif %}
{% endif %}
{% endfor %}

{% set unique_over_resources = rzm.tw_overrides | rejectattr('override_mode', 'equalto', 'IB_DIRECT') | map(attribute='resource_name') | unique %}
{% for res_name in unique_over_resources if res_name %}
[CommandListSafeTexWorks.{{ utils.clean_resource(res_name) }}.CHECK]
local $isInit = 0
if this === null && $isInit == 0
    this = copy Resource{{ utils.clean_resource(res_name) }}
    if this === null
        $isInit = 0
    else
        $isInit = 1
    endif
endif
{% endfor %}

; --- 3. MAIN BLOCKS ---
{% for block in rzm.tw_blocks %}
; Block: {{ block.name }} ({{ block.shader_type }})
{% set block_res = utils.clean_resource(block.resource_name) %}
{% set tex_block_name = block.shared_textures_block if block.use_shared_textures and block.shared_textures_block else block.name %}

{# Auto-generate resource if output resource name is missing #}
{% if not block.resource_name %}
{% set block_res = block.name ~ "_Atlas" %}
[Resource{{ block_res }}]
type = RWTexture2D
width = 4096
height = 4096
format = DXGI_FORMAT_R8G8B8A8_TYPELESS
array = 1
msaa = 1
mips = 1
{% endif %}

{% if block.backdrop_enabled and block.backdrop_resource_name %}
[CommandListBlock_{{ block.name }}.GlobalInit]
run = CustomShaderBlockBackdrop_{{ block.name }}
$TW_Global_Init_Needed_{{ block.name }} = 0

[CustomShaderBlockBackdrop_{{ block.name }}]
run = CommandListTexWorks.SaveTexWorksVALS
cs = /modules/cs_update_region.hlsl
cs-u0 = ref Resource{{ block_res }}
cs-t0 = Resource{{ utils.clean_resource(block.backdrop_resource_name) }}
cs-t1 = null
x44 = {{ block.backdrop_rect[0] }}
y44 = {{ block.backdrop_rect[1] }}
z44 = {{ block.backdrop_rect[2] }}
w44 = {{ block.backdrop_rect[3] }}
x24 = 0.0
dispatch = ({{ block.backdrop_rect[2] }} + 31) // 32, ({{ block.backdrop_rect[3] }} + 31) // 32, 1
run = CommandListTexWorks.RestoreTexWorksVALS
{% endif %}
{% for comp in block.components %}
; --- Component: {{ comp.name }} ---
{% set comp_path = "TexWorks/" ~ block.name ~ "/" ~ comp.name %}
{% if comp.mask_enabled %}
{% if not block.use_shared_textures %}
[Resource{{ block.name }}{{ comp.name }}Mask]
filename = {{ comp_path }}/mask.png
{% endif %}
{% endif %}

[CommandListUpdateComp_{{ block.name }}_{{ comp.name }}]
{# 1. Base initialization pass #}
run = CustomShaderUpdateCompBase_{{ block.name }}_{{ comp.name }}

{# 2. HSV Adjustments #}
{% for slot in comp.slots if slot.active %}
    {% if slot.hsv_enabled and slot.hsv_link %}
run = CustomShaderUpdateSlotHSV_{{ block.name }}_{{ comp.name }}_{{ slot.name }}
    {% endif %}
{% endfor %}

{# 3. Decal Layers #}
{% for slot in comp.slots if slot.active %}
    {% for layer in slot.decal_layers if layer.active %}
        {% if slot.warp_p0_debug %}
x30 = $RZM_DEBUG_VALUE_0
y30 = $RZM_DEBUG_VALUE_1
x31 = $RZM_DEBUG_VALUE_2
y31 = $RZM_DEBUG_VALUE_3
x32 = $RZM_DEBUG_VALUE_4
y32 = $RZM_DEBUG_VALUE_5
x33 = $RZM_DEBUG_VALUE_6
y33 = $RZM_DEBUG_VALUE_7
x34 = $RZM_DEBUG_VALUE_8
y34 = $RZM_DEBUG_VALUE_9
x35 = $RZM_DEBUG_VALUE_10
y35 = $RZM_DEBUG_VALUE_11
x36 = $RZM_DEBUG_VALUE_12
y36 = $RZM_DEBUG_VALUE_13
x37 = $RZM_DEBUG_VALUE_14
y37 = $RZM_DEBUG_VALUE_15
x38 = $RZM_DEBUG_VALUE_16
y38 = $RZM_DEBUG_VALUE_17
        {% endif %}
run = CustomShaderUpdateLayer_{{ block.name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}_P0
        {% if slot.warp_p0_debug %}
x30 = 0
y30 = 0
x31 = 0
y31 = 0
x32 = 0
y32 = 0
x33 = 0
y33 = 0
x34 = 0
y34 = 0
x35 = 0
y35 = 0
x36 = 0
y36 = 0
x37 = 0
y37 = 0
x38 = 0
y38 = 0
        {% endif %}
        {% if slot.multi_pass_mode != 'NONE' %}
            {% if slot.warp_p1_debug %}
x30 = $RZM_DEBUG_VALUE_0
y30 = $RZM_DEBUG_VALUE_1
x31 = $RZM_DEBUG_VALUE_2
y31 = $RZM_DEBUG_VALUE_3
x32 = $RZM_DEBUG_VALUE_4
y32 = $RZM_DEBUG_VALUE_5
x33 = $RZM_DEBUG_VALUE_6
y33 = $RZM_DEBUG_VALUE_7
x34 = $RZM_DEBUG_VALUE_8
y34 = $RZM_DEBUG_VALUE_9
x35 = $RZM_DEBUG_VALUE_10
y35 = $RZM_DEBUG_VALUE_11
x36 = $RZM_DEBUG_VALUE_12
y36 = $RZM_DEBUG_VALUE_13
x37 = $RZM_DEBUG_VALUE_14
y37 = $RZM_DEBUG_VALUE_15
x38 = $RZM_DEBUG_VALUE_16
y38 = $RZM_DEBUG_VALUE_17
            {% endif %}
run = CustomShaderUpdateLayer_{{ block.name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}_P1
            {% if slot.warp_p1_debug %}
x30 = 0
y30 = 0
x31 = 0
y31 = 0
x32 = 0
y32 = 0
x33 = 0
y33 = 0
x34 = 0
y34 = 0
x35 = 0
y35 = 0
x36 = 0
y36 = 0
x37 = 0
y37 = 0
x38 = 0
y38 = 0
            {% endif %}
        {% endif %}
    {% endfor %}
{% endfor %}

{# --- Shaders for Component --- #}

[CustomShaderUpdateCompBase_{{ block.name }}_{{ comp.name }}]
run = CommandListTexWorks.SaveTexWorksVALS
cs = /modules/cs_update_region.hlsl
cs-u0 = ref Resource{{ block_res }}
{% if comp.base_resource_name %}
cs-t0 = Resource{{ utils.clean_resource(comp.base_resource_name) }}
{% elif block.backdrop_enabled and block.backdrop_resource_name %}
cs-t0 = Resource{{ utils.clean_resource(block.backdrop_resource_name) }}
{% else %}
cs-t0 = null
{% endif %}
cs-t2 = {% if comp.mask_enabled %}Resource{{ comp.name }}Mask{% else %}null{% endif %}


{% if comp.tex_morph_enabled and comp.tex_morph_resource_name %}
cs-t1 = Resource{{ utils.clean_resource(comp.tex_morph_resource_name) }}
{% else %}
cs-t1 = null
{% endif %}
{% if comp.hsv_enabled is true%}
{% set v_name = utils.format_var(comp.hsv_link) %}
{% set v_base = comp.hsv_base %}
{# COMPATIBILITY FIX: Robust dictionary lookup and scoping fix #}
{% set ns = {'v_obj': none, 'v_base': comp.hsv_base} %}
{% set v_target = comp.hsv_link.lstrip('$@#%').strip()|lower %}
{% for val in rzm.rzm_values %}
    {% if val.value_name.lstrip('$@#%').strip()|lower == v_target %}
        {% if ns.update({'v_obj': val}) or true %}{% endif %}
    {% endif %}
{% endfor %}
{% set v_obj = ns.v_obj %}
{% if v_obj and v_obj.value_type == 'VECTOR' %}
    {# If component base in UI is (0,0,0), use variable default from blender #}
    {% if comp.hsv_base[0] == 0 and comp.hsv_base[1] == 0 and comp.hsv_base[2] == 0 %}
        {% if ns.update({'v_base': v_obj.vector_value}) or true %}{% endif %}
    {% endif %}
{% endif %}
{% set v_base = ns.v_base %}
x43 = ${{ v_name }}_X - {{ "%.3f"|format(v_base[0]) }}
y43 = ${{ v_name }}_Y - {{ "%.3f"|format(v_base[1]) }}
z43 = ${{ v_name }}_Z - {{ "%.3f"|format(v_base[2]) }}
w43 = {{ "%.3f"|format(v_base[3]) }}
{% endif %}

x44 = {{ comp.rect[0] }}
y44 = {{ comp.rect[1] }}
z44 = {{ comp.rect[2] }}
w44 = {{ comp.rect[3] }}
;x45 = {{ comp.base_rect[0] }}
;y45 = {{ comp.base_rect[1] }}
;z45 = {{ comp.base_rect[2] }}
;w45 = {{ comp.base_rect[3] }}

{# RZM_TEXMORPH: Фактор смешивания #}
{% if comp.tex_morph_enabled and comp.tex_morph_link %}
x24 = ${{ utils.format_var(comp.tex_morph_link) }}
{% else %}
x24 = 0.0
{% endif %}

{% if comp.mask_enabled %}
w24 = 1
{% else %}
w24 = 0
{% endif %}

dispatch = ({{ comp.rect[2] }} + 31) // 32, ({{ comp.rect[3] }} + 31) // 32, 1
run = CommandListTexWorks.RestoreTexWorksVALS

{% for slot in comp.slots if slot.active %}
{# Slot Resources (Masks, Decal variations, Config Buffer) #}
{% if slot.mask_enabled %}
{% if not block.use_shared_textures %}
[Resource{{ block.name }}{{ comp.name }}{{ slot.name }}Mask]
{% set clean_comp = comp.name.replace(" ", "") %}
{% set clean_slot = slot.name.replace(" ", "") %}
filename = {{ comp_path }}/{{ slot.name }}/{{ clean_comp }}{{ clean_slot }}.MASK.png
{% endif %}
{% endif %}

{# New Config Buffers for Slot #}
{% if not comp.use_shared_config %}
[Resource.TexWorks.{{ block.name }}.{{ comp.name }}.{{ slot.name }}.Config.P0]
type = Buffer
format = R32_FLOAT
array = 8
{% set p0_x = comp.rect[0] + slot.rect[0] %}
{% set p0_y = comp.rect[1] + slot.rect[1] %}
{% set p0_w = slot.rect[2] %}
{% set p0_h = slot.rect[3] %}
{% set p0_rot = slot.rotation %}
{% set p0_dmy = slot.dummy %}
{% set p0_mir = 1.0 if slot.mirror else 0.0 %}
{% set p0_flp = 1.0 if slot.flip else 0.0 %}
data = {{ p0_x }} {{ p0_y }} {{ p0_w }} {{ p0_h }} {{ p0_rot }} {{ p0_dmy }} {{ p0_mir }} {{ p0_flp }}

{% if slot.multi_pass_mode != 'NONE' %}
[Resource.TexWorks.{{ block.name }}.{{ comp.name }}.{{ slot.name }}.Config.P1]
type = Buffer
format = R32_FLOAT
array = 8
{% set p1_x = slot.multi_pass_rect[0] %}
{% set p1_y = slot.multi_pass_rect[1] %}
{% set p1_w = slot.multi_pass_rect[2] %}
{% set p1_h = slot.multi_pass_rect[3] %}
{% set p1_rot = slot.multi_pass_rotation %}
{% set p1_dmy = slot.multi_pass_dummy %}
{% set p1_mir = 1.0 if slot.multi_pass_mirror else 0.0 %}
{% set p1_flp = 1.0 if slot.multi_pass_flip else 0.0 %}
data = {{ p1_x }} {{ p1_y }} {{ p1_w }} {{ p1_h }} {{ p1_rot }} {{ p1_dmy }} {{ p1_mir }} {{ p1_flp }}
{% endif %}
{% endif %}

{# Warp Buffers #}
{% if not comp.use_shared_config %}
{% if slot.warp_p0_enabled %}
[Resource.TexWorks.{{ block.name }}.{{ comp.name }}.{{ slot.name }}.Config.Warp.P0]
type = Buffer
format = R32G32_FLOAT
array = 9
data = {% for v in slot.warp_p0_grid %}{{ "%.5f"|format(v) }} {% endfor %}
{% endif %}

{% if slot.warp_p1_enabled %}
[Resource.TexWorks.{{ block.name }}.{{ comp.name }}.{{ slot.name }}.Config.Warp.P1]
type = Buffer
format = R32G32_FLOAT
array = 9
data = {% for v in slot.warp_p1_grid %}{{ "%.5f"|format(v) }} {% endfor %}
{% endif %}
{% endif %}

{% if not block.use_shared_textures %}
{% for layer in slot.decal_layers if layer.active %}
    {% for i in range(layer.count) %}
        {% set file_suffix = "" %}
        {% if block.shader_type == 'NORMAL' %}{% set file_suffix = "_N" %}{% endif %}
        {% if block.shader_type == 'MATERIAL' %}{% set file_suffix = "_M" %}{% endif %}
[Resource_{{ block.name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}.{{ i }}]
filename = {{ comp_path }}/{{ slot.name }}/{{ layer.name }}/{{ i }}{{ file_suffix }}.png
    {% endfor %}
{% endfor %}
{% endif %}

{# HSV Compute Shader (TODO: Optional - currently updated to use buffer logic if needed) #}
{% if slot.hsv_enabled and slot.hsv_link %}
[CustomShaderUpdateSlotHSV_{{ block.name }}_{{ comp.name }}_{{ slot.name }}]
run = CommandListTexWorks.SaveTexWorksVALS
cs = /modules/decal_draw_hsv.hlsl
cs-u0 = ref Resource{{ block_res }}
cs-t0 = null

cs-t5 = {% if slot.hsv_mask_enabled %}Resource{{ tex_block_name }}{{ comp.name }}{{ slot.name }}Mask{% elif comp.mask_enabled %}Resource{{ tex_block_name }}{{ comp.name }}Mask{% else %}null{% endif %}
{% set v_name = utils.format_var(slot.hsv_link) %}
{% set v_base = slot.hsv_base %}
{# COMPATIBILITY FIX: Robust dictionary lookup and scoping fix #}
{% set ns = {'v_obj': none, 'v_base': slot.hsv_base} %}
{% set v_target = slot.hsv_link.lstrip('$@#%').strip()|lower %}
{% for val in rzm.rzm_values %}
    {% if val.value_name.lstrip('$@#%').strip()|lower == v_target %}
        {% if ns.update({'v_obj': val}) or true %}{% endif %}
    {% endif %}
{% endfor %}
{% set v_obj = ns.v_obj %}
{% if v_obj and v_obj.value_type == 'VECTOR' %}
    {# If slot base in UI is (0,0,0), use variable default from blender #}
    {% if slot.hsv_base[0] == 0 and slot.hsv_base[1] == 0 and slot.hsv_base[2] == 0 %}
        {% if ns.update({'v_base': v_obj.vector_value}) or true %}{% endif %}
    {% endif %}
{% endif %}
{% set v_base = ns.v_base %}

x43 = ${{ v_name }}_X - {{ "%.3f"|format(v_base[0]) }}
y43 = ${{ v_name }}_Y - {{ "%.3f"|format(v_base[1]) }}
z43 = ${{ v_name }}_Z - {{ "%.3f"|format(v_base[2]) }}
w43 = {{ "%.3f"|format(v_base[3]) }}
x44 = {{ comp.rect[0] + slot.rect[0] }}
y44 = {{ comp.rect[1] + slot.rect[1] }}
z44 = {{ slot.rect[2] }}
w44 = {{ slot.rect[3] }}
x45 = 0.0
y45 = 0.0
z45 = 0.0
w45 = 0.0

{% if slot.hsv_mask_enabled %}
w24 = 1 
{% else %}
w24 = 0
{% endif %}
dispatch = ({{ slot.rect[2] }} + 31) // 32, ({{ slot.rect[3] }} + 31) // 32, 1
run = CommandListTexWorks.RestoreTexWorksVALS
{% endif %}

{# Layer Compute Shaders #}
{% for layer in slot.decal_layers if layer.active %}
{% set l_var_base = "TW_D" ~ comp.name ~ slot.name ~ layer.name %}
{% set material = rzm.tw_materials.get(layer.name) %}

{# SHARED PARAMETERS MACRO #}
{% macro layer_shader_params(pass_idx) %}
{% set warp_enabled = (pass_idx == 0 and slot.warp_p0_enabled) or (pass_idx == 1 and slot.warp_p1_enabled) %}
cs = /modules/{% if warp_enabled %}decal_draw_wrap.hlsl{% else %}decal_draw.hlsl{% endif %}

cs-u0 = ref Resource{{ block_res }}
cs-t0 = null
cs-t5 = {% if slot.mask_enabled %}Resource{{ tex_block_name }}{{ comp.name }}{{ slot.name }}Mask{% else %}null{% endif %}

{% set cfg_block = comp.shared_config_block if comp.use_shared_config and comp.shared_config_block else block.name %}
{% set cfg_comp = comp.shared_config_component if comp.use_shared_config and comp.shared_config_component else comp.name %}

cs-t6 = Resource.TexWorks.{{ cfg_block }}.{{ cfg_comp }}.{{ slot.name }}.Config.P{{ pass_idx }}

{% if pass_idx == 0 and slot.warp_p0_enabled %}
cs-t7 = Resource.TexWorks.{{ cfg_block }}.{{ cfg_comp }}.{{ slot.name }}.Config.Warp.P0
{% elif pass_idx == 1 and slot.warp_p1_enabled %}
cs-t7 = Resource.TexWorks.{{ cfg_block }}.{{ cfg_comp }}.{{ slot.name }}.Config.Warp.P1
{% endif %}

;x45 = {{ "%.1f"|format(comp.rect[0]) }}
;y45 = {{ "%.1f"|format(comp.rect[1]) }}
;z45 = {{ "%.1f"|format(comp.rect[2]) }}
;w45 = {{ "%.1f"|format(comp.rect[3]) }}

{% if scene.rzm.addons.debugger_info %}
; Debug override data from UI (Linked to persist vars)
{% endif %}
{% endmacro %}

{# --- PASS 0 SHADER --- #}
[CustomShaderUpdateLayer_{{ block.name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}_P0]
{{ layer_shader_params(0) }}
if ${{ l_var_base }}Index0 >= 0
    {# Index Switching Pass 0 #}
    {% for i in range(layer.count) %}
    {% if loop.first %}if ${{ l_var_base }}Index0 == {{ i }}{% else %}elif ${{ l_var_base }}Index0 == {{ i }}{% endif %}

        cs-t0 = Resource_{{ tex_block_name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}.{{ i }}
    {% endfor %}
    endif
    w24 = {{ 1.0 if (slot.mask_enabled and slot.pass0_use_mask) else 0.0 }}
    dispatch = ({{ slot.rect[2] }} + 31) // 32, ({{ slot.rect[3] }} + 31) // 32, 1
endif

{# --- PASS 1 SHADER --- #}
{% if slot.multi_pass_mode != 'NONE' %}
[CustomShaderUpdateLayer_{{ block.name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}_P1]
{{ layer_shader_params(1) }}
{% set p1_idx_var = l_var_base ~ "Index1" if slot.multi_pass_mode == 'INDIVIDUAL' else l_var_base ~ "Index0" %}
if ${{ p1_idx_var }} >= 0
    {# Index Switching Pass 1 #}
    {% for i in range(layer.count) %}
    {% if loop.first %}if ${{ p1_idx_var }} == {{ i }}{% else %}elif ${{ p1_idx_var }} == {{ i }}{% endif %}

        cs-t0 = Resource_{{ tex_block_name }}_{{ comp.name }}_{{ slot.name }}_{{ layer.name }}.{{ i }}
    {% endfor %}
    endif
    w24 = {{ 1.0 if (slot.mask_enabled and slot.pass1_use_mask) else 0.0 }}
    dispatch = ({{ slot.multi_pass_rect[2] }} + 31) // 32, ({{ slot.multi_pass_rect[3] }} + 31) // 32, 1
endif
{% endif %}
{% endfor %}
{% endfor %}
{% endfor %}
{% endfor %}

; --- 4. INITIALIZATION & HIERARCHY ---
[Constants]
{% for block in rzm.tw_blocks %}
global $TW_Init_Needed_{{ block.name }} = 1
global $TW_Global_Init_Needed_{{ block.name }} = 1
{% endfor %}

{% set tw_vars %}
{% set processed_vars = [] %}
{% for block in rzm.tw_blocks %}
    {% for comp in block.components %}
global $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 0
global $Comp_{{ block.name }}_{{ comp.name }}_PastSum = -1
        {% for slot in comp.slots if slot.active %}
            {% for layer in slot.decal_layers if layer.active %}
                {% set l_var_base = "TW_D" ~ comp.name ~ slot.name ~ layer.name %}
global persist ${{ l_var_base }}Index0 = -1
global ${{ l_var_base }}IndexPast0 = -1
                {% if slot.multi_pass_mode == 'INDIVIDUAL' %}
global persist ${{ l_var_base }}Index1 = -1
global ${{ l_var_base }}IndexPast1 = -1
                {% endif %}
            {% endfor %}
        {% endfor %}
    {% endfor %}
{% endfor %}
{% endset %}
{{ utils.deduplicate(tw_vars) }}

[CommandListTexWorks]
if $ModInitialised == 1
    {% for block in rzm.tw_blocks %}
    run = CommandListBlock_{{ block.name }}
    {% endfor %}
    run = CommandListTexWorks_Finalize
    $TWInitialised = 1
endif

{% for block in rzm.tw_blocks %}
[CommandListBlock_{{ block.name }}]
{# Shader Config Injection #}
x43 = {{ "%.3f"|format(block.shader_config[0]) }}
y43 = {{ "%.3f"|format(block.shader_config[1]) }}
z43 = {{ "%.3f"|format(block.shader_config[2]) }}
w43 = {{ "%.3f"|format(block.shader_config[3]) }}

x47 = {{ "%.3f"|format(block.shader_overlay[0]) }}
y47 = {{ "%.3f"|format(block.shader_overlay[1]) }}
z47 = {{ "%.3f"|format(block.shader_overlay[2]) }}
w47 = {{ "%.3f"|format(block.shader_overlay[3]) }}

{# Global Backdrop Init (Runs Once) #}
{% if block.backdrop_enabled and block.backdrop_resource_name %}
if $TW_Global_Init_Needed_{{ block.name }} == 1
    run = CommandListBlock_{{ block.name }}.GlobalInit
endif
{% endif %}

{# Initialization #}
if $TW_Init_Needed_{{ block.name }} == 1
    {% for comp in block.components %}
    $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 1
    {% endfor %}
    $TW_Init_Needed_{{ block.name }} = 0
endif

{% for comp in block.components %}
{# 1. Check Decal Changes #}
{% for slot in comp.slots if slot.active %}
    {% for layer in slot.decal_layers if layer.active %}
        {% set l_var_base = "TW_D" ~ comp.name ~ slot.name ~ layer.name %}
if ${{ l_var_base }}Index0 != ${{ l_var_base }}IndexPast0
    $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 1
endif
        {% if slot.multi_pass_mode == 'INDIVIDUAL' %}
if ${{ l_var_base }}Index1 != ${{ l_var_base }}IndexPast1
    $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 1
endif
        {% endif %}
    {% endfor %}
{% endfor %}

{# 2. Check HSV Changes #}
{% set sum_parts = [] %}

{# --- ДОБАВИТЬ ВОТ ЭТОТ БЛОК --- #}
{% if comp.hsv_enabled and comp.hsv_link %}
    {% set cv_name = utils.format_var(comp.hsv_link) %}
    {% set _ = sum_parts.append("$" ~ cv_name ~ "_X") %}
    {% set _ = sum_parts.append("$" ~ cv_name ~ "_Y") %}
    {% set _ = sum_parts.append("$" ~ cv_name ~ "_Z") %}
    {% set _ = sum_parts.append("$" ~ cv_name ~ "_W") %}
{% endif %}
{# ------------------------------ #}

{% for slot in comp.slots if slot.active %}
    {% if slot.hsv_link %}
        {% set v_name = utils.format_var(slot.hsv_link) %}
        {% set _ = sum_parts.append("$" ~ v_name ~ "_X") %}
        {% set _ = sum_parts.append("$" ~ v_name ~ "_Y") %}
        {% set _ = sum_parts.append("$" ~ v_name ~ "_Z") %}
        {% set _ = sum_parts.append("$" ~ v_name ~ "_W") %}
    {% endif %}
{% endfor %}
{# RZM_TEXMORPH: Учитываем фактор морфинга в сумме изменений компонента #}
{% if comp.tex_morph_enabled and comp.tex_morph_link %}
    {% set m_var = utils.format_var(comp.tex_morph_link) %}
    {% set _ = sum_parts.append("$" ~ m_var) %}
{% endif %}
{% if sum_parts %}
local $current_sum_{{ block.name }}_{{ comp.name }} = {{ sum_parts | join(' + ') }}
if $Comp_{{ block.name }}_{{ comp.name }}_PastSum != $current_sum_{{ block.name }}_{{ comp.name }}
    $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 1
endif
{% endif %}

{# 3. Conditional Update #}
if $TW_{{ block.name }}_{{ comp.name }}_Is_Updated == 1
    run = CommandListUpdateComp_{{ block.name }}_{{ comp.name }}
    $TW_{{ block.name }}_{{ comp.name }}_Is_Updated = 0
endif
{% endfor %}
{% endfor %}

[CommandListTexWorks_Finalize]
{# Finalizing Indices Sync #}
{% for block in rzm.tw_blocks %}
    {% for comp in block.components %}
        {% for slot in comp.slots if slot.active %}
            {% for layer in slot.decal_layers if layer.active %}
                {% set l_var_base = "TW_D" ~ comp.name ~ slot.name ~ layer.name %}
${{ l_var_base }}IndexPast0 = ${{ l_var_base }}Index0
                {% if slot.multi_pass_mode == 'INDIVIDUAL' %}
${{ l_var_base }}IndexPast1 = ${{ l_var_base }}Index1
                {% endif %}
            {% endfor %}
        {% endfor %}
        
        {% set sum_parts = [] %}

        {% if comp.hsv_enabled and comp.hsv_link %}
            {% set cv_name = utils.format_var(comp.hsv_link) %}
            {% set _ = sum_parts.append("$" ~ cv_name ~ "_X") %}
            {% set _ = sum_parts.append("$" ~ cv_name ~ "_Y") %}
            {% set _ = sum_parts.append("$" ~ cv_name ~ "_Z") %}
            {% set _ = sum_parts.append("$" ~ cv_name ~ "_W") %}
        {% endif %}

        {% for slot in comp.slots if slot.active %}
            {% if slot.hsv_link %}
                {% set v_name = utils.format_var(slot.hsv_link) %}
                {% set _ = sum_parts.append("$" ~ v_name ~ "_X") %}
                {% set _ = sum_parts.append("$" ~ v_name ~ "_Y") %}
                {% set _ = sum_parts.append("$" ~ v_name ~ "_Z") %}
                {% set _ = sum_parts.append("$" ~ v_name ~ "_W") %}
            {% endif %}
        {% endfor %}
        {% if comp.tex_morph_enabled and comp.tex_morph_link %}
            {% set m_var = utils.format_var(comp.tex_morph_link) %}
            {% set _ = sum_parts.append("$" ~ m_var) %}
        {% endif %}
        {% if sum_parts %}
$Comp_{{ block.name }}_{{ comp.name }}_PastSum = {{ sum_parts | join(' + ') }}
        {% endif %}
    {% endfor %}
{% endfor %}


{# Reset Shader Config #}
x46 = 1.0
y46 = 1.0
z46 = 1.0
w46 = 1.0

x47 = 0.0
y47 = 0.0
z47 = 0.0
w47 = 0.0


{% endmacro %}

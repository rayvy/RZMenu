{
    "Window": [
        {"label": "Screen Width", "text": "$ScreenWidth"},
        {"label": "Screen Height", "text": "$ScreenHeight"},
        {"label": "Safe Width", "text": "$SafeWidth"},
        {"label": "Safe Height", "text": "$SafeHeight"}
    ],
    "Properties": [
        {"label": "Active Element ID", "text": "{{element.id}}"},
        {"label": "Element X Pos", "text": "{{element.position[0]}}"},
        {"label": "Element Width", "text": "{{element.size[0]}}"},
        {"label": "Active Page Color (R)", "text": "{{element.page_color[0]}}"}
    ],
    "Variables": [
        {"label": "First Link Name", "text": "{{element.value_link[0].value_name}}"},
        {"label": "First Link Value", "text": "${{element.value_link[0].value_name}}"},
        {"label": "First Link Range", "text": "clamp(value, {{element.value_link[0].value_min}}, {{element.value_link[0].value_max}})"}
    ],
    "Logic": [
        {
            "label": "Cycle Value Link",
            "text": [
                "if {{element.value_link[0].value_name}} < {{element.value_link[0].value_max}}",
                "    {{element.value_link[0].value_name}} = {{element.value_link[0].value_name}} + 1",
                "else:",
                "    {{element.value_link[0].value_name}} = 0"
            ]
        }
    ],
    "Math": [
        {"label": "Clamp(v, min, max)", "text": "clamp(value, 0, 1)"},
        {"label": "Lerp(a, b, t)", "text": "lerp(0, 100, $ScreenWidth / 1920)"},
        {"label": "Pulse(speed)", "text": "sin($Time * speed) * 0.5 + 0.5"}
    ]
}
